               return results;\n            }\n            if (!keyComparator_(entry.key, minKey)) {\n                // \\u6761\\u76EE\\u952E >= minKey\\uFF0C\\u6DFB\\u52A0\\u503C\n                results.insert(results.end(), entry.values.begin(), entry.values.end());\n            }\n        }\n\n        // 4. \\u79FB\\u52A8\\u5230\\u4E0B\\u4E00\\u4E2A\\u53F6\\u5B50\n        currentLeafId = currentLeaf.getNextLeafId();\n    }\n\n    return results;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u8303\\u56F4\\u67E5\\u8BE2\\u904D\\u5386\"}),\"\\uFF1A\"]}),`\n`,(0,e.jsx)(l,{chart:`graph LR\n    A[\\u67E5\\u627E\\u8D77\\u59CB\\u53F6\\u5B50] --> B[\\u626B\\u63CF\\u53F6\\u5B50]\n    B --> C[\\u6536\\u96C6\\u5339\\u914D\\u6761\\u76EE]\n    C --> D{\\u66F4\\u591A\\u53F6\\u5B50?}\n    D -->|\\u662F| E[\\u8DDF\\u968F\\u4E0B\\u4E00\\u4E2A\\u94FE\\u63A5]\n    E --> B\n    D -->|\\u5426| F[\\u8FD4\\u56DE\\u7ED3\\u679C]`}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u5927\\u6570\\u636E\\u7684 Blob \\u5B58\\u50A8\"}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u5F53\\u952E/\\u503C\\u4E0D\\u9002\\u5408\\u5185\\u8054\\u5B58\\u50A8\\u65F6\"}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u9608\\u503C\"}),\"\\uFF1A\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"\\u5185\\u90E8\\u952E\\uFF1A32 \\u5B57\\u8282\\u5185\\u8054\"}),`\n`,(0,e.jsx)(n.li,{children:\"\\u53F6\\u5B50\\u952E\\uFF1A32 \\u5B57\\u8282\\u5185\\u8054\"}),`\n`,(0,e.jsx)(n.li,{children:\"\\u53F6\\u5B50\\u503C\\uFF1A32 \\u5B57\\u8282\\u5185\\u8054\"}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Blob \\u5B58\\u50A8\\u7B56\\u7565\"}),\"\\uFF1A\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`struct Entry {\n    PropertyValue key;\n    std::vector<int64_t> values;\n    int64_t keyBlobId = 0;      // \\u8D85\\u5927\\u952E\\u7684 blob\n    int64_t valuesBlobId = 0;   // \\u8D85\\u5927\\u503C\\u5217\\u8868\\u7684 b