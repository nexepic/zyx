ob'})\n# Another automatic transaction\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Explicit Transaction Mode\"}),`\n`,(0,e.jsx)(n.p,{children:\"In explicit transaction mode, you control when to commit:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Enter transaction mode\nzyx> BEGIN\n\n# All statements are part of this transaction\nzyx (transaction)> CREATE (p:Person {name: 'Charlie'})\nzyx (transaction)> CREATE (p:Person {name: 'Diana'})\n\n# Only commit when ready\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Transaction Isolation\"}),`\n`,(0,e.jsx)(n.p,{children:\"ZYX provides isolation between concurrent transactions:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Terminal 1\nzyx> BEGIN\nzyx (transaction)> MATCH (n:Person) WHERE name = 'Alice'\nzyx (transaction)> SET n.age = 31\n\n# Terminal 2 (concurrent)\nzyx> BEGIN\nzyx (transaction)> MATCH (n:Person) WHERE name = 'Alice'\n# Sees the original age value\n\n# Terminal 1\nzyx (transaction)> COMMIT\n\n# Terminal 2\nzyx (transaction)> COMMIT\n# May fail due to concurrent modification\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Transaction Best Practices\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Keep Transactions Short\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# GOOD: Short, focused transaction\nzyx> BEGIN\nzyx (transaction)> CREATE (p:Person {name: 'Eve'})\nzyx (transaction)> COMMIT\n\n# AVOID: Long-running transaction\nzyx> BEGIN\nzyx (transaction)> CREATE (p:Person {name: 'Frank'})\n# ... wait for user input ...\nzyx (transaction)> CREATE (p:Person {name: 'Grace'})\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Handle Errors Gracefully\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Start transaction\nzyx> BEGIN\n\n# Try operations\nzyx (transaction)> CREATE (p:Person {name: 'Henry', age: 28})\nzyx (transaction)> CREATE (p:Person {name: 'Iris', age: 32})\n\n# Check for errors before committing\nzyx (transaction)> MATCH (n:Person) WHERE n.name IN ['Henry', 'Iris']\nzyx (transaction)> RETURN count(n) AS created\n\n# If count is 2, commit\nzyx (transaction)> COMMIT\n\n# Otherwise rollback\nzyx (transaction)> ROLLBACK\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Use Transactions for Data Integrity\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Ensure referential integrity\nzyx> BEGIN\n\n# Create department\nzyx (transaction)> CREATE (d:Department {name: 'Engineering'})\n\n# Create employee\nzyx (transaction)> CREATE (e:Employee {name: 'Jack'})\n\n# Link them\nzyx (transaction)> MATCH (d:Department {name: 'Engineering'}), (e:Employee {name: 'Jack'})\nzyx (transaction)> CREATE (e)-[:WORKS_IN]->(d)\n\n# Only commit if all succeed\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Transaction Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Insert with Transaction\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Insert multiple related records\nzyx> BEGIN\n\n# Insert user\nzyx (transaction)> CREATE (u:User {id: 1, name: 'Alice'})\n\n# Insert user settings\nzyx (transaction)> CREATE (s:Settings {user_id: 1, theme: 'dark'})\n\n# Link them\nzyx (transaction)> MATCH (u:User {id: 1}), (s:Settings {user_id: 1})\nzyx (transaction)> CREATE (u)-[:HAS_SETTINGS]->(s)\n\n# Commit all or none\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Update with Validation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Validate before committing\nzyx> BEGIN\n\n# Update record\nzyx (transaction)> MATCH (p:Person {name: 'Alice'})\nzyx (transaction)> SET p.age = 32\n\n# Verify update\nzyx (transaction)> MATCH (p:Person {name: 'Alice'})\nzyx (transaction)> RETURN p.age\n\n# If correct, commit; otherwise rollback\nzyx (transaction)> COMMIT\n`