th, pqTable);\n\n    // 6. \\u526A\\u679D\\u5019\\u9009\\u96C6\\u5E76\\u521B\\u5EFA\\u53CC\\u5411\\u8FB9\n    std::vector<int64_t> candidates;\n    for (auto& [id, dist] : neighbors) {\n        candidates.push_back(id);\n    }\n    prune(nodeId, candidates);\n\n    // 7. \\u4FDD\\u5B58\\u90BB\\u63A5\\u5173\\u7CFB\\u5E76\\u521B\\u5EFA\\u56DE\\u6307\\u94FE\\u63A5\n    registry_->saveAdjacency(nodeId, candidates);\n    for (int64_t neighbor : candidates) {\n        addBackLink(neighbor, nodeId);\n    }\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u590D\\u6742\\u5EA6\"}),\"\\uFF1AO(beamWidth \\xD7 maxDegree \\xD7 dim)\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u641C\\u7D22\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u4F7F\\u7528\\u675F\\u641C\\u7D22\\u67E5\\u627E k \\u4E2A\\u6700\\u8FD1\\u90BB\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> search(\n    const std::vector<float>& query,\n    size_t k\n) const {\n    // 1. \\u8BA1\\u7B97 PQ \\u8DDD\\u79BB\\u8868\\u4EE5\\u5B9E\\u73B0\\u5FEB\\u901F\\u8FD1\\u4F3C\n    auto pqTable = isPQTrained() ? quantizer_->computeDistanceTable(query) : std::vector<float>{};\n\n    // 2. \\u4F7F\\u7528\\u675F\\u5BBD\\u7684\\u8D2A\\u5A6A\\u641C\\u7D22\n    auto candidates = greedySearch(query, entryPoint, std::max(config_.beamWidth, k * 2), pqTable);\n\n    // 3. \\u4F7F\\u7528\\u7CBE\\u786E\\u8DDD\\u79BB\\u91CD\\u65B0\\u6392\\u5E8F\n    std::vector<std::pair<int64_t, float>> results;\n    for (auto& [nodeId, _] : candidates) {\n        float exactDist = distRaw(query, nodeId);\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. \\u6392\\u5E8F\\u5E76\\u8FD4\\u56DE top-k\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u590D\\u6742\\u5EA6\"}),\"\\uFF1AO(beamWidth \\xD7 maxDegree \\xD7 dim + k \\xD7 dim)\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u8D2A\\u5A6A\\u641C\\u7D22\\u7B97\\u6CD5\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u6838\\u5FC3\\u641C\\u7D22\\u7B97\\u6CD5\\u4F7F\\u7528\\u675F\\u641C\\u7D22\\u904D\\u5386\\u56FE\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> greedySearch(\n    const std::vector<float>& query,\n    int64_t startNode,\n    size_t beamWidth,\n    const std::vector<float>& pqTable\n) const {\n    std::unordered_set<int64_t> visited;\n    std::priority_queue<\n        std::pair<float, int64_t>,\n        std::vector<std::pair<float, int64_t>>,\n        std::greater<>\n    > queue;  // \\u6700\\u5C0F\\u5806\\uFF1A(\\u8DDD\\u79BB, \\u8282\\u70B9)\n\n    std::vector<std::pair<int64_t, float>> results;\n\n    // \\u4F7F\\u7528\\u5165\\u53E3\\u70B9\\u521D\\u59CB\\u5316\n    float startDist = computeDistance(query, pqTable, startNode);\n    queue.push({startDist, startNode});\n    visited.insert(startNode);\n    results.push_back({startNode, startDist});\n\n    // \\u675F\\u641C\\u7D22\\u904D\\u5386\n    while (!queue.empty()) {\n        auto [dist, currentNode] = queue.top();\n        queue.pop();\n\n        // \\u63A2\\u7D22\\u90BB\\u5C45\n        auto neighbors = registry_->loadAdjacency(currentNode);\n        for (int64_t neighbor : neighbors) {\n            if (visited.contains(neighbor)) continue;\n            visited.insert(neighbor);\n\n            float neighborDist = computeDistance(query, pqTable, neighbor);\n            results.push_back({neighbor, neighborDist});\n            queue.push({neighborDist, neighbor});\n        }\n    }\n\n    // \\u6392\\u5E8F\\u5E76\\u9650\\u5236\\u5230\\u675F\\u5BBD\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    if (results.size() > beamWidth) {\n        results.resize(beamWidth);\n    }\n\n    return results;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u641C\\u7D22\\u6D41\\u7A0B\"}),`\n`,(0,e.jsx)(i,{chart:`flowchart TD\n    Start([\\u5F00\\u59CB\\u67E5\\u8BE2]) --> Init[\\u4F7F\\u7528\\u5165\\u53E3\\u70B9\\u521D\\u59CB\\u5316\\u961F\\u5217]\n    Init --> Loop{\\u961F\\u5217\\u4E3A\\u7A7A?}\n    Loop -->|\\u5426| Pop[\\u5F39\\u51FA\\u6700\\u8FD1\\u7684\\u8282\\u70B9]\n    Pop --> Expand[\\u63A2\\u7D22\\u672A\\u8BBF\\u95EE\\u7684\\u90BB\\u5C45]\n    Expand --> Compute[\\u8BA1\\u7B97\\u5230\\u90BB\\u5C45\\u7684\\u8DDD\\u79BB]\n    Compute --> Push[\\u5C06\\u90BB\\u5C45\\u63A8\\u5165\\u961F\\u5217]\n    Push --> Loop\n    Loop -->|\\u662F| Sort[\\u6309\\u8DDD\\u79BB\\u6392\\u5E8F\\u7ED3\\u679C]\n    Sort --> Limit[\\u9650\\u5236\\u5230\\u675F\\u5BBD]\n    Limit --> Rerank[\\u4F7F\\u7528\\u7CBE\\u786E\\u8DDD\\u79BB\\u91CD\\u65B0\\u6392\\u5E8F]\n    Rerank --> Return([\\u8FD4\\u56DE top-k \\u7ED3\\u679C])`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u590D\\u6742\\u5EA6\"}),\"\\uFF1AO(beamWidth \\xD7 maxDegree \\xD7 dim)\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u526A\\u679D\\u7B56\\u7565\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u9C81\\u68D2\\u526A\\u679D\\u901A\\u8FC7\\u79FB\\u9664\\u5197\\u4F59\\u8FB9\\u6765\\u7EF4\\u62A4\\u56FE\\u8D28\\u91CF\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void prune(int64_t nodeId, std::vector<int64_t>& candidates) const {\n    // \\u52A0\\u8F7D\\u8282\\u70B9\\u5411\\u91CF\\u4EE5\\u8FDB\\u884C\\u7CBE\\u786E\\u8DDD\\u79BB\\u8BA1\\u7B97\n    auto nodeVec = loadRawVector(nodeId);\n\n    // 1. \\u6309\\u5230\\u8282\\u70B9\\u7684\\u8DDD\\u79BB\\u6392\\u5E8F\\u5019\\u9009\n    std::vector<std::pair<int64_t, float>> candDists;\n    for (int64_t candId : candidates) {\n        float dist = computeDistance(nodeVec, candId);\n        candDists.push_back({candId, dist});\n    }\n    std::sort(candDists.begin(), candDists.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n\n    // 2. Alpha \\u526A\\u679D\\uFF1A\\u79FB\\u9664\\u88AB\\u906E\\u6321\\u7684\\u5019\\u9009\n    std::vector<int64_t> result;\n    result.reserve(config_.maxDegree);\n\n    for (const auto& [candId, candDist] : candDists) {\n        if (result.size() >= config_.maxDegree) break;\n\n        bool occluded = false;\n        auto candVec = loadRawVector(candId);\n\n        // \\u68C0\\u67E5\\u5019\\u9009\\u662F\\u5426\\u88AB\\u73B0\\u6709\\u90BB\\u5C45\\u906E\\u6321\n        for (int64_t existingId : result) {\n            auto existingVec = loadRawVector(existingId);\n            float distExistingToCand = computeDistance(existingVec, candVec);\n\n            // \\u906E\\u6321\\u6761\\u4EF6\\uFF1Aalpha * dist(existing, cand) <= dist(node, cand)\n            if (config_.alpha * distExistingToCand <= candDist) {\n                occluded = true;\n                break;\n            }\n        }\n\n        if (!occluded) {\n            result.push_back(candId);\n        }\n    }\n\n    candidates = result;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u526A\\u679D\\u903B\\u8F91\"}),`\n`,(0,e.jsx)(i,{chart:`graph TD\n    A[\\u8282\\u70B9] -->|1.0| B[\\u5019\\u9009 1]\n    A -->|1.5| C[\\u5019\\u9009 2]\n    A -->|2.0| D[\\u5019\\u9009 3]\n\n    B -->|0.8| C\n    B -->|1.2| D\n\n\n    Note[\"\\u5019\\u9009 2 \\u88AB\\u906E\\u6321\\uFF1Aalpha*0.8 <= 1.5\"]`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u906E\\u6321\\u6761\\u4EF6\"}),\"\\uFF1A\\u5019\\u9009\\u88AB\\u906E\\u6321\\u7684\\u6761\\u4EF6\\u662F\\uFF1A\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`alpha \\xD7 distance(existing, candidate) \\u2264 distance(node, candidate)\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u590D\\u6742\\u5EA6\"}),\"\\uFF1AO(maxDegree\\xB2 \\xD7 dim)\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u4E58\\u79EF\\u91CF\\u5316\\u96C6\\u6210\"}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ \\u8BAD\\u7EC3\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void train(const std::vector<std::vector<float>>& samples) {\n    // \\u786E\\u5B9A\\u5B50\\u7A7A\\u95F4\\u914D\\u7F6E\n    size_t subDim = 8;  // \\u5B50\\u7A7A\\u95F4\\u7EF4\\u5EA6\n    size_t numSubspaces = config_.dim / subDim;  // \\u4F8B\\u5982\\uFF1A768/8 = 96\n\n    // \\u521B\\u5EFA\\u5E76\\u8BAD\\u7EC3\\u91CF\\u5316\\u5668\n    auto pq = std::make_unique<NativeProductQuantizer>(\n        config_.dim,\n        numSubspaces,\n        256  // \\u6BCF\\u4E2A\\u5B50\\u7A7A\\u95F4 256 \\u4E2A\\u8D28\\u5FC3\n    );\n    pq->train(samples);\n\n    // \\u6301\\u4E45\\u5316\\u91CF\\u5316\\u5668\n    registry_->saveQuantizer(*pq);\n    quantizer_ = std::move(pq);\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ \\u7F16\\u7801\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) const {\n    std::vector<uint8_t> codes(numSubspaces_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* subVec = vec.data() + offset;\n\n        // \\u67E5\\u627E\\u6700\\u8FD1\\u7684\\u8D28\\u5FC3\n        float minDist = std::numeric_limits<float>::max();\n        uint8_t bestIdx = 0;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                subVec,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n            if (dist < minDist) {\n                minDist = dist;\n                bestIdx = static_cast<uint8_t>(c);\n            }\n        }\n        codes[m] = bestIdx;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u8DDD\\u79BB\\u8BA1\\u7B97\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// \\u4E3A\\u67E5\\u8BE2\\u8BA1\\u7B97\\u8DDD\\u79BB\\u8868\\uFF08\\u6BCF\\u6B21\\u641C\\u7D22\\u8BA1\\u7B97\\u4E00\\u6B21\\uFF09\nstd::vector<float> computeDistanceTable(const std::vector<float>& query) const {\n    std::vector<float> table(numSubspaces_ * numCentroids_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* querySub = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            table[m * numCentroids_ + c] = VectorMetric::computeL2Sqr(\n                querySub,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n        }\n    }\n\n    return table;\n}\n\n// \\u4F7F\\u7528\\u8868\\u67E5\\u627E\\u7684\\u5FEB\\u901F PQ \\u8DDD\\u79BB\nfloat computeDistance(\n    const std::vector<float>& pqTable,\n    const std::vector<uint8_t>& codes\n) const {\n    float dist = 0.0f;\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        dist += pqTable[m * numCentroids_ + codes[m]];\n    }\n    return dist;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u6DF7\\u5408\\u6A21\\u5F0F\"}),`\n`,(0,e.jsx)(n.p,{children:\"ZYX \\u4F7F\\u7528\\u6DF7\\u5408\\u65B9\\u6CD5\\u6765\\u5E73\\u8861\\u901F\\u5EA6\\u548C\\u51C6\\u786E\\u6027\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) const {\n    auto ptrs = registry_->getBlobPtrs(targetId);\n\n    // \\u5982\\u679C\\u53EF\\u7528\\u4E14\\u5DF2\\u8BAD\\u7EC3\\uFF0C\\u4F7F\\u7528 PQ\n    if (isPQTrained() && ptrs.pqBlob != 0 && !pqTable.empty()) {\n        return distPQ(pqTable, targetId);\n    }\n\n    // \\u56DE\\u9000\\u5230\\u539F\\u59CB\\u5411\\u91CF\n    return distRaw(query, targetId);\n}\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"::: info \\u6DF7\\u5408\\u6A21\\u5F0F\\u7684\\u4F18\\u52BF\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u5BFC\\u822A\"}),\"\\uFF1A\\u4F7F\\u7528 PQ \\u8FDB\\u8