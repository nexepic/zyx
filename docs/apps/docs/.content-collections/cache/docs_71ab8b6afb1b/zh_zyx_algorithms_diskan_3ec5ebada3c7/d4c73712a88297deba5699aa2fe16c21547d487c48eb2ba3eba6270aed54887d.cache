loat* vecA,\n    const float* vecB,\n    size_t dim\n) {\n    float ip = 0.0f;\n    for (size_t i = 0; i < dim; ++i) {\n        ip += vecA[i] * vecB[i];\n    }\n    return -ip;  // \\u53D6\\u8D1F\\u4EE5\\u9002\\u5E94\\u6700\\u5C0F\\u5806\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u4F59\\u5F26\\u76F8\\u4F3C\\u5EA6\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`float computeCosine(\n    const float* vecA,\n    const float* vecB,\n    size_t dim\n) {\n    float dot = 0.0f, normA = 0.0f, normB = 0.0f;\n    for (size_t i = 0; i < dim; ++i) {\n        dot += vecA[i] * vecB[i];\n        normA += vecA[i] * vecA[i];\n        normB += vecB[i] * vecB[i];\n    }\n    return -dot / (std::sqrt(normA) * std::sqrt(normB));  // \\u53D6\\u8D1F\\u4EE5\\u9002\\u5E94\\u6700\\u5C0F\\u5806\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u65F6\\u95F4\\u590D\\u6742\\u5EA6\\u5206\\u6790\"}),`\n`,(0,e.jsx)(n.p,{children:`| \\u64CD\\u4F5C | \\u590D\\u6742\\u5EA6 | \\u8BF4\\u660E |\n|-----------|------------|-------|\n| \\u63D2\\u5165 | O(beamWidth \\xD7 maxDegree \\xD7 dim) | \\u5305\\u62EC\\u641C\\u7D22\\u548C\\u526A\\u679D |\n| \\u641C\\u7D22 | O(beamWidth \\xD7 maxDegree \\xD7 dim + k \\xD7 dim) | \\u675F\\u641C\\u7D22 + \\u91CD\\u6392\\u5E8F |\n| \\u526A\\u679D | O(maxDegree\\xB2 \\xD7 dim) | \\u6210\\u5BF9\\u8DDD\\u79BB\\u68C0\\u67E5 |\n| PQ \\u8BAD\\u7EC3 | O(samples \\xD7 dim \\xD7 iterations) | K-\\u5747\\u503C\\u805A\\u7C7B |\n| PQ \\u7F16\\u7801 | O(dim) | \\u5B50\\u7A7A\\u95F4\\u91CF\\u5316 |\n| PQ \\u8DDD\\u79BB | O(numSubspaces) | \\u8868\\u67E5\\u627E |`}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u7A7A\\u95F4\\u590D\\u6742\\u5EA6\\u5206\\u6790\"}),`\n`,(0,e.jsx)(n.p,{children:`| \\u7EC4\\u4EF6 | \\u7A7A\\u95F4 | \\u8BF4\\u660E |\n|-----------|-------|-------|\n| \\u539F\\u59CB\\u5411\\u91CF | O(n \\xD7 dim \\xD7 2 \\u5B57\\u8282) | BFloat16 \\u5B58\\u50A8 |\n| PQ \\u7801 | O(n \\xD7 numSubspaces) | \\u901A\\u5E38 8-32 \\u500D\\u538B\\u7F29 |\n| \\