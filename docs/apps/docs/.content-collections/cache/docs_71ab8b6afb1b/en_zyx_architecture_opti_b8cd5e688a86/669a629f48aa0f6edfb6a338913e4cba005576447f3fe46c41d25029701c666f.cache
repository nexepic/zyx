ndexes on frequently queried properties\nCREATE INDEX ON :Person(email)\nCREATE INDEX ON :Person(name)\nCREATE INDEX ON :Person(age)\n\n-- Query will use index\nMATCH (n:Person {email: 'alice@example.com'})\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Limit Result Sets\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Always use LIMIT when exploring\nMATCH (n:Person)\nRETURN n\nLIMIT 100\n\n-- Use SKIP for pagination\nMATCH (n:Person)\nRETURN n\nORDER BY n.name\nSKIP 100 LIMIT 50\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Schema Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Label Design\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- GOOD: Specific labels for different entity types\nMATCH (n:Customer)-[:PURCHASED]->(p:Product)\nRETURN n, p\n\n-- AVOID: Generic labels\nMATCH (n:Entity)-[:RELATED]->(p:Entity)\nWHERE n.type = 'Customer' AND p.type = 'Product'\nRETURN n, p\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Property Optimization\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Store properties efficiently\nMATCH (n:Person)\nCREATE (n)-[:HAS_METRICS]->(m:Metrics {\n  pageViews: 1000,\n  uniqueVisitors: 500,\n  bounceRate: 0.45\n})\n\n-- AVOID: Too many properties on single node\nMATCH (n:Person)\nSET n.pageViews1 = 1000,\n    n.pageViews2 = 2000,\n    n.pageViews3 = 3000,\n    -- ... many more properties\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Transaction Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Keep Transactions Short\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// GOOD: Small, focused transactions\nauto tx = db->beginTransaction();\ntx->execute(\"CREATE (p:Person {name: 'Alice'})\");\ntx->commit();\n\n// AVOID: Long-running transactions\nauto tx = db->beginTransaction();\ntx->execute(\"CREATE (p:Person {name: 'Bob'})\");\n// ... wait for user input ...\ntx->commit();\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Operations\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Process in batches\nconst size_t BATCH_SIZE = 1000;\nfor (size_t i = 0; i < totalRecords; i += BATCH_SIZE) {\n    auto tx = db->beginTransaction();\n\n    std::string query = \"UNWIND range($start, $end) AS id \"\n                        \"CREATE (p:Person {id: id})\";\n\n    Parameters params;\n    params.add(\"start\", i);\n    params.add(\"end\", std::min(i + BATCH_SIZE, totalRecords));\n\n    tx->execute(query, params);\n    tx->commit();\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Storage Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Compression\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Enable compression for large segments\nDatabaseConfig config;\nconfig.setCompressionEnabled(true);\nconfig.setCompressionType(CompressionType::ZSTD);\nconfig.setCompressionLevel(3);\n\nauto db = Database::create(\"/path/to/db\", config);\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Segment Size Tuning\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Tune segment size to workload\nDatabaseConfig config;\n\n// For many small entities\nconfig.setSegmentSize(256 * 1024); // 256 KB\n\n// For fewer large entities\nconfig.setSegmentSize(2 * 1024 * 1024); // 2 MB\n\nauto db = Database::create(\"/path/to/db\", config);\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Checkpoint Configuration\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Optimize checkpoint frequency\nWALConfig walConfig;\n\n// For write-heavy workloads\nwalConfig.setCheckpointInterval(Duration::minutes(1));\nwalConfig.setMaxWalSize(50 * 1024 * 1024); // 50 MB\n\n// For read-heavy workloads\nwalConfig.setCheckpointInterval(Duration::minutes(10));\nwalConfig.setMaxWalSize(200 * 1024 * 1024); // 200 MB\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Cache Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Cache Size Tuning\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`CacheConfig cacheConfig;\n\n// Larger cache for read-heavy workloads\ncacheConfig.setMaxCacheSize(512 * 1024 * 1024); // 512 MB\ncacheConfig.setMaxEntities(500000);\n\n// Smaller cache for write-heavy workloads\ncacheConfig.setMaxCacheSize(128 * 1024 * 1024); // 128 MB\ncacheConfig.setMaxEntities(100000);\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Prefetching Strategy\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Enable prefetching for sequential access\nCacheConfig cacheConfig;\ncacheConfig.setEnablePrefetch(true);\ncacheConfig.setPrefetchThreshold(3);\ncacheConfig.setPrefetchCount(10);\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Concurrency Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Connection Pooling\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class ConnectionPool {\npublic:\n    ConnectionPool(size_t poolSize, const std::string& dbPath) {\n        for (size_t i = 0; i < poolSize; ++i) {\n            auto db = Database::open(dbPath);\n            connections_.push_back(std::move(db));\n        }\n    }\n\n    Database* getConnection() {\n        std::lock_guard<std::mutex> lock(mutex_);\n        // Get available connection\n        return connections_.back().get();\n    }\n\nprivate:\n    std::vector<std::unique_ptr<Database>> connections_;\n    std::mutex mutex_;\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Parallel Queries\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Execute independent queries in parallel\nauto future1 = std::async(std::launch::async, [&]() {\n    return db1->execute(\"MATCH (n:Person) RETURN count(n)\");\n});\n\nauto future2 = std::async(std::launch::async, [&]() {\n    return db2->execute(\"MATCH (n:Product) RETURN count(n)\");\n});\n\nauto result1 = future1.get();\nauto result2 = future2.get();\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Memory Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Streaming Large Results\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Stream results instead of loading all into memory\nauto tx = db->beginTransaction();\n\nauto cursor = tx->executeStream(\n    \"MATCH (n:Person) RETURN n\"\n);\n\nwhile (cursor->hasNext()) {\n    auto row = cursor->next();\n    // Process row\n    delete cursor; // Free memory\n}\n\ntx->commit();\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Processing\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Process in batches to limit memory usage\nconst size_t BATCH_SIZE = 10000;\n\nsize_t offset = 0;\nwhile (true) {\n    auto result = tx->execute(\n        \"MATCH (n:Person) RETURN n SKIP $offset LIMIT $limit\",\n        {{\"offset\", offset}, {\"limit\", BATCH_SIZE}}\n    );\n\n    if (result.isEmpty()) break;\n\n    // Process batch\n    for (const auto& row : result) {\n        processRow(row);\n    }\n\n    offset += BATCH_SIZE;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Monitoring\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Query Profiling\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Profile query execution\nPROFILE MATCH (n:Person)-[:KNOWS]->(m:Person)\nRETURN n, m\n\n-- Explain query plan (without executing)\nEXPLAIN MATCH (n:Person)-[:KNOWS]->(m:Person)\nRETURN n, m\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Statistics Collection\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Collect performance metrics\nauto stats = db->getStatistics();\n\nstd::cout << \"Cache Hit Rate: \" << stats.cacheHitRate << std::endl;\nstd::cout << \"Average Query Time: \" << stats.avgQueryTime << \"ms\" << std::endl;\nstd::cout << \"Transactions/sec: \" << stats.transactionsPerSecond << std::endl;\nstd::cout << 