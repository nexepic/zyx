e\n * @brief Main database interface for graph operations\n *\n * The Database class provides the primary interface for working with\n * ZYX graph databases. It manages database lifecycle, coordinates\n * between storage and query engines, and provides transaction support.\n *\n * Example usage:\n * @code\n * auto db = Database::open(\"/path/to/database\");\n * auto result = db->execute(\"MATCH (n) RETURN n\");\n * db->close();\n * @endcode\n */\nclass Database {\n    // ...\n};\n`})}),`\n`,(0,n.jsx)(e.h4,{children:\"Method Documentation\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`/**\n * @brief Opens an existing database\n *\n * Opens the database at the specified path. The database must already\n * exist or a DatabaseNotFoundException will be thrown.\n *\n * @param path Filesystem path to the database directory\n * @return Unique pointer to the opened Database instance\n *\n * @throws DatabaseNotFoundException if database doesn't exist\n * @throws DatabaseLockException if database is locked by another process\n * @throws IOException if filesystem error occurs\n *\n * @par Example\n * @code\n * try {\n *     auto db = Database::open(\"/data/mydb\");\n *     // Use database\n * } catch (const DatabaseNotFoundException& e) {\n *     std::cerr << \"Database not found\" << std::endl;\n * }\n * @endcode\n */\nstatic std::unique_ptr<Database> open(const std::string& path);\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"2. API Documentation\"}),`\n`,(0,n.jsx)(e.h4,{children:\"Public API Headers\"}),`\n`,(0,n.jsx)(e.p,{children:\"Public API documentation should be comprehensive and include:\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Purpose\"}),\": What the API does\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Parameters\"}),\": Input parameters with types and constraints\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Return values\"}),\": What is returned and possible values\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Exceptions\"}),\": What errors can be thrown\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Examples\"}),\": Usage examples\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Thread safety\"}),\": Whether operations are thread-safe\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Performance\"}),\": Performance characteristics\"]}),`\n`]}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`/**\n * @brief Execute a Cypher query\n *\n * Executes the given Cypher query string and returns the result.\n * The query is executed in a new auto-commit transaction.\n *\n * @param cypher Cypher query string to execute\n * @return Result object containing query results\n *\n * @throws ParseException if query syntax is invalid\n * @throws ExecutionException if query execution fails\n * @throws ConstraintViolationException if constraints are violated\n *\n * @par Thread Safety\n * This method is thread-safe. Multiple threads can execute queries\n * concurrently.\n *\n * @par Performance\n * Query execution time depends on query complexity. Simple lookups\n * typically complete in < 1ms. Complex pattern matching may take\n * longer.\n *\n * @par Example\n * @code\n * auto result = db->execute(\"MATCH (n:Person) RETURN n.name\");\n * for (const auto& row : result) {\n *     std::cout << row[\"n.name\"].asString() << std::endl;\n * }\n * @endcode\n */\nResult execute(const std::string& cypher);\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"3. User Documentation\"}),`\n`,(0,n.jsx)(e.h4,{children:\"Tutorial Style\"}),`\n`,(0,n.jsx)(e.p,{children:\"User documentation should be tutorial and example-driven:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-markdown\",children:`# Quick Start Guide\n\n## Creating a Database\n\nTo create a new database, use the \\`Database::create()\\` method:\n\n\\`\\`\\`cpp\n#include <zyx/zyx.hpp>\n\nusing namespace zyx;\n\n// Create database at specified path\nauto db = Database::create(\"/path/to/database\");\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Adding Data\"}),`\n`,(0,n.jsx)(e.p,{children:\"Add nodes using Cypher queries:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Create a person node\ndb->execute(\"CREATE (p:Person {name: 'Alice', age: 30})\");\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Querying Data\"}),`\n`,(0,n.jsx)(e.p,{children:\"Query data using the MATCH clause:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Find all people\nauto result = db->execute(\"MATCH (p:Person) RETURN p.name, p.age\");\n\n// Process results\nfor (const auto& row : result) {\n    std::cout << row[\"p.name\"].asString() << std::endl;\n}\n`})}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`\n#### Conceptual Documentation\n\nExplain concepts clearly with diagrams:\n\n\\`\\`\\`markdown\n## Transaction System\n\nZYX provides ACID transactions through a Write-Ahead Log (WAL).\n\n### Transaction States\n\n\\`\\`\\`mermaid\nstateDiagram-v2\n    [*] --> Active: BEGIN\n    Active --> Committed: COMMIT\n    Active --> RolledBack: ROLLBACK\n    Committed --> [*]\n    RolledBack --> [*]\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Transaction Isolation\"}),`\n`,(0,n.jsx)(e.p,{children:\"ZYX uses snapshot isolation to ensure transaction consistency...\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`\n### 4. Architecture Documentation\n\n#### Component Overviews\n\n\\`\\`\\`markdown\n# Query Engine Architecture\n\nThe query engine is responsible for parsing, planning, and executing\nCypher queries.\n\n## Components\n\n### Parser\n\nThe parser converts Cypher text into an Abstract Syntax Tree (AST).\n\n**Key responsibilities:**\n- Lexical analysis\n- Syntax parsing\n- AST construction\n\n**Implementation:** ANTLR4-based parser in \\`src/query/parser/cypher/\\`\n\n### Planner\n\nThe planner transforms the AST into an executable query plan.\n\n**Key responsibilities:**\n- Logical plan generation\n- Optimization rule application\n- Cost estimation\n\n**Implementation:** \\`src/query/planner/QueryPlanner.cpp\\`\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Documentation Structure\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Directory Organization\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`docs/\n\\u251C\\u2500\\u2500 user-guide/           # User-facing documentation\n\\u2502   \\u251C\\u2500\\u2500 installation.md\n\\u2502   \\u251C\\u2500\\u2500 quick-start.md\n\\u2502   \\u2514\\u2500\\u2500 advanced-queries.md\n\\u251C\\u2500\\u2500 api/                  # API reference\n\\u2502   \\u251C\\u2500\\u2500 cpp-api.md\n\\u2502   \\u251C\\u2500\\u2500 transaction.md\n\\u2502   \\u2514\\u2500\\u2500 types.md\n\\u251C\\u2500\\u2500 architecture/         # Architecture documentation\n\\u2502   \\u251C\\u2500\\u2500 overview.md\n\\u2502   \\u251C\\u2500\\u2500 storage.md\n\\u2502   \\u2514\\u2500\\u2500 query-engine.md\n\\u2514\\u2500\\u2500 contributing/         # Contributor documentation\n    \\u251C\\u2500\\u2500 development-setup.md\n    \\u251C\\u2500\\u2500 testing.md\n    \\u2514\\u2500\\u2500 doc-standards.md\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Writing Guidelines\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Style Guidelines\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Use clear, simple language\"}),\": Avoid jargon when possible\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Be concise\"}),\": Get to the point quickly\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Use active voice\"}),': \"Create a database\" not \"A database can be created\"']}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Break into sections\"}),\": Use headings to organize content\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Include examples\"}),\": Show, don't just tell\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Formatting\"}),`\n`,(0,n.jsx)(e.h4,{children:\"Code Blocks\"}),`\n`,(0,n.jsx)(e.p,{children:\"Use syntax-highlighted code blocks:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-markdown\",children:'```cpp\\nauto db = Database::open(\"/path/to/db\");\\n```\\n'})}),`\n`,(0,n.jsx)(e.h4,{children:\"Admonitions\"}),`\n`,(0,n.jsx)(e.p,{children:\"Use callouts for important information:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-markdown\",children:`::: tip Best Practice\nAlways close databases when done to release resources.\n:::\n\n::: warning Warning\nDeleting nodes also deletes all connected relationships.\n:::\n\n::: danger Critical\nNever modify the database files directly while the database is open.\n:::\n`})}),`\n`,(0,n.jsx)(e.h4,{children:\"Tables\"}),`\n`,(0,n.jsx)(e.p,{children:\"Use tables for structured information:\"}),`\n`,(0,n.jsxs)(e.p,{children:[`| Method | Description | Thread-Safe |\n|--------|-------------|-------------|\n| `,(0,n.jsx)(e.code,{children:\"open()\"}),` | Opens existing database | No |\n| `,(0,n.jsx)(e.code,{children:\"create()\"}),` | Creates new database | No |\n| `,(0,n.jsx)(e.code,{children:\"execute()\"}),\" | Executes query | Yes |\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Diagrams\"}),`\n`,(0,n.jsx)(e.p,{children:\"Use Mermaid for diagrams:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-markdown\",children:`\\`\\`\\`mermaid\ngraph LR\n    A[Query] --> B[Parser]\n    B --> C[Planner]\n    C --> D[Executor]\n    D --> E[Result]\n`})}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`\n#### Visual Diagram Standards\n\n**CRITICAL**: Follow these strict guidelines for all diagrams in documentation.\n\n1. **NO ASCII ART**: Absolutely NO hand-drawn ASCII art diagrams\n   - **Forbidden**: Box-drawing characters like \\`\\u250C\\u2502\\u2514\\u2500\\u2502/\\\\\\`, \\`+----+\\`, \\`|    |\\`\n   - **Why**: ASCII art is difficult to maintain, error-prone, renders poorly on different devices, and cannot be easily updated\n   - **Always use**: Mermaid diagrams instead\n\n2. **Color Restrictions**: Professional grayscale only\n   - **FORBIDDEN colors** (never use these):\n     - \\`fill:#90EE90\\` (light green)\n     - \\`fill:#e1f5ff\\` (light blue)\n     - \\`fill:#ffe1e1\\` (light red)\n     - \\`fill:#ff0\\`, \\`fill:#f9f\\`, \\`fill:#bbf\\` (bright colors)\n     - \\`fill:lightblue\\`, \\`fill:lightgreen\\`, etc.\n     - Any \\`stroke:\\` styling with colors\n   - **ALLOWED styling** (use sparingly):\n     - No fill/color at all (default black/white) - **PREFERRED**\n     - Subtle grays only: \\`fill:#f0f0f0\\`, \\`fill:#e0e0e0\\`, \\`fill:#d0d0d0\\`\n   - **Rationale**: Colorful diagrams appear unprofessional, may not print well, and can be distracting. Simple grayscale diagrams are cleaner and more publication-ready.\n\n3. **Diagram Types**: Use appropriate Mermaid diagram types:\n   - **Structure**: \\`classDiagram\\` for class hierarchies, data structures\n   - **Flow/Process**: \\`flowchart TD\\` or \\`graph TD\\` for processes and flows\n   - **State**: \\`stateDiagram-v2\\` for state machines\n   - **Sequence**: \\`sequenceDiagram\\` for interactions\n   - **Entity Relationship**: \\`erDiagram\\` for database schemas\n\n4. **Diagram Clarity**:\n   - Keep diagrams simple and focused\n   - Avoid excessive detail or visual noise\n   - Ensure text is readable and labels are clear\n   - Use consistent styling across all documentation\n\n#### Examples\n\n**GOOD - Clean Mermaid diagram:**\n\\`\\`\\`mermaid\nclassDiagram\n    class Database {\n        +open() void\n        +close() void\n        +execute(query) Result\n    }\n    class Transaction {\n        +commit() bool\n        +rollback() void\n    }\n    Database --> Transaction\n`})}),`\n`,(0,n.jsx)(e.p,{children:(0,n.jsx)(e.strong,{children:\"BAD - ASCII art (FORBIDDEN):\"})}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`\\u250C\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2510\n\\u2502  Database   \\u2502\n\\u251C\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2524\n\\u2502  open()     \\u2502\n\\u2502  close()    \\u2502\n\\u2502  execute()  \\u2502\n\\u2514\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2518\n`})}),`\n`,(0,n.jsx)(e.p,{children:(0,n.jsx)(e.strong,{children:\"BAD - Colorful Mermaid (FORBIDDEN):\"})}),`\n`,(0,n.jsx)(i,{chart:`graph TD\n    A[Start] --> B[Process]\n    style A fill:#90EE90\n    style B fill:#e1f5ff\n    style A stroke:#f00,stroke-width:4px`}),`\n`,(0,n.jsx)(e.p,{children:(0,n.jsx)(e.strong,{children:\"GOOD - Professional grayscale:\"})}),`\n`,(0,n.jsx)(i,{chart:`graph TD\n    A[Start] --> B[Process]\n    B --> C[End]`}),`\n`,(0,n.jsx)(e.h4,{children:\"Code Example Standards\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Real Code Only\"}),\": All code examples MUST be from actual implementation\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Forbidden\"}),': Hypothetical code, pseudo-code, \"simplified\" examples']}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Required\"}),\": Copy directly from source files\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Reference\"}),\": Include file paths for context (e.g., \",(0,n.jsx)(e.code,{children:\"See: include/graph/core/Database.hpp:123-145\"}),\")\"]}),`\n`]}),`\n`]}),`\n`,(0,n.jsxs)(e.li,{children:[`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Code Accuracy\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Verify all examples compile and w