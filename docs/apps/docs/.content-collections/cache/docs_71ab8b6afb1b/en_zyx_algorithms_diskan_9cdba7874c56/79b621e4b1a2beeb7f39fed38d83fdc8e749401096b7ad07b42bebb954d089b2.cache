"var Component=(()=>{var u=Object.create;var a=Object.defineProperty;var m=Object.getOwnPropertyDescriptor;var p=Object.getOwnPropertyNames;var g=Object.getPrototypeOf,f=Object.prototype.hasOwnProperty;var b=(i,e)=>()=>(e||i((e={exports:{}}).exports,e),e.exports),y=(i,e)=>{for(var t in e)a(i,t,{get:e[t],enumerable:!0})},o=(i,e,t,s)=>{if(e&&typeof e==\"object\"||typeof e==\"function\")for(let r of p(e))!f.call(i,r)&&r!==t&&a(i,r,{get:()=>e[r],enumerable:!(s=m(e,r))||s.enumerable});return i};var v=(i,e,t)=>(t=i!=null?u(g(i)):{},o(e||!i||!i.__esModule?a(t,\"default\",{value:i,enumerable:!0}):t,i)),_=i=>o(a({},\"__esModule\",{value:!0}),i);var d=b((q,c)=>{c.exports=_jsx_runtime});var x={};y(x,{default:()=>h});var n=v(d());function l(i){let e={a:\"a\",code:\"code\",h1:\"h1\",h2:\"h2\",h3:\"h3\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...i.components},{Mermaid:t}=e;return t||D(\"Mermaid\",!0),(0,n.jsxs)(n.Fragment,{children:[(0,n.jsx)(e.h1,{children:\"DiskANN Algorithm\"}),`\n`,(0,n.jsx)(e.p,{children:\"DiskANN (Disk-based Approximate Nearest Neighbor) is a high-performance graph-based algorithm for approximate nearest neighbor search in high-dimensional vector spaces. ZYX uses DiskANN to power vector similarity search operations with support for Product Quantization (PQ) for memory efficiency.\"}),`\n`,(0,n.jsx)(e.h2,{children:\"Overview\"}),`\n`,(0,n.jsx)(e.p,{children:`::: info Algorithm Background\nDiskANN was developed by Microsoft Research specifically for efficient approximate nearest neighbor (ANN) search on large-scale vector datasets. It achieves sub-millisecond query latency with high recall through graph-based indexing and intelligent pruning strategies.\n:::`}),`\n`,(0,n.jsx)(e.p,{children:\"DiskANN builds a navigable small-world graph where vectors are nodes connected by edges to their approximate nearest neighbors. The algorithm uses:\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Graph Structure\"}),\": Navigable small-world graph for efficient traversal\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Greedy Search\"}),\": Beam search with bounded width for fast querying\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Robust Pruning\"}),\": Alpha-based pruning to maintain graph quality\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Product Quantization\"}),\": Lossy compression for memory-efficient storage\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Hybrid Mode\"}),\": Combines PQ and raw vectors for balanced performance\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Key Benefits\"}),`\n`,(0,n.jsx)(e.p,{children:\"::: tip Core Features\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Scalability\"}),\": Handles millions of vectors efficiently\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Accuracy\"}),\": High recall with tunable precision\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Memory Efficiency\"}),\": PQ compression reduces memory footprint by 8-32x\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Fast Search\"}),\": Sub-millisecond query latency\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Dynamic Updates\"}),`: Supports incremental insertions and deletions\n:::`]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Graph Structure\"}),`\n`,(0,n.jsx)(e.p,{children:\"The graph is built as a directed graph where each node (vector) maintains connections to its nearest neighbors.\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`struct GraphNode {\n    int64_t nodeId;              // Node identifier\n    std::vector<float> vector;   // High-dimensional vector\n    std::vector<int64_t> neighbors;  // Adjacency list (maxDegree connections)\n};\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Graph Properties\"}),`\n`,(0,n.jsx)(t,{chart:`graph TD\n    A[Node A] -->|distance| B[Node B]\n    A -->|distance| C[Node C]\n    A -->|distance| D[Node D]\n    B -->|distance| E[Node E]\n    B -->|distance| F[Node F]\n    C -->|distance| G[Node G]\n    D -->|distance| H[Node H]`}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Max Degree\"}),\": Each node maintains at most \",(0,n.jsx)(e.code,{children:\"maxDegree\"}),\" outgoing edges (default: 64)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Entry Point\"}),\": A designated node serves as the starting point for searches\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Bidirectional Edges\"}),\": Edges are created in both directions for efficient traversal\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Configuration\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`struct DiskANNConfig {\n    uint32_t dim;                       // Vector dimensionality\n    uint32_t beamWidth = 100;           // Search beam width\n    uint32_t maxDegree = 64;            // Maximum connections per node\n    float alpha = 1.2f;                 // Pruning factor (1.0-2.0)\n    size_t autoTrainThreshold = 2000;   // Vectors before auto-training PQ\n    std::string metric = \"L2\";          // Distance metric (L2, IP, Cosine)\n};\n`})}),`\n`,(0,n.jsx)(e.p,{children:\"::: details Configuration Details\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"dim\"}),\": Vector space dimensionality, must match the vectors you're indexing\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"beamWidth\"}),\": Beam search width, controls candidate queue size during search\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"maxDegree\"}),\": Maximum number of neighbors each node maintains in the graph\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"alpha\"}),\": Pruning factor, controls how aggressively the graph is pruned\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"autoTrainThreshold\"}),\": Number of vectors before automatically triggering PQ training\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"metric\"}),`: Distance metric type, supports L2, IP (Inner Product), and Cosine\n:::`]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Parameter Tuning\"}),`\n`,(0,n.jsx)(e.p,{children:`::: tip Tuning Guidelines\nAdjust these parameters based on your use case:`}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"High Recall Priority\"}),\": Increase \",(0,n.jsx)(e.code,{children:\"beamWidth\"}),\" and \",(0,n.jsx)(e.code,{children:\"maxDegree\"})]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Speed Priority\"}),\": Decrease \",(0,n.jsx)(e.code,{children:\"beamWidth\"}),\" and \",(0,n.jsx)(e.code,{children:\"maxDegree\"})]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Memory Constrained\"}),\": Decrease \",(0,n.jsx)(e.code,{children:\"maxDegree\"}),`, use more aggressive PQ\n:::`]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[`| Parameter | Effect | Range | Recommendation |\n|-----------|--------|-------|----------------|\n| `,(0,n.jsx)(e.code,{children:\"beamWidth\"}),` | Search quality vs speed | 50-200 | 100 for balance |\n| `,(0,n.jsx)(e.code,{children:\"maxDegree\"}),` | Graph connectivity | 32-128 | 64 for most cases |\n| `,(0,n.jsx)(e.code,{children:\"alpha\"}),` | Pruning aggressiveness | 1.0-2.0 | 1.2 for good quality |\n| `,(0,n.jsx)(e.code,{children:\"autoTrainThreshold\"}),\" | When to train PQ | 1000-10000 | 2000 for startup |\"]}),`\n`,(0,n.jsx)(e.h2,{children:\"Core Operations\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Insert Vector\"}),`\n`,(0,n.jsx)(e.p,{children:\"Inserts a new vector into the index and builds graph connections:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void insert(int64_t nodeId, const std::vector<float>& vec) {\n    // 1. Validate dimension\n    if (vec.size() != config_.dim) {\n        throw std::invalid_argument(\"Dimension mismatch\");\n    }\n\n    // 2. Auto-train PQ if threshold reached\n    if (!isPQTrained() && cachedCount_++ == config_.autoTrainThreshold) {\n        auto samples = sampleVectors(config_.autoTrainThreshold);\n        train(samples);\n    }\n\n    // 3. Store vector data\n    int64_t rawBlob = registry_->saveRawVector(toBFloat16(vec));\n    int64_t pqBlob = isPQTrained() ? registry_->savePQCodes(quantizer_->encode(vec)) : 0;\n\n    // 4. Handle first node\n    if (entryPoint == 0) {\n        registry_->updateEntryPoint(nodeId);\n        return;\n    }\n\n    // 5. Find nearest neighbors using greedy search\n    auto pqTable = isPQTrained() ? quantizer_->computeDistanceTable(vec) : std::vector<float>{};\n    auto neighbors = greedySearch(vec, entryPoint, config_.beamWidth, pqTable);\n\n    // 6. Prune candidates and create bidirectional edges\n    std::vector<int64_t> candidates;\n    for (auto& [id, dist] : neighbors) {\n        candidates.push_back(id);\n    }\n    prune(nodeId, candidates);\n\n    // 7. Save adjacency and create back-links\n    registry_->saveAdjacency(nodeId, candidates);\n    for (int64_t neighbor : candidates) {\n        addBackLink(neighbor, nodeId);\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Complexity\"}),\": O(beamWidth \\xD7 maxDegree \\xD7 dim)\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Search\"}),`\n`,(0,n.jsx)(e.p,{children:\"Finds k nearest neighbors using beam search:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> search(\n    const std::vector<float>& query,\n    size_t k\n) const {\n    // 1. Compute PQ distance table for fast approximation\n    auto pqTable = isPQTrained() ? quantizer_->computeDistanceTable(query) : std::vector<float>{};\n\n    // 2. Greedy search with beam width\n    auto candidates = greedySearch(query, entryPoint, std::max(config_.beamWidth, k * 2), pqTable);\n\n    // 3. Re-rank with exact distances\n    std::vector<std::pair<int64_t, float>> results;\n    for (auto& [nodeId, _] : candidates) {\n        float exactDist = distRaw(query, nodeId);\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. Sort and return top-k\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Complexity\"}),\": O(beamWidth \\xD7 maxDegree \\xD7 dim + k \\xD7 dim)\"]}),`\n`,(0,n.jsx)(e.h2,{children:\"Greedy Search Algorithm\"}),`\n`,(0,n.jsx)(e.p,{children:\"The core search algorithm traverses the graph using beam search:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> greedySearch(\n    const std::vector<float>& query,\n    int64_t startNode,\n    size_t beamWidth,\n    const std::vector<float>& pqTable\n) const {\n    std::unordered_set<int64_t> visited;\n    std::priority_queue<\n        std::pair<float, int64_t>,\n        std::vector<std::pair<float, int64_t>>,\n        std::greater<>\n    > queue;  // Min-heap: (distance, node)\n\n    std::vector<std::pair<int64_t, float>> results;\n\n    // Initialize with entry point\n    float startDist = computeDistance(query, pqTable, startNode);\n    queue.push({startDist, startNode});\n    visited.insert(startNode);\n    results.push_back({startNode, startDist});\n\n    // Beam search traversal\n    while (!queue.empty()) {\n        auto [dist, currentNode] = queue.top();\n        queue.pop();\n\n        // Explore neighbors\n        auto neighbors = registry_->loadAdjacency(currentNode);\n        for (int64_t neighbor : neighbors) {\n            if (visited.contains(neighbor)) continue;\n            visited.insert(neighbor);\n\n            float neighborDist = computeDistance(query, pqTable, neighbor);\n            results.push_back({neighbor, neighborDist});\n            queue.push({neighborDist, neighbor});\n        }\n    }\n\n    // Sort and limit to beam width\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    if (results.size() > beamWidth) {\n        results.resize(beamWidth);\n    }\n\n    return results;\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Search Flow\"}),`\n`,(0,n.jsx)(t,{chart:`flowchart TD\n    Start([Start Query]) --> Init[Initialize queue with entry point]\n    Init --> Loop{Queue empty?}\n    Loop -->|No| Pop[Pop closest node]\n    Pop --> Expand[Explore unvisited neighbors]\n    Expand --> Compute[Compute distances to neighbors]\n    Compute --> Push[Push neighbors to queue]\n    Push --> Loop\n    Loop -->|Yes| Sort[Sort results by distance]\n    Sort --> Limit[Limit to beam width]\n    Limit --> Rerank[Re-rank with exact distances]\n    Rerank --> Return([Return top-k results])`}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Complexity\"}),\": O(beamWidth \\xD7 maxDegree \\xD7 dim)\"]}),`\n`,(0,n.jsx)(e.h2,{children:\"Pruning Strategy\"}),`\n`,(0,n.jsx)(e.p,{children:\"Robust pruning maintains graph quality by removing redundant edges:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void prune(int64_t nodeId, std::vector<int64_t>& candidates) const {\n    // Load node vector for accurate distance computation\n    auto nodeVec = loadRawVector(nodeId);\n\n    // 1. Sort candidates by distance to node\n    std::vector<std::pair<int64_t, float>> candDists;\n    for (int64_t candId : candidates) {\n        float dist = computeDistance(nodeVec, candId);\n        candDists.push_back({candId, dist});\n    }\n    std::sort(candDists.begin(), candDists.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n\n    // 2. Alpha-pruning: Remove occluded candidates\n    std::vector<int64_t> result;\n    result.reserve(config_.maxDegree);\n\n    for (const auto& [candId, candDist] : candDists) {\n        if (result.size() >= config_.maxDegree) break;\n\n        bool occluded = false;\n        auto candVec = loadRawVector(candId);\n\n        // Check if candidate is occluded by existing neighbors\n        for (int64_t existingId : result) {\n            auto existingVec = loadRawVector(existingId);\n            float distExistingToCand = computeDistance(existingVec, candVec);\n\n            // Occlusion condition: alpha * dist(existing, cand) <= dist(node, cand)\n            if (config_.alpha * distExistingToCand <= candDist) {\n                occluded = true;\n                break;\n            }\n        }\n\n        if (!occluded) {\n            result.push_back(candId);\n        }\n    }\n\n    candidates = result;\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Pruning Logic\"}),`\n`,(0,n.jsx)(t,{chart:`graph TD\n    A[Node] -->|1.0| B[Candidate 1]\n    A -->|1.5| C[Candidate 2]\n    A -->|2.0| D[Candidate 3]\n\n    B -->|0.8| C\n    B -->|1.2| D\n\n\n    Note[\"Candidate 2 is occluded: alpha*0.8 <= 1.5\"]`}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Occlusion Condition\"}),\": A candidate is occluded if:\"]}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`alpha \\xD7 distance(existing, candidate) \\u2264 distance(node, candidate)\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Complexity\"}),\": O(maxDegree\\xB2 \\xD7 dim)\"]}),`\n`,(0,n.jsx)(e.h2,{children:\"Product Quantization Integration\"}),`\n`,(0,n.jsx)(e.h3,{children:\"PQ Training\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void train(const std::vector<std::vector<float>>& samples) {\n    // Determine subspace configuration\n    size_t subDim = 8;  // Subspace dimension\n    size_t numSubspaces = config_.dim / subDim;  // e.g., 768/8 = 96\n\n    // Create and train quantizer\n    auto pq = std::make_unique<NativeProductQuantizer>(\n        config_.dim,\n        numSubspaces,\n        256  // 256 centroids per subspace\n    );\n    pq->train(samples);\n\n    // Persist quantizer\n    registry_->saveQuantizer(*pq);\n    quantizer_ = std::move(pq);\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"PQ Encoding\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) const {\n    std::vector<uint8_t> codes(numSubspaces_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* subVec = vec.data() + offset;\n\n        // Find nearest centroid\n        float minDist = std::numeric_limits<float>::max();\n        uint8_t bestIdx = 0;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                subVec,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n            if (dist < minDist) {\n                minDist = dist;\n                bestIdx = static_cast<uint8_t>(c);\n            }\n        }\n        codes[m] = bestIdx;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Distance Computation\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Compute distance table for query (once per search)\nstd::vector<float> computeDistanceTable(const std::vector<float>& query) const {\n    std::vector<float> table(numSubspaces_ * numCentroids_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* querySub = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            table[m * numCentroids_ + c] = VectorMetric::computeL2Sqr(\n                querySub,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n        }\n    }\n\n    return table;\n}\n\n// Fast PQ distance using table lookup\nfloat computeDistance(\n    const std::vector<float>& pqTable,\n    const std::vector<uint8_t>& codes\n) const {\n    float dist = 0.0f;\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        dist += pqTable[m * numCentroids_ + codes[m]];\n    }\n    return dist;\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Hybrid Mode\"}),`\n`,(0,n.jsx)(e.p,{children:\"ZYX uses a hybrid approach:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) const {\n    auto ptrs = registry_->getBlobPtrs(targetId);\n\n    // Use PQ if available and trained\n    if (isPQTrained() && ptrs.pqBlob != 0 && !pqTable.empty()) {\n        return distPQ(pqTable, targetId);\n    }\n\n    // Fallback to raw vector\n    return distRaw(query, targetId);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Benefits\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Navigation\"}),\": Fast approximate distances using PQ\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Re-ranking\"}),\": Exact distances using raw vectors for top results\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Backward Compatibility\"}),\": Old vectors work without PQ codes\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Distance Metrics\"}),`\n`,(0,n.jsx)(e.h3,{children:\"L2 Distance (Euclidean)\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`float computeL2Sqr(\n    const float* vecA,\n    const float* vecB,\n    size_t dim\n) {\n    float dist = 0.0f;\n    for (size_t i = 0; i < dim; ++i) {\n        float diff = vecA[i] - vecB[i];\n        dist += diff * diff;\n    }\n    return dist;\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Inner Product (IP)\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`float computeIP(\n    const float* vecA,\n    const float* vecB,\n    size_t dim\n) {\n    float ip = 0.0f;\n    for (size_t i = 0; i < dim; ++i) {\n        ip += vecA[i] * vecB[i];\n    }\n    return -ip;  // Negate for min-heap\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Cosine Similarity\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`float computeCosine(\n    const float* vecA,\n    const float* vecB,\n    size_t dim\n) {\n    float dot = 0.0f, normA = 0.0f, normB = 0.0f;\n    for (size_t i = 0; i < dim; ++i) {\n        dot += vecA[i] * vecB[i];\n        normA += vecA[i] * vecA[i];\n        normB += vecB[i] * vecB[i];\n    }\n    return -dot / (std::sqrt(normA) * std::sqrt(normB));  // Negate for min-heap\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Time Complexity Analysis\"}),`\n`,(0,n.jsx)(e.p,{children:`| Operation | Complexity | Notes |\n|-----------|------------|-------|\n| Insert | O(beamWidth \\xD7 maxDegree \\xD7 dim) | Includes search and pruning |\n| Search | O(beamWidth \\xD7 maxDegree \\xD7 dim + k \\xD7 dim) | Beam search + re-ranking |\n| Prune | O(maxDegree\\xB2 \\xD7 dim) | Pairwise distance checks |\n| PQ Train | O(samples \\xD7 dim \\xD7 iterations) | K-means clustering |\n| PQ Encode | O(dim) | Subspace quantization |\n| PQ Distance | O(numSubspaces) | Table lookup |`}),`\n`,(0,n.jsx)(e.h2,{children:\"Space Complexity Analysis\"}),`\n`,(0,n.jsx)(e.p,{children:`| Component | Space | Notes |\n|-----------|-------|-------|\n| Raw Vectors | O(n \\xD7 dim \\xD7 2 bytes) | BFloat16 storage |\n| PQ Codes | O(n \\xD7 numSubspaces) | Typically 8-32x compression |\n| Graph Edges | O(n \\xD7 maxDegree) | Average degree ~maxDegree |\n| PQ Codebooks | O(dim) | Shared across all vectors |\n| Distance Table | O(numSubspaces \\xD7 256) | Per query |`