ong,{children:\"High Fanout\"}),\": Minimizes tree height for fewer disk I/Os\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Leaf Linking\"}),\": Doubly-linked leaf nodes for sequential access\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Node Splitting/Merging\"}),\": Automatic balancing on insert/delete\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Blob Support\"}),\": Handles oversized keys and value lists\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"B+Tree vs B-Tree\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Why B+Tree for Databases?\"}),`\n`,(0,n.jsx)(t,{chart:`graph TD\n    A[B-Tree vs B+Tree] --> B[B-Tree]\n    A --> C[B+Tree]\n\n    B --> B1[Keys in internal nodes]\n    B --> B2[Data pointers in all nodes]\n    B --> B3[Faster single record lookup]\n    B --> B4[Slower range queries]\n\n    C --> C1[Keys only in internal nodes]\n    C --> C2[Data only in leaf nodes]\n    C --> C3[Optimized for range scans]\n    C --> C4[Sequential leaf access]`}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Key Differences\"}),\":\"]}),`\n`,(0,n.jsx)(e.p,{children:`| Feature | B-Tree | B+Tree |\n|---------|--------|--------|\n| Data Storage | All nodes | Leaf nodes only |\n| Leaf Links | None | Doubly-linked |\n| Range Queries | Slower (tree traversal) | Faster (sequential scan) |\n| Fanout | Lower | Higher (more pointers) |\n| Disk I/O | More for ranges | Optimized for sequential access |`}),`\n`,(0,n.jsx)(e.h2,{children:\"B+Tree Structure\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Node Layout\"}),`\n`,(0,n.jsx)(t,{chart:`graph TD\n    A[Root Node] --> B[Internal Node]\n    A --> C[Internal Node]\n    B --> D[Leaf 1]\n    B --> E[Leaf 2]\n    C --> F[Leaf 3]\n    C --> G[Leaf 4]\n\n    D -.-> E\n    E -.-> F\n    F -.-> G`}),`\n`,(0,n.jsx)(e.p,{children:(0,n.jsx)(e.strong,{children:\"B+Tree Structure:\"})}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Root Node: Level 2\"}),`\n`,(0,n.jsx)