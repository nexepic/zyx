"var Component=(()=>{var p=Object.create;var l=Object.defineProperty;var T=Object.getOwnPropertyDescriptor;var N=Object.getOwnPropertyNames;var A=Object.getPrototypeOf,m=Object.prototype.hasOwnProperty;var R=(r,n)=>()=>(n||r((n={exports:{}}).exports,n),n.exports),E=(r,n)=>{for(var a in n)l(r,a,{get:n[a],enumerable:!0})},o=(r,n,a,c)=>{if(n&&typeof n==\"object\"||typeof n==\"function\")for(let i of N(n))!m.call(r,i)&&i!==a&&l(r,i,{get:()=>n[i],enumerable:!(c=T(n,i))||c.enumerable});return r};var g=(r,n,a)=>(a=r!=null?p(A(r)):{},o(n||!r||!r.__esModule?l(a,\"default\",{value:r,enumerable:!0}):a,r)),C=r=>o(l({},\"__esModule\",{value:!0}),r);var t=R((H,s)=>{s.exports=_jsx_runtime});var u={};E(u,{default:()=>d});var e=g(t());function h(r){let n={a:\"a\",code:\"code\",h1:\"h1\",h2:\"h2\",h3:\"h3\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...r.components};return(0,e.jsxs)(e.Fragment,{children:[(0,e.jsx)(n.h1,{children:\"Advanced Queries\"}),`\n`,(0,e.jsx)(n.p,{children:\"This guide covers advanced Cypher query patterns and techniques for complex data retrieval and manipulation in ZYX.\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Aggregation and Grouping\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Basic Aggregation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Count nodes\nMATCH (n:Person)\nRETURN COUNT(n) AS total\n\n-- Count with conditions\nMATCH (n:Person)\nRETURN COUNT(CASE WHEN n.age > 30 THEN 1 END) AS over_30\n\n-- Sum aggregation\nMATCH (n:Person)\nRETURN SUM(n.salary) AS total_salary\n\n-- Average aggregation\nMATCH (n:Person)\nRETURN AVG(n.age) AS avg_age\n\n-- Min/Max\nMATCH (n:Person)\nRETURN MIN(n.age) AS youngest, MAX(n.age) AS oldest\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Grouping with Multiple Aggregates\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Group by city with multiple aggregations\nMATCH (n:Person)\nRETURN n.city,\n       COUNT(n) AS population,\n       AVG(n.age) AS avg_age,\n       MIN(n.salary) AS min_salary,\n       MAX(n.salary) AS max_salary\nORDER BY population DESC\n\n-- Group by multiple properties\nMATCH (n:Person)\nRETURN n.city, n.country,\n       COUNT(n) AS count\nORDER BY count DESC\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"COLLECT for List Aggregation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Collect values into a list\nMATCH (n:Person)\nRETURN n.city, COLLECT(n.name) AS residents\n\n-- Collect with ordering\nMATCH (n:Person)\nRETURN n.city, COLLECT(n.name ORDER BY n.name) AS residents\n\n-- Collect distinct values\nMATCH (n:Person)\nRETURN DISTINCT n.city, COLLECT(DISTINCT n.profession) AS professions\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Advanced Filtering\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Pattern Filtering\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Filter based on relationship existence\nMATCH (n:Person)\nWHERE (n)-[:KNOWS]->()\nRETURN n\n\n-- Filter based on non-existence\nMATCH (n:Person)\nWHERE NOT (n)-[:KNOWS]->()\nRETURN n\n\n-- Filter by relationship count\nMATCH (n:Person)\nWHERE size((n)-[:KNOWS]->()) > 5\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"List Operations\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Check if value in list\nMATCH (n:Person)\nWHERE 'Developer' IN n.skills\nRETURN n\n\n-- Check if list contains any of multiple values\nMATCH (n:Person)\nWHERE ANY(skill IN n.skills WHERE skill IN ['Developer', 'Designer'])\nRETURN n\n\n-- Check if all conditions met\nMATCH (n:Person)\nWHERE ALL(skill IN n.skills WHERE length(skill) > 3)\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"String Matching\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Regular expression matching\nMATCH (n:Person)\nWHERE n.name =~ 'A.*'\nRETURN n\n\n-- Case-insensitive matching\nMATCH (n:Person)\nWHERE toLower(n.name) = toLower('ALICE')\nRETURN n\n\n-- Multiple string conditions\nMATCH (n:Person)\nWHERE n.name STARTS WITH 'A'\n  AND n.email CONTAINS '@example.com'\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Optional Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Optional Relationships\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Match nodes with optional relationship\nMATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nRETURN n.name, c.name AS company\n\n-- Handle nulls from optional match\nMATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nRETURN n.name,\n       coalesce(c.name, 'Unemployed') AS company\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Multiple Optional Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`MATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nOPTIONAL MATCH (n)-[:LIVES_IN]->(l:Location)\nRETURN n.name, c.name, l.city\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"UNION and Combining Results\"}),`\n`,(0,e.jsx)(n.h3,{children:\"UNION ALL\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Combine results (including duplicates)\nMATCH (n:Person)\nWHERE n.city = 'New York'\nRETURN n.name AS name\nUNION ALL\nMATCH (n:Person)\nWHERE n.city = 'San Francisco'\nRETURN n.name AS name\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"UNION DISTINCT\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Combine results (remove duplicates)\nMATCH (n:Person)\nWHERE n.city = 'New York'\nRETURN n.name AS name\nUNION\nMATCH (n:Person)\nWHERE n.city = 'San Francisco'\nRETURN n.name AS name\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Subqueries and WITH Clause\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Complex WITH Operations\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Chain multiple operations\nMATCH (n:Person)\nWITH n\nWHERE n.age > 30\nWITH n, n.age * 2 AS double_age\nWHERE double_age > 60\nRETURN n.name, double_age\n\n-- Aggregate and filter\nMATCH (n:Person)\nWITH n.city AS city, COLLECT(n.name) AS residents, COUNT(n) AS count\nWHERE count > 10\nRETURN city, residents, count\nORDER BY count DESC\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Pattern Comprehension\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Create list from pattern\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) | b.name] AS friends\n\n-- Pattern comprehension with filter\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) WHERE b.age > 30 | b.name] AS older_friends\n\n-- Nested comprehension\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) |\n  {name: b.name, friends: [(b)-[:KNOWS]->(c) | c.name]}\n] AS friend_network\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Shortest Path Queries\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Single Shortest Path\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find shortest path between two nodes\nMATCH (a:Person {name: 'Alice'}), (b:Person {name: 'Charlie'})\nMATCH path = shortestPath((a)-[:KNOWS*]-(b))\nRETURN path\n\n-- Find shortest path with specific relationship type\nMATCH (a:Person {name: 'Alice'}), (b:Person {name: 'Charlie'})\nMATCH path = shortestPath((a)-[:KNOWS*]-(b))\nRETURN path\n\n-- Get path length\nMATCH (a:Person {name: 'Alice'}), (b:Person {name: 'Charlie'})\nMATCH path = shortestPath((a)-[:KNOWS*]-(b))\nRETURN length(path) AS distance\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"All Shortest Paths\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find all shortest paths\nMATCH (a:Person {name: 'Alice'}), (b:Person {name: 'Charlie'})\nMATCH path = allShortestPaths((a)-[:KNOWS*]-(b))\nRETURN path\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Variable Length Paths\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Unbounded Paths\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find all connected nodes (any depth)\nMATCH (n:Person {name: 'Alice'})-[:KNOWS*]-(connected)\nRETURN DISTINCT connected\n\n-- Specify minimum depth\nMATCH (n:Person {name: 'Alice'})-[:KNOWS*2..]-(connected)\nRETURN DISTINCT connected\n\n-- Specify maximum depth\nMATCH (n:Person {name: 'Alice'})-[:KNOWS*..3]-(connected)\nRETURN DISTINCT connected\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Bounded Variable Length Paths\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Specify exact range\nMATCH (n:Person {name: 'Alice'})-[:KNOWS*2..3]-(connected)\nRETURN DISTINCT connected\n\n-- Path with intermediate nodes\nMATCH path = (a:Person {name: 'Alice'})-[:KNOWS*2..3]-(b:Person)\nRETURN [node in nodes(path) | node.name] AS connection_chain\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Complex Pattern Matching\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Intersection Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find nodes connected to multiple specific nodes\nMATCH (n:Person)\nWHERE (n)-[:KNOWS]->({name: 'Alice'})\n  AND (n)-[:KNOWS]->({name: 'Bob'})\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Exclusion Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find people who know Alice but not Bob\nMATCH (n:Person)-[:KNOWS]->({name: 'Alice'})\nWHERE NOT (n)-[:KNOWS]->({name: 'Bob'})\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Relationship Chains\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Match specific relationship sequences\nMATCH (a:Person)-[:KNOWS]->(b:Person)-[:WORKS_AT]->(c:Company)\nWHERE a.name = 'Alice'\nRETURN a, b, c\n\n-- Match relationship with properties\nMATCH (n:Person)-[r:KNOWS {since: 2020}]->(m:Person)\nRETURN n, r, m\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Conditional Logic\"}),`\n`,(0,e.jsx)(n.h3,{children:\"CASE Expressions\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Simple CASE\nMATCH (n:Person)\nRETURN n.name,\n       CASE n.age\n         WHEN < 20 THEN 'Young'\n         WHEN < 40 THEN 'Adult'\n         ELSE 'Senior'\n       END AS age_group\n\n-- Generic CASE\nMATCH (n:Person)\nRETURN n.name,\n       CASE\n         WHEN n.age < 18 THEN 'Minor'\n         WHEN n.age >= 18 AND n.age < 65 THEN 'Adult'\n         ELSE 'Senior'\n       END AS category\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"COALESCE for Null Handling\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Provide default for null values\nMATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nRETURN n.name, coalesce(c.name, 'Unemployed') AS company\n\n-- Multiple fallback values\nMATCH (n:Person)\nRETURN n.name,\n       coalesce(n.email, n.phone, 'No contact info') AS contact\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Query Profiling\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Profile query execution\nPROFILE MATCH (n:Person)\nWHERE n.age > 30\nRETURN n\n\n-- Explain query plan (without executing)\nEXPLAIN MATCH (n:Person)\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Optimization Tips\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- GOOD: Start with specific nodes\nMATCH (n:Person {name: 'Alice'})-[:KNOWS]->(b)\nRETURN b\n\n-- AVOID: Too broad patterns\nMATCH (a)-[:KNOWS]->(b)\nRETURN a, b\n\n-- GOOD: Use labels\nMATCH (n:Person)-[:KNOWS]->(m:Person)\nRETURN n, m\n\n-- GOOD: Filter early\nMATCH (n:Person)\nWHERE n.age > 30\nMATCH (n)-[:KNOWS]->(b)\nRETURN b\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Advanced Examples\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Social Network Analysis\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find friends of friends (not direct friends)\nMATCH (me:Person {name: 'Alice'})-[:KNOWS]->(friend)-[:KNOWS]->(fof)\nWHERE NOT (me)-[:KNOWS]->(fof) AND fof <> me\nRETURN fof.name, COUNT(friend) AS mutual_friends\nORDER BY mutual_friends DESC\nLIMIT 10\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Recommendation Engine\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Recommend people with similar interests\nMATCH (me:Person {name: 'Alice'})-[:HAS_INTEREST]->(i:Interest)<-[:HAS_INTEREST]-(other:Person)\nWHERE me <> other\nWITH other, COUNT(i) AS common_interests\nORDER BY common_interests DESC\nRETURN other.name, common_interests\nLIMIT 10\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Influence Analysis\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Find most influential people in a network\nMATCH (p:Person)\nWITH p, SIZE((p)<-[:KNOWS]-()) AS influence\nORDER BY influence DESC\nRETURN p.name, influence\nLIMIT 10\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use PROFILE\"}),\": Always profile complex queries to understand performance\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Limit path lengths\"}),\": Use bounded variable length paths to avoid explosion\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Filter early\"}),\": Apply WHERE clauses as early as possible\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use indexes\"}),\": Create indexes on frequently queried properties\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Avoid cartesian products\"}),\": Be careful with multiple disconnected MATCH patterns\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use WITH wisely\"}),\": Break complex queries into logical steps\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Test incrementally\"}),\": Build complex queries step by step\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Next Steps\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Explore \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/pattern-matching\",children:\"Pattern Matching\"}),\" for more advanced patterns\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Learn about \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/batch-operations\",children:\"Batch Operations\"}),\" for bulk data processing\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Understand \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/transactions\",children:\"Transaction Control\"}),\" for data consistency\"]}),`\n`]})]})}function d(r={}){let{wrapper:n}=r.components||{};return n?(0,e.jsx)(n,{...r,children:(0,e.jsx)(h,{...r})}):h(r)}return C(u);})();\n;return Component;"