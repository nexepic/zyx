eIds;\n\n    while (currentEdgeId != 0) {\n        // \\u5728\\u8FB9\\u94FE\\u8868\\u4E2D\\u68C0\\u6D4B\\u5230\\u5FAA\\u73AF\\u3002\\u4E2D\\u6B62\\u904D\\u5386\\u3002\n        if (visitedEdgeIds.contains(currentEdgeId)) {\n            throw std::runtime_error(\"Cycle detected in incoming edges linked-list for node \" +\n                                     std::to_string(nodeId));\n        }\n        visitedEdgeIds.insert(currentEdgeId);\n\n        Edge edge = dataManager->getEdge(currentEdgeId);\n        if (edge.isActive()) {\n            inEdges.push_back(edge);\n        }\n        currentEdgeId = edge.getNextInEdgeId();\n    }\n    return inEdges;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u7279\\u6027\"}),\"\\uFF1A\\u4E0E \",(0,e.jsx)(n.code,{children:\"getOutgoingEdges\"}),\" \\u76F8\\u540C\\uFF0C\\u4F46\\u7528\\u4E8E\\u5165\\u8FB9\\u5173\\u7CFB\\u3002\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u83B7\\u53D6\\u6240\\u6709\\u8FDE\\u63A5\\u7684\\u8FB9\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u5408\\u5E76\\u51FA\\u8FB9\\u548C\\u5165\\u8FB9\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<Edge> RelationshipTraversal::getAllConnectedEdges(int64_t nodeId) const {\n    std::vector<Edge> outEdges = getOutgoingEdges(nodeId);\n    std::vector<Edge> inEdges = getIncomingEdges(nodeId);\n\n    // \\u5408\\u5E76\\u4E24\\u4E2A\\u5411\\u91CF\n    outEdges.insert(outEdges.end(), inEdges.begin(), inEdges.end());\n    return outEdges;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u4F7F\\u7528\\u573A\\u666F\"}),\"\\uFF1A\\u67E5\\u627E\\u8FDE\\u63A5\\u5230\\u8282\\u70B9\\u7684\\u6240\\u6709\\u5173\\u7CFB\\uFF0C\\u65E0\\u8BBA\\u65B9\\u5411\\u5982\\u4F55\\u3002\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u83B7\\u53D6\\u8FDE\\u63A5\\u7684\\u76EE\\u6807\\u8282\\u70B9\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u68C0\\u7D22\\u901A\\u8FC7\\u51FA\\u8FB9\\u53EF\\u8FBE\\u7684\\u6240\\u6709\\u8