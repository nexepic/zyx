n.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) const {\n    auto ptrs = registry_->getBlobPtrs(targetId);\n\n    // \\u4F7F\\u7528 PQ \\u8FDB\\u884C\\u5FEB\\u901F\\u5BFC\\u822A\n    if (isPQTrained() && ptrs.pqBlob != 0 && !pqTable.empty()) {\n        return distPQ(pqTable, targetId);\n    }\n\n    // \\u56DE\\u9000\\u5230\\u539F\\u59CB\\u5411\\u91CF\n    return distRaw(query, targetId);\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u641C\\u7D22\\u5DE5\\u4F5C\\u6D41\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u56FE\\u904D\\u5386\"}),\"\\uFF1A\\u4F7F\\u7528 PQ \\u8DDD\\u79BB\\u8FDB\\u884C\\u5FEB\\u901F\\u5BFC\\u822A\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u5019\\u9009\\u9009\\u62E9\"}),\"\\uFF1A\\u4F7F\\u7528\\u8FD1\\u4F3C\\u8DDD\\u79BB\\u627E\\u5230 top \\u5019\\u9009\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u91CD\\u6392\\u5E8F\"}),\"\\uFF1A\\u4F7F\\u7528\\u539F\\u59CB\\u5411\\u91CF\\u8BA1\\u7B97 top-k \\u7ED3\\u679C\\u7684\\u7CBE\\u786E\\u8DDD\\u79BB\"]}),`\n`]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> search(\n    const std::vector<float>& query,\n    size_t k\n) const {\n    // 1. \\u8BA1\\u7B97 PQ \\u8DDD\\u79BB\\u8868\n    auto pqTable = isPQTrained() ?\n        quantizer_->computeDistanceTable(query) :\n        std::vector<float>{};\n\n    // 2. \\u4F7F\\u7528 PQ \\u8DDD\\u79BB\\u8FDB\\u884C\\u8D2A\\u5A6A\\u641C\\u7D22\n    auto candidates = greedySearch(\n        query,\n        entryPoint,\n        std::max(config_.beamWidth, k * 2),\n        pqTable\n    );\n\n    // 3. \\u4F7F\\u7528\\u7CBE\\u786E\\u8DDD\\u79BB\\u91CD\\u6392\\u5E8F\n    std::vector<std::pair<int64_t, float>> results;\n    for (auto& [nodeId, _] : candidates) {\n        float exactDist = distRaw(query, nodeId);\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. \\u6392\\u5E8F\\u5E76\\u8FD4\\u56DE top-k\n    std::sort(results.begin(), results.end());\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u4F18\\u52BF\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u901F\\u5EA6\"}),\"\\uFF1A\\u56FE\\u904D\\u5386\\u671F\\u95F4\\u4F7F\\u7528 PQ \\u8DDD\\u79BB\\uFF08O(M) vs O(D)\\uFF09\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u7CBE\\u5EA6\"}),\"\\uFF1A\\u6700\\u7EC8\\u6392\\u5E8F\\u4F7F\\u7528\\u7CBE\\u786E\\u8DDD\\u79BB\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u5185\\u5B58\"}),\"\\uFF1A\\u4E3A\\u6240\\u6709\\u5411\\u91CF\\u5B58\\u50A8 PQ \\u7801\\uFF0C\\u4E3A\\u91CD\\u6392\\u5E8F\\u5B58\\u50A8\\u539F\\u59CB\\u5411\\u91CF\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u517C\\u5BB9\\u6027\"}),\"\\uFF1A\\u9002\\u7528\\u4E8E\\u6CA1\\u6709 PQ \\u7801\\u7684\\u73B0\\u6709\\u5411\\u91CF\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u5E8F\\u5217\\u5316\"}),`\n`,(0,e.jsx)(n.p,{children:\"PQ \\u7801\\u672C\\u53EF\\u4EE5\\u5E8F\\u5217\\u5316\\u4EE5\\u6301\\u4E45\\u5316\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void serialize(std::ostream& os) const {\n    utils::Serializer::writePOD(os, dim_);\n    utils::Serializer::writePOD(os, numSubspaces_);\n    utils::Serializer::writePOD(os, numCentroids_);\n    utils::Serializer::writePOD(os, isTrained_);\n\n    if (isTrained_) {\n        for (const auto& subspace : codebooks_) {\n            for (const auto& centroid : subspace) {\n                for (float v : centroid)\n                    utils::Serializer::writePOD(os, v);\n            }\n        }\n    }\n}\n\nstatic std::unique_ptr<NativeProductQuantizer> deserialize(\n    std::istream& is\n) {\n    size_t dim = utils::Serializer::readPOD<size_t>(is);\n    size_t subs = utils::Serializer::readPOD<size_t>(is);\n    size_t cents = utils::Serializer::readPOD<size_t>(is);\n    bool trained = utils::Serializer::readPOD<bool>(is);\n\n    auto pq = std::make_unique<NativeProductQuantizer>(dim, subs, cents);\n    pq->isTrained_ = trained;\n\n    if (trained) {\n        pq->codebooks_.resize(subs);\n        size_t subDim = dim / subs;\n        for (size_t m = 0; m < subs; ++m) {\n            pq->codebooks_[m].resize(cents);\n            for (size_t c = 0; c < cents; ++c) {\n                pq->codebooks_[m][c].resize(subDim);\n                for (size_t d = 0; d < subDim; ++d)\n                    pq->codebooks_[m][c][d] =\n                        utils::Serializer::readPOD<float>(is);\n            }\n        }\n    }\n    return pq;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u6027\\u80FD\\u7279\\u5F81\"}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u538B\\u7F29\\u6BD4\"}),`\n`,(0,e.jsx)(n.p,{children:`| \\u7EF4\\u5EA6 | \\u539F\\u59CB (FP32) | \\u539F\\u59CB (BF16) | PQ (8D) | \\u6BD4\\u7387 (vs BF16) |\n|-----------|------------|------------|---------|-----------------|\n| 128 | 512 \\u5B57\\u8282 | 256 \\u5B57\\u8282 | 16 \\u5B57\\u8282 | 16\\xD7 |\n| 256 | 1024 \\u5B57\\u8282 | 512 \\u5B57\\u8282 | 32 \\u5B57\\u8282 | 16\\xD7 |\n| 384 | 1536 \\u5B57\\u8282 | 768 \\u5B57\\u8282 | 48 \\u5B57\\u8282 | 16\\xD7 |\n| 512 | 2048 \\u5B57\\u8282 | 1024 \\u5B57\\u8282 | 64 \\u5B57\\u8282 | 16\\xD7 |\n| 768 | 3072 \\u5B57\\u8282 | 1536 \\u5B57\\u8282 | 96 \\u5B57\\u8282 | 16\\xD7 |\n| 1024 | 4096 \\u5B57\\u8282 | 2048 \\u5B57\\u8282 | 128 \\u5B57\\u8282 | 16\\xD7 |`}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u641C\\u7D22\\u6027\\u80FD\"}),`\n`,(0,e.jsx)(n.p,{children:`| \\u6570\\u636E\\u96C6\\u5927\\u5C0F | \\u7D22\\u5F15\\u7C7B\\u578B | \\u5185\\u5B58 | QPS (P=0.9) | Recall @10 |\n|--------------|------------|--------|-------------|------------|\n| 100\\u4E07 | \\u539F\\u59CB (BF16) | 1.5 GB | 500 | 100