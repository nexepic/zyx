nst {\n    std::vector<float> table(numSubspaces_ * numCentroids_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* querySubPtr = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                querySubPtr,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n            table[m * numCentroids_ + c] = dist;\n        }\n    }\n    return table;\n}\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"\\u8FD9\\u521B\\u5EFA\\u4E86\\u5927\\u5C0F\\u4E3A M \\xD7 K \\u7684\\u8DDD\\u79BB\\u8868 T\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`T[m][i] = ||q_m - c_mi||\\xB2\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[\"\\u5BF9\\u4E8E M = 96\\uFF0CK = 256\\uFF1A\\u8868\\u5927\\u5C0F = 96 \\xD7 256 \\xD7 4 = \",(0,e.jsx)(n.strong,{children:\"98,304 \\u5B57\\u8282\"}),\"\\uFF08~96 KB\\uFF09\"]}),`\n`,(0,e.jsx)(n.h4,{children:\"\\u5FEB\\u901F\\u8DDD\\u79BB\\u67E5\\u627E\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u7ED9\\u5B9A\\u6570\\u636E\\u5E93\\u5411\\u91CF x \\u7684 PQ \\u7801\\uFF0C\\u8BA1\\u7B97\\u8FD1\\u4F3C\\u8DDD\\u79BB\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`d(q, x) \\u2248 \\u03A3 T[m][codes[m]]\n`})}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`static float computeDistance(\n    const std::vector<uint8_t>& codes,\n    const std::vector<float>& distTable,\n    size_t numSubspaces,\n    size_t numCentroids = 256\n) {\n    float dist = 0.0f;\n    size_t m = 0;\n    size_t stride = numCentroids;\n\n    // \\u624B\\u52A8\\u5FAA\\u73AF\\u5C55\\u5F00\\u4EE5\\u63D0\\u9AD8\\u6D41\\u6C34\\u7EBF\\u6548\\u7387\n    for (; m + 3 < numSubspaces; m += 4) {\n        dist += distTable[(m + 0) * stride + codes[m + 0]];\n        dist += distTable[(m + 1) * stride + codes[m + 1]];\n        dist += distTable[(m + 2) * stride + codes[m + 2]];\n        dist += distTable[(m + 3) * stride + codes[m + 3]];\n    }\n    for (; m < numSubspaces; ++m) {\n        dist += distTable[m * stride + codes[m]];\n    }\n    return dist;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u8DDD\\u79BB\\u8BA1\\u7B97\\u6D41\\u7A0B\"}),`\n`,(0,e.jsx)(r,{chart:`flowchart TD\n    Start([\\u67E5\\u8BE2\\u5411\\u91CF q]) --> Precompute[\\u9884\\u8BA1\\u7B97\\u8DDD\\u79BB\\u8868]\n    Precompute --> Table[\"\\u8868 T\"]\n\n    Database[\"\\u6570\\u636E\\u5E93\\u5411\\u91CF x\"] --> Lookup[\\u67E5\\u627E\\u8DDD\\u79BB]\n\n    Table --> Lookup\n    Lookup --> Sum[\"\\u5BF9 M \\u4E2A\\u8DDD\\u79BB\\u6C42\\u548C\"]\n    Sum --> Return([\\u8FD1\\u4F3C\\u8DDD\\u79BB d])`}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"\\u8DDD\\u79BB\\u8BA1\\u7B97\\uFF1A\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"\\u8868 T\\uFF1AM \\xD7 K \\u4E2A\\u6761\\u76EE\\uFF08\\u5BF9\\u4E8E M=96\\u3001K=256 \\u7EA6 96 KB\\uFF09\"}),`\n`,(0,e.jsx)(n.li,{children:\"\\u5BF9\\u4E8E\\u6BCF\\u4E2A\\u6570\\u636E\\u5E93\\u5411\\u91CF\\uFF1Ad = \\u03A3 T[m, codes[m]]\"}),`\n`,(0,e.jsx)(n.li,{children:\"\\u590D\\u6742\\u5EA6\\uFF1A\\u8868\\u9884\\u8BA1\\u7B97\\u540E\\u6BCF\\u4E2A\\u5411\\u91CF O(M)\"}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u590D\\u6742\\u5EA6\\u5206\\u6790\"}),`\n`,(0,e.jsx)(n.p,{children:`| \\u64CD\\u4F5C | \\u539F\\u59CB\\u8BA1\\u7B97 | PQ with ADC | \\u52A0\\u901F\\u6BD4 |\n|-----------|----------------|-------------|---------|\n| \\u5355\\u6B21\\u8DDD\\u79BB | O(D) | O(M) | D/M |\n| \\u8DDD\\u79BB\\u8868 | - | O(M \\xD7 K \\xD7 Di) | - |\n| 1000 \\u6B21\\u8DDD\\u79BB | O(1000 \\xD7 D) | O(M \\xD7 K \\xD7 Di + 1000 \\xD7 M) | ~D/M |`}),`\n`,(0,e.jsx)(n.p,{children:\"\\u5BF9\\u4E8E D = 768\\uFF0CM = 96\\uFF0CK = 256\\uFF0CDi = 8\\uFF1A\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"\\u539F\\u59CB\\uFF1A1000 \\xD7 768 = 768,000 \\u6B21\\u64CD\\u4F5C\"}),`\n`,(0,e.jsx)(n.li,{children:\"PQ\\uFF1A96 \\xD7 256 \\xD7 8 + 1000 \\xD7 96 = 196,608 + 96,000 = 292,608 \\u6B21\\u64CD\\u4F5C\"}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u52A0\\u901F\\u6BD4\"}),\"\\uFF1A2.6\\xD7\"]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[\"\\u5BF9\\u4E8E 10,000 \\u6B21\\u8DDD\\u79BB\\uFF1A\",(0,e.jsx)(n.strong,{children:\"\\u52A0\\u901F\\u6BD4\"}),\"\\uFF1A~7.5\\xD7\\uFF08\\u644A\\u9500\\uFF09\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"K-Means \\u8BAD\\u7EC3\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means \\u805A\\u7C7B\\u7528\\u4E8E\\u8BAD\\u7EC3\\u6BCF\\u4E2A\\u5B50\\u7A7A\\u95F4\\u7684\\u7801\\u672C\\u3002\"}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u7B97\\u6CD5\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class KMeans {\npublic:\n    static std::vector<std::vector<float>> run(\n        const std::vector<std::vector<float>>& data,\n        size_t k,\n        size_t max_iter = 15\n    ) {\n        if (data.empty()) return {};\n        size_t dim = data[0].size();\n        size_t n = data.size();\n\n        // \\u968F\\u673A\\u521D\\u59CB\\u5316\\u8D28\\u5FC3\n        std::vector centroids(k, std::vector<float>(dim));\n        std::vector<int> assignment(n);\n        std::mt19937 rng(42);\n        std::uniform_int_distribution<size_t> dist(0, n - 1);\n\n        for (size_t i = 0; i < k; ++i) {\n            centroids[i] = data[dist(rng)];\n        }\n\n        // EM \\u8FED\\u4EE3\n        for (size_t it = 0; it < max_iter; ++it) {\n            bool changed = false;\n            std::vector sums(k, std::vector(dim, 0.0f));\n            std::vector<size_t> counts(k, 0);\n\n            // E \\u6B65\\uFF1A\\u5C06\\u70B9\\u5206\\u914D\\u5230\\u6700\\u8FD1\\u7684\\u8D28\\u5FC3\n            for (size_t i = 0; i < n; ++i) {\n                float min_dist = std::numeric_limits<float>::max();\n                int best_c = 0;\n\n                for (size_t c = 0; c < k; ++c) {\n                    float dist_val = VectorMetric::computeL2Sqr(\n                        data[i].data(),\n                        centroids[c].data(),\n                        dim\n                    );\n\n                    if (dist_val < min_dist) {\n                        min_dist = dist_val;\n                        best_c = c;\n                    }\n                }\n                if (assignment[i] != best_c) changed = true;\n                assignment[i] = best_c;\n\n                // \\u4E3A M \\u6B65\\u7D2F\\u52A0\n                for (size_t d = 0; d < dim; ++d)\n                    sums[best_c][d] += data[i][d];\n                counts[best_c]++;\n            }\n\n            if (!changed) break;\n\n            // M \\u6B65\\uFF1A\\u66F4\\u65B0\\u8D28\\u5FC3\n            for (size_t c = 0; c < k; ++c) {\n                if (counts[c] > 0) {\n                    float inv_count = 1.0f / static_cast<float>(counts[c]);\n                    for (size_t d = 0; d < dim; ++d)\n                        centroids[c][d] = sums[c][d] * inv_count;\n                } else {\n                    centroids[c] = data[dist(rng)]; // \\u91CD\\u65B0\\u521D\\u59CB\\u5316\\u7A7A\\u7C07\n                }\n            }\n        }\n        return centroids;\n    }\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u8BAD\\u7EC3\\u590D\\u6742\\u5EA6\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u5BF9\\u4E8E\\u4E00\\u4E2A\\u5B50\\u7A7A\\u95F4\\uFF1A\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"E \\u6B65\\uFF1AO(n \\xD7 K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"M \\u6B65\\uFF1AO(K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"\\u6BCF\\u6B21\\u8FED\\u4EE3\\u603B\\u8BA1\\uFF1AO(n \\xD7 K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"M \\u4E2A\\u5B50\\u7A7A\\u95F4\\u603B\\u8BA1\\uFF1AO(M \\xD7 n \\xD7 K \\xD7 Di \\xD7 iterations)\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:\"\\u5BF9\\u4E8E n = 10,000 \\u4E2A\\u8BAD\\u7EC3\\u5411\\u91CF\\uFF0CM = 96\\uFF0CK = 256\\uFF0CDi = 8\\uFF0Citerations = 15\\uFF1A\"}),`\n`,(0,e.jsxs)(n.ul,{children