e Batching\"}),`\n`,(0,e.jsx)(n.p,{children:\"Use batch operations when:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Importing large datasets (>1000 records)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Performing bulk updates or deletions\"}),`\n`,(0,e.jsx)(n.li,{children:\"Migrating data from other systems\"}),`\n`,(0,e.jsx)(n.li,{children:\"Processing time-consuming operations\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Batching Strategies\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Fixed Size Batches\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Process 1000 records at a time\n# Batch 1\nzyx> BEGIN\nzyx (transaction)> CREATE (p:Person {id: 1, name: 'Alice'})\nzyx (transaction)> CREATE (p:Person {id: 2, name: 'Bob'})\n# ... 998 more records ...\nzyx (transaction)> COMMIT\n\n# Batch 2\nzyx> BEGIN\nzyx (transaction)> CREATE (p:Person {id: 1001, name: 'Charlie'})\n# ... next 1000 records ...\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Time-Based Batching\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Commit every N seconds\nzyx> BEGIN\n# Start timer\n# Process records for 10 seconds\nzyx (transaction)> CREATE (p:Person {name: 'David'})\n# ... more records ...\n# After 10 seconds:\nzyx (transaction)> COMMIT\n\n# Start next batch\nzyx> BEGIN\n# Continue processing...\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Memory-Based Batching\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Monitor memory usage\nzyx> BEGIN\n# Process until memory reaches threshold\nzyx (transaction)> CREATE (p:Person {name: 'Eve'})\n# ... more records ...\n# Check memory: if usage > 500MB, commit\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"CLI Batching Techniques\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Using Scripts\"}),`\n`,(0,e.jsx)(n.p,{children:\"Create a Cypher script for batch operations:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// batch_import.cypher\n// Process in batches of 1000\n\n// Batch 1: Records 1-1000\nBEGIN\nCREATE (p:Person {id: 1, name: 'Person1'})\nCREATE (p:Person {id: 2, name: 'Person2'})\n// ... up to id: 1000 ...\nCOMMIT;\n\n// Batch 2: Records 1001-2000\nBEGIN\nCREATE (p:Person {id: 1001, name: 'Person1001'})\n// ... up to id: 2000 ...\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Run the script:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`$ zyx-cli < batch_import.cypher\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Using Parameterized Queries\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Prepare parameterized query\nzyx> :param batch_size => 1000\nzyx> :param start_id => 1\n\n# Execute with parameters\nzyx> BEGIN\nzyx (transaction)> CREATE (p:Person {id: $start_id})\nzyx (transaction)> CREATE (p:Person {id: $start_id + 1})\n# ... etc ...\nzyx (transaction)> COMMIT\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Batch Import Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"CSV Import in Batches\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Import large CSV in batches\n# Using shell script to split CSV and process\n\n#!/bin/bash\n# import_batches.sh\n\nBATCH_SIZE=1000\nTOTAL_RECORDS=10000\nFILE=\"people.csv\"\n\nfor ((START=1; START<=TOTAL_RECORDS; START+=BATCH_SIZE)); do\n  END=$((START + BATCH_SIZE - 1))\n\n  # Generate Cypher for this batch\n  cat > batch_$START.cypher <<EOF\nBEGIN\n\\\\$(tail -n +$START $FILE | head -n $BATCH_SIZE | \\\\\n  awk -F, '{print \"CREATE (:Person {id: \" \\\\$1 \", name: \\\\\"\" \\\\$2 \"\\\\\", age: \" \\\\$3 \"})\"}')\nCOMMIT;\nEOF\n\n  # Execute batch\n  zyx-cli < batch_$START.cypher\n  echo \"Imported records $START to $END\"\n\n  # Clean up\n  rm batch_$START.cypher\ndone\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Node Creation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Create nodes in batches\n// Batch 1\nBEGIN\nUNWIND range(1, 1000) AS id\nCREATE (p:Person {id: id, name: 'Person' + id})\nCOMMIT;\n\n// Batch 2\nBEGIN\nUNWIND range(1001, 2000) AS id\nCREATE (p:Person {id: id, name: 'Person' + id})\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Relationship Creation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Create relationships after nodes exist\n// Batch 1\nBEGIN\nMATCH (p1:Person {id: 1}), (p2:Person {id: 2})\nCREATE (p1)-[:KNOWS]->(p2);\n\nMATCH (p1:Person {id: 1}), (p2:Person {id: 3})\nCREATE (p1)-[:KNOWS]->(p2);\n\n// ... 998 more relationships ...\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Batch Update Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Property Updates\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Update properties in batches\n// Batch 1\nBEGIN\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nSET p.processed = true, p.updatedAt = timestamp()\nCOMMIT;\n\n// Batch 2\nBEGIN\nMATCH (p:Person)\nWHERE p.id >= 1001 AND p.id <= 2000\nSET p.processed = true, p.updatedAt = timestamp()\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Delete\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Delete in batches to avoid locking issues\n// Batch 1\nBEGIN\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nDETACH DELETE p\nCOMMIT;\n\n// Batch 2\nBEGIN\nMATCH (p:Person)\nWHERE p.id >= 1001 AND p.id <= 2000\nDETACH DELETE p\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Optimization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Use UNWIND for Bulk Operations\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Efficient batch creation using UNWIND\nBEGIN\nWITH [\n  {id: 1, name: 'Alice', age: 30},\n  {id: 2, name: 'Bob', age: 25},\n  {id: 3, name: 'Charlie', age: 35}\n  // ... up to 1000 items ...\n] AS batch\nUNWIND batch AS item\nCREATE (p:Person {id: item.id, name: item.name, age: item.age})\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Using FOREACH for Batching\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Process list in chunks\nBEGIN\nMATCH (p:Person)\nWITH collect(p) AS people\nWITH people, size(people) AS total\nFOREACH (i IN range(0, total/1000) |\n  FOREACH (p IN people[i*1000..(i+1)*1000-1] |\n    SET p.batchProcessed = true\n  )\n)\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Parallel Batch Processing\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Run multiple batch operations in parallel\n# Terminal 1\nzyx-cli < batch_1.cypher &\n\n# Terminal 2\nzyx-cli < batch_2.cypher &\n\n# Terminal 3\nzyx-cli < batch_3.cypher &\n\n# Wait for all to complete\nwait\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Error Handling in Batches\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Skip Failed Records\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Use FOREACH with conditional logic\nBEGIN\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nFOREACH (_ IN CASE WHEN p.age > 0 THEN [1] ELSE [] END |\n  SET p.valid = true\n)\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch with Validation\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Validate before batch commit\nBEGIN\n// Perform updates\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nSET p.processed = true\n\n// Verify updates\nWITH count(p) AS updated\nWHERE updated = 1000\n// Only commit if all updated\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Continue on Error\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Wrapper script to handle batch failures\n#!/bin/bash\n# robust_batch.sh\n\nfor BATCH_FILE in batch_*.cypher; do\n  echo \"Processing $BATCH_FILE\"\n\n  # Execute batch\n  if zyx-cli < $BATCH_FILE; then\n    echo \"Success: $BATCH_FILE\"\n  else\n    echo \"Failed: $BATCH_FILE\"\n    # Log failure and continue\n    echo \"$BATCH_FILE failed\" >> failures.log\n  fi\ndone\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Monitoring Batch Operations\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Progress Tracking\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Track progress during batch operation\nBEGIN\n// Get initial count\nMATCH (p:Person)\nWITH count(p) AS initial_count\n\n// Process batch\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nSET p.processed = true\n\n// Report progress\nWITH initial_count, count(p) AS total\nRETURN initial_count, total, 'Batch 1/10' AS progress\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Statistics\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Collect statistics during batch processing\n#!/bin/bash\n# batch_with_stats.sh\n\nSTART_TIME=$(date +%s)\n\nfor BATCH in {1..10}; do\n  BATCH_START=$(date +%s)\n\n  # Process batch\n  zyx-cli < batch_\\${BATCH}.cypher\n\n  BATCH_END=$(date +%s)\n  BATCH_DURATION=$((BATCH_END - BATCH_START))\n\n  echo \"Batch $BATCH: \\${BATCH_DURATION}s\"\ndone\n\nEND_TIME=$(date +%s)\nTOTAL_DURATION=$((END_TIME - START_TIME))\n\necho \"Total time: \\${TOTAL_DURATION}s\"\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Batch Size Guidelines\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Small records (< 1KB each): 5000-10000 per batch\n# Medium records (1-10KB each): 1000-5000 per batch\n# Large records (> 10KB each): 100-1000 per batch\n# Complex operations: 100-500 per batch\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Memory Management\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Release memory between batches\nBEGIN\n// Process batch\nMATCH (p:Person)\nWHERE p.id >= 1 AND p.id <= 1000\nSET p.processed = true\nCOMMIT;\n\n// Clear cache\nzyx> CALL db.clearQueryCache();\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Transaction Control\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`# Always commit between batches\n# Don't let transactions run too long\n# Monitor lock contention\n\n# Good practice:\nfor BATCH in batch_*.cypher; do\n  # Each file has its own transaction\n  zyx-cli < $BATCH\ndone\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Real-World Examples\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Social Network Import\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-bash\",children:`#!/bin/bash\n# import_social_network.sh\n\n# Import users in batches\nfor BATCH in {1..100}; do\n  START=$((BATCH * 10000 - 9999))\n  END=$((BATCH * 10000))\n\n  cat > user_batch_$BATCH.cypher <<EOF\nBEGIN\nUSING PERIODIC COMMIT 1000\nLOAD CSV FROM 'file:///users/users_$START-$END.csv' AS row\nCREATE (u:User {id: toInteger(row.id), name: row.name, email: row.email})\nCOMMIT;\nEOF\n\n  zyx-cli < user_batch_$BATCH.cypher\ndone\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"E-commerce Data Migration\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`// Migrate product catalog in batches\n// Batch 1: Electronics\nBEGIN\nMATCH (p:OldProduct {category: 'Electronics'})\nCREATE (n:Product {\n  id: p.id,\n  name: p.name,\n  price: p.price,\n  category: 'Electronics'\n})\nDELETE p\nCOMMIT;\n\n// Batch 2: Clothing\nBEGIN\nMATCH (p:OldProduct {category: 'Clothing'})\nCREATE (n:Product {\n  id: p.id,\n  name: p.name,\n  price: p.price,\n  category: 'Clothing'\n})\nDELETE p\nCOMMIT;\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Tips and Tricks\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Test batch size\"}),\": Start with small batches and increase\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Monitor resources\"}),\": Watch CPU, memory, and disk I/O\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use indexes\"}),\": Create indexes before batch operations\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Disable constraints\"}),\": Temporarily disable for faster imports\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Log progress\"}),\": Keep detailed logs for troubleshooting\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Validate data\"}),\": Check data integrity after each batch\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Plan rollback\"}),\": Know how to undo if something goes wrong\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Next Steps\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Learn about \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/import-export\",children:\"Import & Export\"}),\" for data migration\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Understand \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/transactions\",children:\"Transaction Control\"}),\" for data consistency\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Explore \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/advanced-queries\",children:\"Advanced Queries\"}),\" for complex operations\"]}),`\n`]})]})}function d(r={}){let{wrapper:n}=r.components||{};return n?(0,e.jsx)(n,{...r,children:(0,e.jsx)(l,{...r})}):l(r)}return B(I);})();\n;return Component;"