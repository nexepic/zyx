.jsx)(n.code,{className:\"language-cypher\",children:`// Before optimization\nMATCH (u:User)\nWHERE u.age > 25\nRETURN u\n\n// After optimization\n// Filter pushed to node scan\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Implementation\"}),\":\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void pushDownFilters(LogicalPlan* plan) {\n    for (auto* filterOp : plan->getOperators<FilterOperator>()) {\n        // Find scan operator below filter\n        auto* scanOp = plan->findBelow(filterOp, ScanOperator::Type);\n\n        if (canPushDown(filterOp, scanOp)) {\n            // Move filter below scan\n            plan->reorder(filterOp, scanOp);\n        }\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Rule 2: Index Selection\"}),`\n`,(0,e.jsx)(n.p,{children:\"Use indexes when available:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void selectIndexes(LogicalPlan* plan) {\n    for (auto* scanOp : plan->getOperators<ScanOperator>()) {\n        if (hasIndex(scanOp->getLabel(), scanOp->getProperty())) {\n            // Replace scan with index scan\n            auto* indexScanOp = new IndexScanOperator(scanOp);\n            plan->replace(scanOp, indexScanOp);\n        }\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Rule 3: Join Reordering\"}),`\n`,(0,e.jsx)(n.p,{children:\"Optimize join order for performance:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void reorderJoins(LogicalPlan* plan) {\n    auto* join = plan->findJoin();\n\n    if (join) {\n        auto leftSize = estimateSize(join->getLeft());\n        auto rightSize = estimateSize(join->getRight());\n\n        // Swap if right side is smaller\n        if (rightSize < leftSize) {\n            join->swapChildren();\n        }\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Rule 4: Projection Pruning\"}),`\n`,(0,e.jsx)(n.p,{children:\"Remove unused columns:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void pruneProjections(LogicalPlan* plan) {\n    auto* projectOp = plan->findTop<ProjectOperator>();\n\n    if (projectOp) {\n        auto usedColumns = collectUsedColumns(plan, projectOp);\n        projectOp->pruneUnused(usedColumns);\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Cost Estimation\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Statistics Collection\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`struct TableStatistics {\n    uint64_t rowCount;\n    std::map<std::string, uint64_t> distinctCounts;\n    std::map<std::string, double> histograms;\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Cost Model\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`double estimateCost(LogicalOperator* op) {\n    switch (op->getType()) {\n        case OperatorType::Scan:\n            return estimateScanCost(op);\n        case OperatorType::IndexScan:\n            return estimateIndexScanCost(op);\n        case OperatorType::Filter:\n            return estimateFilterCost(op);\n        case OperatorType::Join:\n            return estimateJoinCost(op);\n        default:\n            return 0.0;\n    }\n}\n\ndouble estimateScanCost(ScanOperator* op) {\n    double tableSize = stats.getRowCount(op->getLabel());\n    return tableSize * SEQ_PAGE_COST;\n}\n\ndouble estimateFilterCost(FilterOperator* op) {\n    double inputRows = op->getChild()->getOutputRows();\n    double selectivity = estimateSelectivity(op->getPredicate());\n    return inputRows * CPU_TUPLE_COST + inputRows * selectivity * CPU_TUPLE_COST;\n}\n\ndouble estimateJoinCost(JoinOperator* op) {\n    double outerRows = op->getOuter()->getOutputRows();\n    double innerRows = op->getInner()->getOutputRows();\n    return outerRows * innerRows * CPU_TUPLE_COST;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Plan Selection\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Enumerate Plans\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<PhysicalPlan*> enumeratePlans(LogicalPlan* logical) {\n    std::vector<PhysicalPlan*> plans;\n\n    // Generate different physical implementations\n    plans.push_back(createNestedLoopJoinPlan(logical));\n    plans.push_back(createHashJoinPlan(logical));\n\n    return plans;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Choose Best Plan\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`PhysicalPlan* chooseBestPlan(const std::vector<PhysicalPlan*>& plans) {\n    PhysicalPlan* best = nullptr;\n    double minCost = std::numeric_limits<double>::max();\n\n    for (auto* plan : plans) {\n        double cost = estimateTotalCost(plan);\n        if (cost < minCost) {\n            minCost = cost;\n            best = plan;\n        }\n    }\n\n    return best;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Optimizations\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Caching Plans\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class PlanCache {\n    std::unordered_map<std::string, PhysicalPlan*> cache;\n\npublic:\n    PhysicalPlan* getPlan(const std::string& query) {\n        auto it = cache.find(query);\n        if (it != cache.end()) {\n            return it->second;\n        }\n        return nullptr;\n    }\n\n    void cachePlan(const std::string& query, PhysicalPlan* plan) {\n        cache[query] = plan;\n    }\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Adaptive Optimization\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class AdaptiveOptimizer {\n    struct PlanStats {\n        PhysicalPlan* plan;\n        uint64_t executionCount;\n        double avgExecutionTime;\n    };\n\n    std::unordered_map<std::string, PlanStats> planHistory;\n\npublic:\n    PhysicalPlan* optimize(const std::string& query, LogicalPlan* logical) {\n        // Check if we have history\n        auto it = planHistory.find(query);\n        if (it != planHistory.end()) {\n            return it->second.plan;\n        }\n\n        // Generate and cache plan\n        auto* plan = chooseBestPlan(enumeratePlans(logical));\n        planHistory[query] = {plan, 0, 0.0};\n        return plan;\n    }\n\n    void updateStats(const std::string& query, double executionTime) {\n        auto& stats = planHistory[query];\n        stats.executionCount++;\n        stats.avgExecutionTime =\n            (stats.avgExecutionTime * (stats.executionCount - 1) + executionTime) /\n            stats.executionCount;\n    }\n};\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Tips\"}),`\n`,(0,e.jsx)(n.h3,{children:\"For Users\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use indexes\"}),\": Create indexes on frequently queried properties\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Filter early\"}),\": Apply filters in WHERE clause\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Limit results\"}),\": Use LIMIT to avoid large result sets\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Avoid cross products\"}),\": Ensure patterns are connected\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Profile queries\"}),\": Use EXPLAIN to analyze plans\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"For Developers\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Maintain statistics\"}),\": Keep table statistics up to date\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Tune cost model\"}),\": Adjust cost constants for your hardware\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Monitor plans\"}),\": Track plan execution times\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Test queries\"}),\": Validate plan quality regularly\"]}),`\n`]}),`\n`,(0,e.jsx)(n.