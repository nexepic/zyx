72\\u9650\\u5236**\\uFF1A\\u4EC5\\u9650\\u4E13\\u4E1A\\u7070\\u5EA6\n   - **\\u7981\\u6B62\\u7684\\u989C\\u8272**\\uFF08\\u5207\\u52FF\\u4F7F\\u7528\\uFF09\\uFF1A\n     - \\`fill:#90EE90\\`\\uFF08\\u6D45\\u7EFF\\u8272\\uFF09\n     - \\`fill:#e1f5ff\\`\\uFF08\\u6D45\\u84DD\\u8272\\uFF09\n     - \\`fill:#ffe1e1\\`\\uFF08\\u6D45\\u7EA2\\u8272\\uFF09\n     - \\`fill:#ff0\\`, \\`fill:#f9f\\`, \\`fill:#bbf\\`\\uFF08\\u660E\\u4EAE\\u989C\\u8272\\uFF09\n     - \\`fill:lightblue\\`, \\`fill:lightgreen\\` \\u7B49\n     - \\u4EFB\\u4F55\\u5E26\\u989C\\u8272\\u7684 \\`stroke:\\` \\u6837\\u5F0F\n   - **\\u5141\\u8BB8\\u7684\\u6837\\u5F0F**\\uFF08\\u8C28\\u614E\\u4F7F\\u7528\\uFF09\\uFF1A\n     - \\u65E0\\u586B\\u5145/\\u989C\\u8272\\uFF08\\u9ED8\\u8BA4\\u9ED1\\u767D\\uFF09- **\\u9996\\u9009**\n     - \\u4EC5\\u9650\\u5FAE\\u5999\\u7684\\u7070\\u8272\\uFF1A\\`fill:#f0f0f0\\`, \\`fill:#e0e0e0\\`, \\`fill:#d0d0d0\\`\n   - **\\u7406\\u7531**\\uFF1A\\u5F69\\u8272\\u56FE\\u8868\\u663E\\u5F97\\u4E0D\\u4E13\\u4E1A\\u3001\\u6253\\u5370\\u6548\\u679C\\u4E0D\\u4F73\\u3001\\u53EF\\u80FD\\u5206\\u6563\\u6CE8\\u610F\\u529B\\u3002\\u7B80\\u5355\\u7684\\u7070\\u5EA6\\u56FE\\u8868\\u66F4\\u7B80\\u6D01\\u3001\\u66F4\\u9002\\u5408\\u51FA\\u7248\\u3002\n\n3. **\\u56FE\\u8868\\u7C7B\\u578B**\\uFF1A\\u4F7F\\u7528\\u9002\\u5F53\\u7684 Mermaid \\u56FE\\u8868\\u7C7B\\u578B\\uFF1A\n   - **\\u7ED3\\u6784**\\uFF1A\\`classDiagram\\` \\u7528\\u4E8E\\u7C7B\\u5C42\\u6B21\\u7ED3\\u6784\\u3001\\u6570\\u636E\\u7ED3\\u6784\n   - **\\u6D41\\u7A0B/\\u8FC7\\u7A0B**\\uFF1A\\`flowchart TD\\` \\u6216 \\`graph TD\\` \\u7528\\u4E8E\\u8FC7\\u7A0B\\u548C\\u6D41\\u7A0B\n   - **\\u72B6\\u6001**\\uFF1A\\`stateDiagram-v2\\` \\u7528\\u4E8E\\u72B6\\u6001\\u673A\n   - **\\u5E8F\\u5217**\\uFF1A\\`sequenceDiagram\\` \\u7528\\u4E8E\\u4EA4\\u4E92\n   - **\\u5B9E\\u4F53\\u5173\\u7CFB**\\uFF1A\\`erDiagram\\` \\u7528\\u4E8E\\u6570\\u636E\\u5E93\\u6A21\\u5F0F\n\n4. **\\u56FE\\u8868\\u6E05\\u6670\\u5EA6**\\uFF1A\n   - \\u4FDD\\u6301\\u56FE\\u8868\\u7B80\\u5355\\u548C\\u4E13\\u6CE8\n   - \\u907F\\u514D\\u8FC7\\u591A\\u7EC6\\u8282\\u6216\\u89C6\\u89C9\\u566A\\u97F3\n   - \\u786E\\u4FDD\\u6587\\u672C\\u53EF\\u8BFB\\u4E14\\u6807\\u7B7E\\u6E05\\u6670\n   - \\u5728\\u6240\\u6709\\u6587\\u6863\\u4E2D\\u4FDD\\u6301\\u4E00\\u81F4\\u7684\\u6837\\u5F0F\n\n#### \\u793A\\u4F8B\n\n**\\u826F\\u597D - \\u5E72\\u51C0\\u7684 Mermaid \\u56FE\\u8868\\uFF1A**\n\\`\\`\\`mermaid\nclassDiagram\n    class Database {\n        +open() void\n        +close() void\n        +execute(query) Result\n    }\n    class Transaction {\n        +commit() bool\n        +rollback() void\n    }\n    Database --> Transaction\n`})}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"\\u4E0D\\u826F - ASCII \\u827A\\u672F\\uFF08\\u7981\\u6B62\\uFF09\\uFF1A\"})}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`\\u250C\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2510\n\\u2502  Database   \\u2502\n\\u251C\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2524\n\\u2502  open()     \\u2502\n\\u2502  close()    \\u2502\n\\u2502  execute()  \\u2502\n\\u2514\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2518\n`})}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"\\u4E0D\\u826F - \\u5F69\\u8272 Mermaid\\uFF08\\u7981\\u6B62\\uFF09\\uFF1A\"})}),`\n`,(0,e.jsx)(l,{chart:`graph TD\n    A[\\u5F00\\u59CB] --> B[\\u5904\\u7406]\n    style A fill:#90EE90\n    style B fill:#e1f5ff\n    style A stroke:#f00,stroke-width:4px`}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"\\u826F\\u597D - \\u4E13\\u4E1A\\u7070\\u5EA6\\uFF1A\"})}),`\n`,(0,e.jsx)(l,{chart:`graph TD\n    A[\\u5F00\\u59CB] --> B[\\u5904\\u7406]\n    B --> C[\\u7ED3\\u675F]`}),`\n`,(0,e.jsx)(n.h4,{children:\"\\u4EE3\\u7801\\u793A\\u4F8B\\u6807\\u51C6\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[`\n`