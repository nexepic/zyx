ource\n    int64_t nextInEdgeId = 0;     // Next incoming to target\n    int64_t prevInEdgeId = 0;     // Previous incoming to target\n    int64_t propertyEntityId = 0;\n    int64_t labelId = 0;\n    uint32_t propertyStorageType = 0;\n    bool isActive = true;\n};\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Core Operations\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Get Outgoing Edges\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves all outgoing edges from a node by traversing the outgoing edge list:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Edge> RelationshipTraversal::getOutgoingEdges(int64_t nodeId) const {\n    std::vector<Edge> outEdges;\n    const auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return outEdges;\n    }\n\n    const Node node = dataManager->getNode(nodeId);\n    int64_t currentEdgeId = node.getFirstOutEdgeId();\n\n    // Keep track of visited edge IDs to detect cycles in the linked list.\n    std::unordered_set<int64_t> visitedEdgeIds;\n\n    while (currentEdgeId != 0) {\n        // Cycle detected in the edge linked-list. Abort traversal.\n        if (visitedEdgeIds.contains(currentEdgeId)) {\n            throw std::runtime_error(\"Cycle detected in outgoing edges linked-list for node \" +\n                                     std::to_string(nodeId));\n        }\n        visitedEdgeIds.insert(currentEdgeId);\n\n        Edge edge = dataManager->getEdge(currentEdgeId);\n        if (edge.isActive()) {\n            outEdges.push_back(edge);\n        }\n        currentEdgeId = edge.getNextOutEdgeId();\n    }\n    return outEdges;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Algorithm\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[\"Start with the node's \",(0,n.jsx)(e.code,{children:\"firstOutEdgeId\"})]}),`\n`,(0,n.jsxs)(e.li,{children:[\"Traverse the linked list using \",(0,n.jsx)(e.code,{children:\"nextOutEdgeId\"}),\" pointers\"]}),`\n`,(0,n.jsx)(e.li,{children:\"Track visited edges to detect cycles (data corruption)\"}),`\n`,(0,n.jsx)(e.li,{children:\"Only include active edges (skip deleted edges)\"}),`\n`,(0,n.jsxs)(e.li,{children:[\"Stop when \",(0,n.jsx)(e.code,{children:\"nextOutEdgeId\"}),\" is 0 (end of list)\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(k) where k = number of outgoing edges\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Space Complexity\"}),\": O(k) for result vector + O(k) for cycle detection\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Cycle Detection\"}),\": Prevents infinite loops on corrupted data\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Active Filtering\"}),\": Automatically excludes deleted edges\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Get Incoming Edges\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves all incoming edges to a node by traversing the incoming edge list:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Edge> RelationshipTraversal::getIncomingEdges(int64_t nodeId) const {\n    std::vector<Edge> inEdges;\n    const auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return inEdges;\n    }\n\n    const Node node = dataManager->getNode(nodeId);\n    int64_t currentEdgeId = node.getFirstInEdgeId();\n\n    // Keep track of visited edge IDs to detect cycles in the linked list.\n    std::unordered_set<int64_t> visitedEdgeIds;\n\n    while (currentEdgeId != 0) {\n        // Cycle detected in the edge linked-list. Abort traversal.\n        if (visitedEdgeIds.contains(currentEdgeId)) {\n            throw std::runtime_error(\"Cycle detected in incoming edges linked-list for node \" +\n                                     std::to_string(nodeId));\n        }\n        visitedEdgeIds.insert(currentEdgeId);\n\n        Edge edge = dataManager->getEdge(currentEdgeId);\n        if (edge.isActive()) {\n            inEdges.push_back(edge);\n        }\n        currentEdgeId = edge.getNextInEdgeId();\n    }\n    return inEdges;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\": Same as \",(0,n.jsx)(e.code,{children:\"getOutgoingEdges\"}),\", but for incoming relationships.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Get All Connected Edges\"}),`\n`,(0,n.jsx)(e.p,{children:\"Combines both outgoing and incoming edges:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Edge> RelationshipTraversal::getAllConnectedEdges(int64_t nodeId) const {\n    std::vector<Edge> outEdges = getOutgoingEdges(nodeId);\n    std::vector<Edge> inEdges = getIncomingEdges(nodeId);\n\n    // Combine the two vectors\n    outEdges.insert(outEdges.end(), inEdges.begin(), inEdges.end());\n    return outEdges;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Finding all relationships connected to a node regardless of direction.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Get Connected Target Nodes\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves all nodes reachable via outgoing edges:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Node> RelationshipTraversal::getConnectedTargetNodes(int64_t nodeId) const {\n    std::vector<Node> targetNodes;\n    std::vector<Edge> outEdges = getOutgoingEdges(nodeId);\n\n    targetNodes.reserve(outEdges.size());\n    const auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return targetNodes;\n    }\n\n    for (const auto &edge: outEdges) {\n        targetNodes.push_back(dataManager->getNode(edge.getTargetNodeId()));\n    }\n    return targetNodes;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Cypher queries like \",(0,n.jsx)(e.code,{children:\"MATCH (a)-[:KNOWS]->(b) RETURN b\"})]}),`\n`,(0,n.jsx)(e.h3,{children:\"Get Connected Source Nodes\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves all nodes that point to this node via incoming edges:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Node> RelationshipTraversal::getConnectedSourceNodes(int64_t nodeId) const {\n    std::vector<Node> sourceNodes;\n    std::vector<Edge> inEdges = getIncomingEdges(nodeId);\n\n    sourceNodes.reserve(inEdges.size());\n    const auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return sourceNodes;\n    }\n\n    for (const auto &edge: inEdges) {\n        sourceNodes.push_back(dataManager->getNode(edge.getSourceNodeId()));\n    }\n    return sourceNodes;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Cypher queries like \",(0,n.jsx)(e.code,{children:\"MATCH (a)-[:KNOWS]->(b) RETURN a\"}),\" where \",(0,n.jsx)(e.code,{children:\"b\"}),\" is fixed.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Get All Connected Nodes\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves all neighbors (both sources and targets) with deduplication:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<Node> RelationshipTraversal::getAllConnectedNodes(int64_t nodeId) const {\n    std::vector<Node> connectedNodes;\n\n    const auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return connectedNodes;\n    }\n\n    std::unordered_set<int64_t> nodeIds;\n    for (const auto &edge: getOutgoingEdges(nodeId)) {\n        int64_t targetId = edge.getTargetNodeId();\n        if (nodeIds.insert(targetId).second) {\n            connectedNodes.push_back(dataManager->getNode(targetId));\n        }\n    }\n\n    for (const auto &edge: getIncomingEdges(nodeId)) {\n        int64_t sourceId = edge.getSourceNodeId();\n        if (nodeIds.insert(sourceId).second) {\n            connectedNodes.push_back(dataManager->getNode(sourceId));\n        }\n    }\n    return connectedNodes;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Key Feature\"}),\": Uses \",(0,n.jsx)(e.code,{children:\"std::unordered_set\"}),\" to deduplicate nodes that are connected via both incoming and outgoing edges.\"]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Finding all neighbors of a node in undirected traversals.\"]}),`\n`,(0,n.jsx)(e.h2,{children:\"Edge Linking Operations\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Link Edge\"}),`\n`,(0,n.jsx)(e.p,{children:\"Inserts a new edge into the adjacency structure:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void RelationshipTraversal::linkEdge(Edge &edge) const {\n    int64_t edgeId = edge.getId();\n    int64_t sourceNodeId = edge.getSourceNodeId();\n    int64_t targetNodeId = edge.getTargetNodeId();\n\n    auto dataManager = dataManager_.lock();\n    if (!dataManager) {\n        return;\n    }\n\n    // Link to source node's outgoing list\n    Node sourceNode = dataManager->getNode(sourceNodeId);\n    int64_t firstOutEdgeId = sourceNode.getFirstOutEdgeId();\n\n    if (firstOutEdgeId == 0) {\n        // Source has no outgoing edges yet\n        sourceNode.setFirstOutEdgeId(edgeId);\n        dataManager->updateNode(sourceNode);\n    } else {\n        // Insert at head of source's outgoing list\n        Edge firstOutEdge = dataManager->getEdge(firstOutEdgeId);\n        edge.setNextOutEdgeId(firstOutEdgeId);\n        firstOutEdge.setPrevOutEdgeId(edgeId);\n\n        sourceNode.setFirstOutEdgeId(edgeId);\n\n        dataManager->updateEdge(firstOutEdge);\n        dataManager->updateNode(sourceNode);\n    }\n\n    // Link to target node's incoming list\n    Node targetNode = dataManager->getNode(targetNodeId);\n    int64_t firstInEdgeId = targetNode.getFirstInEdgeId();\n\n   