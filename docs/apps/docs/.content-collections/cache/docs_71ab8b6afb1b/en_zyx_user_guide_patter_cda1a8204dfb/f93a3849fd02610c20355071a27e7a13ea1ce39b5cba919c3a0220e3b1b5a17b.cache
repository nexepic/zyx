"var Component=(()=>{var p=Object.create;var t=Object.defineProperty;var R=Object.getOwnPropertyDescriptor;var T=Object.getOwnPropertyNames;var N=Object.getPrototypeOf,m=Object.prototype.hasOwnProperty;var A=(r,n)=>()=>(n||r((n={exports:{}}).exports,n),n.exports),E=(r,n)=>{for(var a in n)t(r,a,{get:n[a],enumerable:!0})},s=(r,n,a,c)=>{if(n&&typeof n==\"object\"||typeof n==\"function\")for(let i of T(n))!m.call(r,i)&&i!==a&&t(r,i,{get:()=>n[i],enumerable:!(c=R(n,i))||c.enumerable});return r};var P=(r,n,a)=>(a=r!=null?p(N(r)):{},s(n||!r||!r.__esModule?t(a,\"default\",{value:r,enumerable:!0}):a,r)),S=r=>s(t({},\"__esModule\",{value:!0}),r);var l=A((W,o)=>{o.exports=_jsx_runtime});var O={};E(O,{default:()=>d});var e=P(l());function h(r){let n={a:\"a\",code:\"code\",h1:\"h1\",h2:\"h2\",h3:\"h3\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...r.components};return(0,e.jsxs)(e.Fragment,{children:[(0,e.jsx)(n.h1,{children:\"Pattern Matching\"}),`\n`,(0,e.jsx)(n.p,{children:\"Pattern matching is the heart of Cypher, allowing you to express complex graph patterns and traverse relationships efficiently. This guide dives deep into pattern matching techniques.\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Pattern Fundamentals\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Node Patterns\"}),`\n`,(0,e.jsx)(n.p,{children:\"Nodes are the foundation of graph patterns:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Anonymous node\nMATCH () RETURN 1\n\n-- Named node\nMATCH (n) RETURN n\n\n-- Node with label\nMATCH (n:Person) RETURN n\n\n-- Node with multiple labels\nMATCH (n:Person:Developer) RETURN n\n\n-- Node with properties\nMATCH (n:Person {name: 'Alice'}) RETURN n\n\n-- Node with multiple properties\nMATCH (n:Person {name: 'Alice', age: 30}) RETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Relationship Patterns\"}),`\n`,(0,e.jsx)(n.p,{children:\"Relationships connect nodes in patterns:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Directed relationship\nMATCH (a)-[:KNOWS]->(b) RETURN a, b\n\n-- Undirected relationship\nMATCH (a)-[:KNOWS]-(b) RETURN a, b\n\n-- Left-directed\nMATCH (a)<-[:KNOWS]-(b) RETURN a, b\n\n-- Named relationship\nMATCH (a)-[r:KNOWS]->(b) RETURN a, r, b\n\n-- Relationship with properties\nMATCH (a)-[r:KNOWS {since: 2020}]->(b) RETURN a, r, b\n\n-- Relationship without type\nMATCH (a)-[r]->(b) RETURN a, r, b\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Complex Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Path Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Simple path\nMATCH p = (a)-[:KNOWS]->(b) RETURN p\n\n-- Multi-hop path\nMATCH p = (a)-[:KNOWS]->(b)-[:KNOWS]->(c) RETURN p\n\n-- Accessing path elements\nMATCH p = (a)-[:KNOWS]->(b)-[:KNOWS]->(c)\nRETURN nodes(p) AS nodes, relationships(p) AS rels\n\n-- Path length\nMATCH p = (a)-[:KNOWS*2..3]->(b)\nRETURN length(p) AS hops\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Variable Length Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Any length path\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*]->(b) RETURN b\n\n-- Minimum length\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*2..]->(b) RETURN b\n\n-- Maximum length\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*..3]->(b) RETURN b\n\n-- Exact range\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*2..3]->(b) RETURN b\n\n-- Unbounded (be careful!)\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*]-(b) RETURN b\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Multi-Relationship Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Relationships from same node\nMATCH (a:Person {name: 'Alice'})-[:KNOWS]->(b),\n      (a)-[:WORKS_WITH]->(c)\nRETURN b, c\n\n-- Multiple relationship types\nMATCH (a)-[:KNOWS|WORKS_WITH]->(b) RETURN a, b\n\n-- Pattern with specific relationship\nMATCH (a)-[r:KNOWS|WORKS_WITH]->(b)\nWHERE r.since > 2020\nRETURN a, r, b\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Pattern Compositions\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Conjunction Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Multiple patterns in same MATCH\nMATCH (a:Person)-[:KNOWS]->(b:Person),\n      (b)-[:WORKS_AT]->(c:Company)\nRETURN a, b, c\n\n-- Filtered conjunction\nMATCH (a:Person)-[:KNOWS]->(b:Person)\nWHERE (b)-[:WORKS_AT]->(c:Company {name: 'TechCorp'})\nRETURN a, b\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Disjunction Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Using OR in patterns\nMATCH (a:Person)\nWHERE (a)-[:KNOWS]->(:Person) OR (a)-[:WORKS_WITH]->(:Person)\nRETURN a\n\n-- Multiple relationship paths\nMATCH (a:Person)-[:KNOWS|WORKS_WITH]->(b:Person)\nRETURN a, b\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Negation Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Pattern doesn't exist\nMATCH (n:Person)\nWHERE NOT (n)-[:KNOWS]->()\nRETURN n\n\n-- Exclude specific pattern\nMATCH (n:Person)\nWHERE NOT (n)-[:KNOWS]->(:Person {name: 'Bob'})\nRETURN n\n\n-- Complex negation\nMATCH (n:Person)\nWHERE NOT (n)-[:KNOWS]->(:Person)-[:WORKS_AT]->(:Company)\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Advanced Pattern Techniques\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Pattern Comprehensions\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Collect nodes from pattern\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) | b.name] AS friend_names\n\n-- With filter\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) WHERE b.age > 30 | b.name] AS older_friends\n\n-- With transformation\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) | {name: b.name, age: b.age}] AS friend_details\n\n-- Nested pattern comprehension\nMATCH (n:Person {name: 'Alice'})\nRETURN [(n)-[:KNOWS]->(b) |\n  {name: b.name, friends: [(b)-[:KNOWS]->(c) | c.name]}\n] AS friend_network\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Pattern Existence\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Check if pattern exists\nMATCH (n:Person)\nWHERE EXISTS((n)-[:KNOWS]->(:Person))\nRETURN n\n\n-- Count relationships\nMATCH (n:Person)\nWHERE size((n)-[:KNOWS]->()) > 5\nRETURN n\n\n-- Multiple pattern checks\nMATCH (n:Person)\nWHERE EXISTS((n)-[:KNOWS]->())\n  AND EXISTS((n)-[:WORKS_AT]->())\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Optional Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Optional relationship\nMATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nRETURN n.name, coalesce(c.name, 'Unemployed') AS company\n\n-- Multiple optional patterns\nMATCH (n:Person)\nOPTIONAL MATCH (n)-[:WORKS_AT]->(c:Company)\nOPTIONAL MATCH (n)-[:LIVES_IN]->(l:Location)\nRETURN n.name, c.name, l.city\n\n-- Optional with filter\nMATCH (n:Person {name: 'Alice'})\nOPTIONAL MATCH (n)-[:KNOWS]->(b:Person)\nWHERE b.age > 30\nRETURN b\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Special Pattern Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Diamond Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Diamond: multiple paths to same node\nMATCH (a:Person {name: 'Alice'})-[:KNOWS]->(b:Person),\n      (a)-[:KNOWS]->(c:Person),\n      (b)-[:KNOWS]->(d:Person),\n      (c)-[:KNOWS]->(d)\nRETURN a, b, c, d\n\n-- Diamond detection\nMATCH (a:Person)-[:KNOWS]->(b:Person),\n      (a)-[:KNOWS]->(c:Person),\n      (b)-[:KNOWS]->(d:Person),\n      (c)-[:KNOWS]->(d)\nWHERE b <> c\nRETURN a, d\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Cycle Detection\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Detect cycles\nMATCH (a:Person)-[:KNOWS*]->(a)\nRETURN DISTINCT a\n\n-- Cycle of specific length\nMATCH (a:Person)-[:KNOWS*3]->(a)\nRETURN a\n\n-- Shortest cycle\nMATCH (a:Person)-[:KNOWS*]->(a)\nWITH a, length([p in (a)-[:KNOWS*]->(a) | p][0]) AS cycle_length\nRETURN a.name, cycle_length\nORDER BY cycle_length\nLIMIT 10\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Bipartite Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Match two node types connected\nMATCH (p:Person)-[:PURCHASED]->(p2:Product)\nRETURN p, p2\n\n-- Find nodes connected to two different sets\nMATCH (n:Person)\nWHERE (n)-[:KNOWS]->(:Person {name: 'Alice'})\n  AND (n)-[:KNOWS]->(:Person {name: 'Bob'})\nRETURN n\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Real-World Patterns\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Social Network Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Mutual friends\nMATCH (a:Person {name: 'Alice'})-[:KNOWS]->(common)<-[:KNOWS]-(b:Person {name: 'Bob'})\nRETURN common.name AS mutual_friend\n\n-- Friends of friends (not direct friends)\nMATCH (me:Person {name: 'Alice'})-[:KNOWS]->(friend)-[:KNOWS]->(fof)\nWHERE NOT (me)-[:KNOWS]->(fof) AND fof <> me\nRETURN DISTINCT fof.name\n\n-- Influence network (2-hop)\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*1..2]->(influenced)\nRETURN DISTINCT influenced.name\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Recommendation Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Collaborative filtering\nMATCH (me:Person {name: 'Alice'})-[:LIKES]->(item:Product)<-[:LIKES]-(other:Person)\nMATCH (other)-[:LIKES]->(rec:Product)\nWHERE NOT (me)-[:LIKES]->(rec)\nRETURN rec.name, COUNT(*) AS score\nORDER BY score DESC\nLIMIT 10\n\n-- Similar users\nMATCH (me:Person {name: 'Alice'})-[:HAS_INTEREST]->(i:Interest)<-[:HAS_INTEREST]-(other:Person)\nWHERE me <> other\nWITH other, COUNT(i) AS common_interests\nORDER BY common_interests DESC\nRETURN other.name, common_interests\nLIMIT 10\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Hierarchical Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Organization hierarchy\nMATCH (e:Employee)-[:WORKS_IN]->(d:Department)-[:PART_OF]->(c:Company)\nRETURN e.name, d.name, c.name\n\n-- Management chain\nMATCH p = (e:Employee {name: 'John'})-[:REPORTS_TO*]->(ceo:Person)\nWHERE NOT (ceo)-[:REPORTS_TO]->()\nRETURN [node in nodes(p) | node.name] AS management_chain\n\n-- Find all subordinates\nMATCH (manager:Person {name: 'Alice'})-[:MANAGES*]->(subordinate)\nRETURN DISTINCT subordinate.name\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Temporal Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Time-based relationships\nMATCH (p:Person)-[r:MET {date: date('2024-01-15')}]->(other)\nRETURN p, other\n\n-- Relationships in time range\nMATCH (p:Person)-[r:KNOWS]->(other)\nWHERE r.since >= 2020 AND r.since <= 2024\nRETURN p.name, other.name, r.since\n\n-- Latest relationship\nMATCH (a:Person)-[r:KNOWS]->(b:Person)\nWITH a, b, r\nORDER BY r.since DESC\nRETURN a.name, b.name, r.since\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Pattern Performance\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Efficient Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- GOOD: Start with specific node\nMATCH (n:Person {name: 'Alice'})-[:KNOWS]->(b)\nRETURN b\n\n-- AVOID: Too broad pattern\nMATCH (a)-[:KNOWS]->(b)\nRETURN a, b\n\n-- GOOD: Use labels\nMATCH (n:Person)-[:KNOWS]->(m:Person)\nRETURN n, m\n\n-- GOOD: Filter early\nMATCH (n:Person)\nWHERE n.age > 30\nMATCH (n)-[:KNOWS]->(b)\nRETURN b\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Pattern Optimization\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Use specific relationship types\nMATCH (n:Person)-[:KNOWS|FRIEND]->(b)\nRETURN b\n\n-- Limit path exploration\nMATCH (a:Person {name: 'Alice'})-[:KNOWS*..3]->(b)\nRETURN b\n\n-- Use PROFILE to analyze\nPROFILE MATCH (n:Person)-[:KNOWS]->(b)\nRETURN n, b\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Pattern Visualization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Displaying Patterns\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Return nodes and relationships\nMATCH (a:Person {name: 'Alice'})-[r:KNOWS]->(b:Person)\nRETURN a, r, b\n\n-- Return path\nMATCH p = (a:Person {name: 'Alice'})-[:KNOWS*2..3]->(b:Person)\nRETURN p\n\n-- Return custom structure\nMATCH (a:Person {name: 'Alice'})-[r:KNOWS]->(b:Person)\nRETURN {\n  from: a.name,\n  to: b.name,\n  type: type(r),\n  since: r.since\n} AS connection\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Be Specific\"}),\": Use labels and properties to make patterns selective\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Limit Depth\"}),\": Use bounded variable length paths\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use PROFILE\"}),\": Understand pattern performance characteristics\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Filter Early\"}),\": Apply WHERE clauses in the MATCH when possible\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Avoid Cartesian Products\"}),\": Connect all patterns explicitly\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use WITH\"}),\": Break complex patterns into logical steps\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Consider Indexes\"}),\": Create indexes on frequently queried properties\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Next Steps\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Learn \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/advanced-queries\",children:\"Advanced Queries\"}),\" for more complex operations\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Understand \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/transactions\",children:\"Transaction Control\"}),\" for data consistency\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Explore \",(0,e.jsx)(n.a,{href:\"/en/zyx/user-guide/batch-operations\",children:\"Batch Operations\"}),\" for bulk processing\"]}),`\n`]})]})}function d(r={}){let{wrapper:n}=r.components||{};return n?(0,e.jsx)(n,{...r,children:(0,e.jsx)(h,{...r})}):h(r)}return S(O);})();\n;return Component;"