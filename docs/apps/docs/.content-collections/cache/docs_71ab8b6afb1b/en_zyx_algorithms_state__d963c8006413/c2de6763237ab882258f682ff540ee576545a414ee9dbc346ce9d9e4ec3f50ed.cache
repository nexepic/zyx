Version();\n\n    // 2. Create new version\n    EntityState* newState = createNewVersion(tx, newData);\n    newState->version = currentVersion + 1;\n\n    // 3. Add to state chain\n    entity->addState(newState);\n\n    // 4. Track for commit\n    tx->trackModifiedEntity(entityId, currentVersion);\n\n    return true;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Commit Phase\"}),`\n`,(0,e.jsx)(n.p,{children:\"Validate no conflicts occurred:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`bool commitTransaction(Transaction* tx) {\n    // 1. Validate all modified entities\n    for (auto [entityId, readVersion] : tx->getModifiedEntities()) {\n        Entity* entity = storage->loadEntity(entityId);\n\n        // Check if version changed since we read it\n        if (entity->getVersion() != readVersion) {\n            // Conflict detected!\n            rollbackTransaction(tx);\n            return false;\n        }\n    }\n\n    // 2. No conflicts, commit all changes\n    for (auto [entityId, version] : tx->getModifiedEntities()) {\n        Entity* entity = storage->loadEntity(entityId);\n        entity->commitLatestState(tx->getId());\n    }\n\n    return true;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"State Chain Operations\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Add New Version\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void addState(Entity* entity, EntityState* newState) {\n    // 1. Link to existing chain\n    newState->previous = entity->latestState;\n\n    // 2. Update latest pointer\n    entity->latestState = newState;\n\n    // 3. Increment version\n    entity->version++;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Find Version for Transaction\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`EntityState* findVersionForTransaction(Entity* entity, Transaction* tx) {\n    EntityState* state = entity->latestState;\n    timestamp_t txStartTime = tx->getStartTime();\n\n    // Traverse back to find version visible to transaction\n    while (state != nullptr) {\n        if (state->isCommitted() && state->timestamp <= txStartTime) {\n            // This version is visible\n            return state;\n        }\n        state = state->previous;\n    }\n\n    // No suitable version found\n    return nullptr;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Prune Old Versions\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void pruneOldVersions(Entity* entity) {\n    EntityState* state = entity->latestState;\n    timestamp_t oldestActiveTx = getOldestActiveTransactionTime();\n\n    // Find oldest version still needed\n    EntityState* oldestNeeded = nullptr;\n    while (state != nullptr) {\n        if (state->timestamp >= oldestActiveTx) {\n            oldestNeeded = state;\n            break;\n        }\n        state = state->previous;\n    }\n\n    // Free older versions\n    if (oldestNeeded && oldestNeeded->previous) {\n        freeVersions(oldestNeeded->previous);\n        oldestNeeded->previous = nullptr;\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Conflict Detection\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Write-Write Conflict\"}),`\n`,(0,e.jsx)(n.p,{children:\"Two transactions modify same entity:\"}),`\n`,(0,e.jsx)(i,{chart:`sequenceDiagram\n    participant Tx1\n    participant Tx2\n    participant Entity\n\n    Tx1->>Entity: Read entity (v1)\n    Tx2->>Entity: Read entity (v1)\n    Tx1->>Entity: Write entity (v2)\n    Note over Tx1,Entity: version 1 to 2\n    Tx1->>Tx1: Commit (success)\n    Tx2->>Entity: Write entity (v3)\n    Note over Tx2,Entity: version 1 to 3\n    Tx2->>Tx2: Commit fails: version is now 2, not 1`}),`\n`,(0,e.jsx)(n.h3,{children:\"Read-Write Conflict\"}),`\n`,(0,e.jsx)(n.p,{children:\"Phantom reads prevented by MVCC:\"}),`\n`,(0,e.jsx)(i,{chart:`sequenceDiagram\n    participant Tx1\n    participant Tx2\n    participant Entity\n\n    Tx1->>Entity: Read entity (v1)\n    Tx2->>Entity: Write entity (v2)\n    Note over Tx2,Entity: version 1 \\u2192 2\n    Tx2->>Tx2: Commit (success)\n    Tx1->>Entity: Read entity (still sees v1)\n    Note over Tx1: MVCC snapshot\n    Tx1->>Tx1: Commit (success - no conflict)`}),`\n`,(0,e.jsx)(n.h2,{children:\"Version Management\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Version Numbering\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class VersionManager {\n    std::atomic<uint64_t> nextVersion;\n\npublic:\n    uint64_t getNextVersion() {\n        return nextVersion.fetch_add(1);\n    }\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Version Limits\"}),`\n`,(0,e.jsx)(n.p,{children:\"Prevent unbounded state chains:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`struct VersionConfig {\n    size_t maxVersionsPerEntity = 10;  // Soft limit\n    size_t pruneThreshold = 15;        // Hard limit\n};\n\nvoid checkVersionLimit(Entity* entity) {\n    if (entity->getVersionCount() > config.pruneThreshold) {\n        pruneOldVersions(entity);\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Characteristics\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Read Performance\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"No locks\"}),\": O(1) read access\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Version search\"}),\": O(n) where n is chain length (typically small)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Cache friendly\"}),\": Latest version cached\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Write Performance\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"No locks during write\"}),\": O(1) to add version\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Conflict detection\"}),\": O(1) per entity on commit\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.stro