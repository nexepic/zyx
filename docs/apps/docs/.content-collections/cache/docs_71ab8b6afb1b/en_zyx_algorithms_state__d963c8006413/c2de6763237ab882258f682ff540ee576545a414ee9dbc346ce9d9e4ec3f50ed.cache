\"language-cpp\",children:`bool batchConflictDetection(Transaction* tx) {\n    auto modified = tx->getModifiedEntities();\n\n    // Load all current versions in parallel\n    std::vector<uint64_t> currentVersions;\n    for (auto [entityId, _] : modified) {\n        Entity* entity = storage->loadEntity(entityId);\n        currentVersions.push_back(entity->getVersion());\n    }\n\n    // Validate all at once\n    for (size_t i = 0; i < modified.size(); ++i) {\n        auto [entityId, readVersion] = modified[i];\n        if (currentVersions[i] != readVersion) {\n            return false;  // Conflict\n        }\n    }\n\n    return true;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Retry Strategy\"}),`\n`,(0,e.jsx)(n.p,{children:\"Exponential backoff for conflicts:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`bool retryOnConflict(Transaction* tx) {\n    size_t maxRetries = 3;\n    size_t retryDelay = 100;  // ms\n\n    for (size_t attempt = 0; attempt < maxRetries; ++attempt) {\n        if (attempt > 0) {\n            std::this_thread::sleep_for(\n                std::chrono::milliseconds(retryDelay)\n            );\n            retryDelay *= 2;  // Exponential backoff\n        }\n\n        if (executeTransaction(tx)) {\n            return true;\n        }\n    }\n\n    return false;  // Failed after retries\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Keep transactions short\"}),\": Reduces conflict probability\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Minimize write set\"}),\": Fewer entities modified = fewer conflicts\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Use appropriate isolation\"}),\": Read committed for most cases\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Monitor conflict rate\"}),\": Track and optimize hot entities\"]}),`\n`,(0,e.