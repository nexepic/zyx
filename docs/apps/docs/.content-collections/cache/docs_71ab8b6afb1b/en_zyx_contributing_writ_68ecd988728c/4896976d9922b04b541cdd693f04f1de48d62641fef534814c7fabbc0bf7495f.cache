t & Assert\n    EXPECT_THROW(db_->execute(emptyQuery), ParseException);\n}\n\nTEST_F(DatabaseTest, HandleVeryLongQuery) {\n    // Arrange\n    std::string longQuery(1000000, ' ');\n\n    // Act & Assert\n    EXPECT_THROW(db_->execute(longQuery), ParseException);\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Testing Error Conditions\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`TEST_F(DatabaseTest, InvalidPropertyTypeThrowsException) {\n    // Arrange\n    std::string query = \"CREATE (n:Person {age: 'not a number'})\";\n\n    // Act & Assert\n    EXPECT_THROW(db_->execute(query), ExecutionException);\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Integration Tests\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Testing Complete Workflows\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`TEST_F(IntegrationTest, CompleteCrudWorkflow) {\n    // Create\n    db_->execute(\"CREATE (n:Person {name: 'Alice', age: 30})\");\n\n    // Read\n    auto result = db_->execute(\"MATCH (n:Person {name: 'Alice'}) RETURN n\");\n    ASSERT_FALSE(result.isEmpty());\n\n    // Update\n    db_->execute(\"MATCH (n:Person {name: 'Alice'}) SET n.age = 31\");\n\n    // Verify update\n    result = db_->execute(\"MATCH (n:Person {name: 'Alice'}) RETURN n.age\");\n    EXPECT_EQ(31, result.peek()[\"n.age\"].asInteger());\n\n    // Delete\n    db_->execute(\"MATCH (n:Person {name: 'Alice'}) DELETE n\");\n\n    // Verify deletion\n    result = db_->execute(\"MATCH (n:Person {name: 'Alice'}) RETURN n\");\n    EXPECT_TRUE(result.isEmpty());\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Testing Transaction Behavior\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`TEST_F(TransactionTest, CommitPersistsChanges) {\n    auto tx = db_->beginTransaction();\n\n    tx->execute(\"CREATE (n:Person {name: 'Bob'})\");\n\n    // Changes not visible before commit\n    auto result = db_->execute(\"MATCH (n:Person {name: 'Bob'}) RETURN n\");\n    EXPECT_TRUE(result.isEmpty());\n\n    tx->commit();\n\n    // Changes visible after commit\n    result = db_->execute(\"MATCH (n:Person {name: 'Bob'}) RETURN n\");\n    EXPECT_FALSE(result.isEmpty());\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Testing Asynchronous Code\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Testing Concurrent Operations\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`TEST_F(ConcurrencyTest, MultipleThreadsCanRead) {\n    // Create test data\n    db_->execute(\"CREATE (n:Person {name: 'Alice'})\");\n\n    const int numThreads = 10;\n    std::vector<std::thread> threads;\n\n    for (int i = 0; i < numThreads; ++i) {\n        threads.emplace_back([this]() {\n            auto result = db_->execute(\"MATCH (n:Person) RETURN count(n)\");\n            EXPECT_EQ(1, result.peek()[\"count(n)\"].asInteger());\n        });\n    }\n\n    for (auto& thread : threads) {\n        thread.join();\n    }\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Parameterized Tests\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Testing Multiple Inputs\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`class QueryParameterizedTest\n    : public ::testing::TestWithParam<std::string> {\nprotected:\n    Database* db_ = nullptr;\n    void SetUp() override {\n        db_ = Database::create(createTempPath());\n    }\n    void TearDown() override {\n        db_->close();\n    }\n};\n\nTEST_P(QueryParameterizedTest, ValidQueriesSucceed) {\n    std::string query = GetParam();\n\n    EXPECT_NO_THROW({\n        auto result = db_->execute(query);\n    });\n}\n\nINSTANTIATE_TEST_SUITE_P(\n    ValidQueries,\n    QueryParameterizedTest,\n    ::testing::Values(\n        \"CREATE (n:Person)\",\n        \"MATCH (n) RETURN n\",\n        \"MATCH (n)-[r]->(m) RETURN n, r, m\"\n    )\n);\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Test Fixtures\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Reusable Test Setup\"}),`\n`,(0,n.jsx)(e.