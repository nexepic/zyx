+2] * b[i+2] + a[i+3] * b[i+3];\n}\n\n// vs Scalar version\nfor (; i < dim; ++i) {\n    sum += a[i] * b[i];\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Benefits\"}),\":\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Reduced branching\"}),\": 4x fewer loop iterations\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Better ILP\"}),\": CPU can execute multiple operations in parallel\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Improved vectorization\"}),\": Compiler can use SIMD instructions\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"SIMD Vectorization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Modern CPUs support SIMD (Single Instruction, Multiple Data) instructions:\"}),`\n`,(0,e.jsx)(n.p,{children:`| Instruction Set | Width | Operations |\n|-----------------|-------|------------|\n| SSE | 128-bit | 4 Float32 |\n| AVX | 256-bit | 8 Float32 |\n| AVX-512 | 512-bit | 16 Float32 |`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Auto-vectorization\"}),\": The compiler automatically generates SIMD code from the unrolled loops:\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Compiler generates AVX code like this:\n__m256 diff = _mm256_sub_ps(_mm256_load_ps(a), _mm256_load_ps(b));\n__m256 sq = _mm256_mul_ps(diff, diff);\nsum = _mm256_reduce_add_ps(sq);\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Cache Optimization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Memory access patterns are optimized for CPU caches:\"}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Sequential Access\"}),\": Vectors stored contiguously\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Spatial locality\"}),\": Adjacent elements loaded together\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Prefetching\"}),\": CPU predicts and preloads data\"]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Alignment\"}),\": BFloat16 aligned to 2-byte boundaries\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:(0,e.jsx)(n.strong,{children:\"Avoids misalignment penalties\"})}),`\n`,(0,e.jsx)(n.li,{children:(0,e.jsx)(n.strong,{children:\"Enables efficient SIMD loads\"})}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Characteristics\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Benchmark Results\"}),`\n`,(0,e.jsx)(n.p,{children:\"Benchmark: Computing distances between 768-dimensional vectors\"}),`\n`,(0,e.jsx)(n.p,{children:`| Metric | Operation | Throughput | Latency |\n|--------|-----------|------------|---------|\n| L2 Sqr | Float32 vs Float32 | 50M ops/sec | 20 ns |\n| L2 Sqr | Float32 vs BFloat16 | 35M ops/sec | 28 ns |\n| L2 Sqr | BFloat16 vs BFloat16 | 30M ops/sec | 33 ns |\n| IP | Float32 vs Float32 | 55M ops/sec | 18 ns |\n| IP | Float32 vs BFloat16 | 40M ops/sec | 25 ns |`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Hardware\"}),\": x86_64, AVX2, 3.0 GHz\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"Dimension Scaling\"}),`\n`,(0,e.jsx)(n.p,{children:\"Distance computation scales linearly with dimension:\"}),`\n`,(0,e.jsx)(n.p,{children:`| Dimension | L2 Time | IP Time |\n|-----------|---------|---------|\n| 128 | 3 ns | 3 ns |\n| 256 | 6 ns | 5 ns |\n| 512 | 12 ns | 10 ns |\n| 768 | 20 ns | 18 ns |\n| 1024 | 28 ns | 25 ns |\n| 1536 | 45 ns | 40 ns |`}),`\n`,(0,e.jsx)(n.h3,{children:\"Memory Bandwidth\"}),`\n`,(0,e.jsx)(n.p,{children:\"For 1 million vectors with 768 dimensions:\"}),`\n`,(0,e.jsx)(n.p,{children:`| Format | Memory Size | Bandwidth (8GB/s) | Search Time |\n|--------|-------------|-------------------|-------------|\n| Float32 | 3.0 GB | 375 ms | 375 ms |\n| BFloat16 | 1.5 GB | 188 ms | 188 ms |\n| PQ (8D) | 96 MB | 12 ms | 12 ms |`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Key insight\"}),\": BFloat16 reduces memory bandwidth by 2x, directly impacting search performance.\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"Metric Selection Guide\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Comparison Table\"}),`\n`,(0,e.jsxs)(n.p,{children:[`| Metric | Range | Use Case | Pros | Cons |\n|--------|-------|----------|------|------|\n| `,(0,e.jsx)(n.strong,{children:\"L2\"}),` | [0, \\u221E) | Geometric distance | Intuitive, scale-sensitive | Affected by vector magnitude |\n| `,(0,e.jsx)(n.strong,{children:\"IP\"}),` | (-\\u221E, \\u221E) | Normalized vectors | Fast, equals cosine for unit vectors | Requires normalization |\n| `,(0,e.jsx)(n.strong,{children:\"Cosine\"}),\" | [-1, 1] | Angular similarity | Magnitude-independent | Slower (requires normalization) |\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"Decision Tree\"}),`\n`,(0,e.jsx)(t,{chart:`flowchart TD\n    A[Are vectors normalized?] -->|Yes| B[Use Inner Product]\n    A -->|No| C{Is magnitude important?}\n    C -->|Yes| D[Use L2 Distance]\n    C -->|No| E[Normalize vectors, then use IP]`}),`\n`,(0,e.jsx)(n.h3,{children:\"Use Case Examples\"}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"1. Image Embeddings (ResNet, ViT)\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Metric: \",(0,e.jsx)(n.strong,{children:\"L2\"}),\" or \",(0,e.jsx)(n.strong,{children:\"Cosine\"})]}),`\n`,(0,e.jsx)(n.li,{children:\"Reason: Magnitude carries information\"}),`\n`,(0,e.jsx)(n.li,{children:\"Recommendation: Normalize, use IP for speed\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"2. Word Embeddings (Word2Vec, GloVe)\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Metric: \",(0,e.jsx)(n.strong,{children:\"Cosine\"}),\" (via IP with normalized vectors)\"]}),`\n`,(0,e.jsx)(n.li,{children:\"Reason: Semantic similarity is angular\"}),`\n`,(0,e.jsx)(n.li,{children:\"Recommendation: Pre-normalize, use IP\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"3. Document Embeddings (BERT, SBERT)\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Metric: \",(0,e.jsx)(n.strong,{children:\"Cosine\"})]}),`\n`,(0,e.jsx)(n.li,{children:\"Reason: Document length shouldn't affect similarity\"}),`\n`,(0,e.jsx)(n.li,{children:\"Recommendation: Normalize vectors, use IP\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"4. Recommendation Systems\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Metric: \",(0,e.jsx)(n.strong,{children:\"IP\"}),\" (for normalized user/item vectors)\"]}),`\n`,(0,e.jsx)(n.li,{children:\"Reason: Captures preference alignment\"}),`\n`,(0,e.jsx)(n.li,{children:\"Recommendation: Ensure normalization\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Integration with DiskANN\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Search Pipeline\"}),`\n`,(0,e.jsx)(n.p,{children:\"Vector metrics are used throughout the DiskANN search pipeline:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> search(\n    const std::vector<float>& query,\n    size_t k\n) {\n    // 1. Compute PQ distance table (uses L2Sqr on sub-vectors)\n    auto pqTable = quantizer_->computeDistanceTable(query);\n\n    // 2. Greedy graph search (uses fast PQ distance)\n    auto candidates = greedySearch(query, entryPoint, beamWidth, pqTable);\n\n    // 3. Re-rank with exact L2 distance (uses L2Sqr with BFloat16)\n    std::vector<std::pair<int64_t, float>> results;\n    for (auto& [nodeId, _] : candidates) {\n        float exactDist = VectorMetric::computeL2Sqr(\n            query.data(),\n            loadBFloat16Vector(nodeId),\n            dim\n        );\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. Sort and return top-k\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Hybrid Distance Computation\"}),`\n`,(0,e.jsx)(n.p,{children:\"DiskANN uses a hybrid approach:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) {\n    // Fast approximate distance using PQ\n    if (hasPQCodes(targetId) && !pqTable.empty()) {\n        return computePQDistance(pqTable, targetId);  // Very fast\n    }\n\n    // Exact distance using BFloat16 vectors\n    return VectorMetric::computeL2Sqr(\n        query.data(),\n        loadBFloat16Vector(targetId),\n        dim\n    );\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Benefits\"}),\":\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Navigation\"}),\": Fast PQ distance for graph traversal\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Accuracy\"}),\": Exact distance for final ranking\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Memory\"}),\": BFloat16 reduces memory footprint\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Integration with Product Quantization\"}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ Training\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-means clustering in PQ training uses L2 squared distance:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void trainPQ(const std::vector<std::vector<float>>& samples) {\n    for (size_t m = 0; m < numSubspaces; ++m) {\n        // For each subspace\n        for (size_t iter = 0; iter < maxIterations; ++iter) {\n            // Assign each sample to nearest centroid\n            for (const auto& sample : samples) {\n                size_t offset = m * subDim;\n                float minDist = std::numeric_limits<float>::max();\n\n                for (size_t c = 0; c < numCentroids; ++c) {\n                    float dist = VectorMetric::computeL2Sqr(\n                        sample.data() + offset,\n                        codebooks[m][c].data(),\n                        subDim\n                    );\n                    if (dist < minDist) {\n                        minDist = dist;\n                        bestCentroid = c;\n                    }\n                }\n                assignments.push_back(bestCentroid);\n            }\n\n            // Update centroids\n            updateCentroids(assignments);\n        }\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ Encoding\"}),`\n`,(0,e.jsx)(n.p,{children:\"Encoding finds the nearest centroid using L2 distance:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) const {\n    std::vector<uint8_t> codes(numSubspaces);\n\n    for (size_t m = 0; m < numSubspaces; ++m) {\n        size_t offset = m * subDim;\n        float minDist = std::numeric_limits<float>::max();\n        uint8_t bestIdx = 0;\n\n        // Find nearest centroid in this subspace\n        for (size_t c = 0; c < numCentroids; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                vec.data() + offset,\n                codebooks[m][c].data(),\n                subDim\n            );\n            if (dist < minDist) {\n                minDist = dist;\n                bestIdx = static_cast<uint8_t>(c);\n            }\n        }\n        codes[m] = bestIdx;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Distance Table Computation\"}),`\n`,(0,e.jsx)(n.p,{children:\"PQ search pre-computes a distance table using L2:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<float> computeDistanceTable(\n    const std::vector<float>& query\n) const {\n    std::vector<float> table(numSubspaces * numCentroids);\n\n    for (size_t m = 0; m < numSubspaces; ++m) {\n        size_t offset = m * subDim;\n        const float* querySub = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids; ++c) {\n            // Compute L2 distance from query to each centroid\n            table[m * numCentroids + c] = VectorMetric::computeL2Sqr(\n                querySub,\n                codebooks[m][c].data(),\n                subDim\n            );\n        }\n    }\n\n    return table;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Efficiency\"}),\": Distance table computed once per query, reused for all candidates.\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsx)(n.h3,{children:\"1. Vector Normalization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Pre-normalize vectors when using cosine similarity:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Normalize once during indexing\nvoid normalizeVector(std::vector<float>& vec) {\n    float norm = 0.0f;\n    for (float v : vec) {\n        norm += v * v;\n    }\n    norm = std::sqrt(norm);\n\n    for (float& v : vec) {\n        v /= norm;\n    }\n}\n\n// Then use fast Inner Product for all comparisons\nfloat similarity = -VectorMetric::computeIP(a, b, dim);  // Negate back\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"2. Batch Processing\"}),`\n`,(0,e.jsx)(n.p,{children:\"Process multiple distance computations in batches:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Better cache utilization\nstd::vector<float> computeBatchDistances(\n    const float* query,\n    const std::vector<const float*>& vectors,\n    size_t dim\n) {\n    std::vector<float> distances(vectors.size());\n\n    for (size_t i = 0; i < vectors.size(); ++i) {\n        distances[i] = VectorMetric::computeL2Sqr(query, vectors[i], dim);\n    }\n\n    return distances;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"3. Precision Selection\"}),`\n`,(0,e.jsx)(n.p,{children:\"Choose precision based on use case:\"}),`\n`,(0,e.jsx)(n.p,{children:`| Use Case | Storage Precision | Query Precision | Reason |\n|----------|-------------------|-----------------|--------|\n| Training | Float32 | Float32 | Maximum accuracy |\n| Indexing | BFloat16 | Float32 | Memory efficiency |\n| Search | BFloat16 | Float32 | Fast queries |\n| Re-ranking | BFloat16 | Float32 | Good accuracy |`}),`\n`,(0,e.jsx)(n.h3,{children:\"4. Aligned Allocation\"}),`\n`,(0,e.jsx)(n.p,{children:\"Align vectors for SIMD efficiency:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Allocate aligned memory\nfloat* allocateAlignedVector(size_t dim) {\n    #ifdef _MSC_VER\n        return static_cast<float*>(_aligned_malloc(dim * sizeof(float), 32));\n    #else\n        return static_cast<float*>(aligned_alloc(32, dim * sizeof(float)));\n    #endif\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Implementation Notes\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Zero-Allocation Design\"}),`\n`,(0,e.jsx)(n.p,{children:\"All metric functions are zero-allocation:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"No dynamic memory\"}),\": Uses stack-allocated variables\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"No virtual calls\"}),\": Static functions enable inlining\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"No exceptions\"}),\": Fast error handling\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Compiler Optimizations\"}),`\n`,(0,e.jsx)(n.p,{children:\"Enable compiler optimizations:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Compiler flags for optimal performance\n-O3                    // Maximum optimization\n-march=native          // Use CPU-specific instructions\n-ffast-math           // Aggressive floating-point optimizations\n-funroll-loops        // Loop unrolling\n-ftree-vectorize      // Auto-vectorization\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Portability\"}),`\n`,(0,e.jsx)(n.p,{children:\"Code is portable across platforms:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"x86_64\"}),\": SSE, AVX, AVX-512 support\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"ARM64\"}),\": NEON support\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Cross-platform\"}),\": Standard C++20\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"See Also\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/diskann\",children:\"DiskANN Algorithm\"}),\" - Graph-based vector search\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/product-quantization\",children:\"Product Quantization\"}),\" - Vector compression\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/kmeans\",children:\"K-Means Clustering\"}),\" - Clustering algorithm\"]}),`\n`]})]})}function h(i={}){let{wrapper:n}=i.components||{};return n?(0,e.jsx)(n,{...i,children:(0,e.jsx)(d,{...i})}):d(i)}function F(i,n){throw new Error(\"Expected \"+(n?\"component\":\"object\")+\" `\"+i+\"` to be defined: you likely forgot to import, pass, or provide it.\")}return M(z);})();\n;return Component;"