 i += 4) {\n        sum += a[i] * b[i] +\n               a[i + 1] * b[i + 1] +\n               a[i + 2] * b[i + 2] +\n               a[i + 3] * b[i + 3];\n    }\n\n    // Handle remaining elements\n    for (; i < dim; ++i) {\n        sum += a[i] * b[i];\n    }\n\n    return -sum;  // Negated for min-heap compatibility\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Important\"}),\": The result is \",(0,e.jsx)(n.strong,{children:\"negated\"}),\" because ZYX uses min-heaps for distance sorting. Larger inner products (more similar) should have smaller distance values.\"]}),`\n`,(0,e.jsx)(n.h4,{children:\"When to Use Inner Product\"}),`\n`,(0,e.jsx)(n.p,{children:\"Use IP when:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Vectors are \",(0,e.jsx)(n.strong,{children:\"L2-normalized\"}),\" (unit length)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"You want \",(0,e.jsx)(n.strong,{children:\"cosine similarity\"}),\" without computing norms\"]}),`\n`,(0,e.jsxs)(n.li,{children:[\"Working with \",(0,e.jsx)(n.strong,{children:\"word embeddings\"}),\" or \",(0,e.jsx)(n.strong,{children:\"neural network embeddings\"})]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Relationship to Cosine\"}),\":\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`Cosine(a,b) = IP(a,b) / (||a|| \\xD7 ||b||)\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"For normalized vectors where ||a|| = ||b|| = 1:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`Cosine(a,b) = IP(a,b)\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Cosine Similarity\"}),`\n`,(0,e.jsx)(n.p,{children:\"Cosine similarity measures the cosine of the angle between two vectors, ranging from -1 (opposite) to 1 (identical).\"}),`\n`,(0,e.jsx)(n.h4,{children:\"Mathematical Definition\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`Cosine(a,b) = IP(a,b) / (||a|| \\xD7 ||b||)\n            = \\u03A3(a\\u1D62 \\xD7 b\\u1D62) / (\\u221A\\u03A3(a\\u1D62\\