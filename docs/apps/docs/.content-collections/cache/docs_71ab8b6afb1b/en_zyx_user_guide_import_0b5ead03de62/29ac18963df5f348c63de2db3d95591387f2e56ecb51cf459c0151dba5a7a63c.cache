dren:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`// Transform data format\nLOAD CSV WITH HEADERS FROM 'file:///path/to/users.csv' AS row\nCREATE (u:User {\n  id: toInteger(row.id),\n  fullName: row.firstName + ' ' + row.lastName,\n  emailAddress: toLower(row.email),\n  birthYear: toInteger(substring(row.birthDate, 0, 4))\n})\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Enrichment During Import\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`// Add computed fields\nLOAD CSV WITH HEADERS FROM 'file:///path/to/users.csv' AS row\nCREATE (u:User {\n  id: toInteger(row.id),\n  name: row.name,\n  email: row.email,\n  age: toInteger(row.age),\n  ageGroup: CASE\n    WHEN toInteger(row.age) < 18 THEN 'Minor'\n    WHEN toInteger(row.age) < 65 THEN 'Adult'\n    ELSE 'Senior'\n  END\n})\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Backup and Restore\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Full Backup\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`// Export all data\nCALL apoc.export.csv.all('full_backup.csv', {})\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Selective Backup\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`// Backup specific data\nMATCH (u:User)\nWHERE u.active = true\nOPTIONAL MATCH (u)-[r]-(related)\nRETURN u, r, related\nCALL apoc.export.csv.query(\n  'MATCH (u:User) WHERE u.active = true RETURN u',\n  'active_users_backup.csv',\n  {}\n)\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Restore from Backup\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`// Restore data\nLOAD CSV WITH HEADERS FROM 'file:///path/to/backup.csv' AS row\nCREATE (u:User {\n  id: toInteger(row.id),\n  name: row.name,\n  email: row.email\n})\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Integration Examples\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Import from SQL Database\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"la