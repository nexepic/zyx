901F\n`,(0,i.jsx)(n.strong,{children:\"\\u7F3A\\u70B9\"}),\"\\uFF1A\\u521D\\u59CB\\u5316\\u4E0D\\u5F53\\u53EF\\u80FD\\u5BFC\\u81F4\\u6536\\u655B\\u7F13\\u6162\\u6216\\u6B21\\u4F18\\u7ED3\\u679C\"]}),`\n`,(0,i.jsx)(n.h3,{children:\"K-Means++ \\u521D\\u59CB\\u5316\"}),`\n`,(0,i.jsx)(n.p,{children:\"\\u6982\\u7387\\u6027\\u5730\\u9009\\u62E9\\u8D28\\u5FC3\\u4F7F\\u5176\\u76F8\\u8DDD\\u8F83\\u8FDC\\uFF1A\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`// \\u7B2C\\u4E00\\u4E2A\\u8D28\\u5FC3\\uFF1A\\u968F\\u673A\\u9009\\u62E9\ncentroids[0] = data[dist(rng)];\n\n// \\u540E\\u7EED\\u8D28\\u5FC3\\uFF1A\\u6982\\u7387\\u4E0E\\u8DDD\\u79BB\\u6210\\u6B63\\u6BD4\nfor (size_t i = 1; i < k; ++i) {\n    std::vector<float> distances(n);\n    float total_dist = 0.0f;\n\n    // \\u8BA1\\u7B97\\u5230\\u6700\\u8FD1\\u8D28\\u5FC3\\u7684\\u8DDD\\u79BB\n    for (size_t j = 0; j < n; ++j) {\n        float min_dist = std::numeric_limits<float>::max();\n        for (size_t c = 0; c < i; ++c) {\n            float d = VectorMetric::computeL2Sqr(\n                data[j].data(), centroids[c].data(), dim\n            );\n            min_dist = std::min(min_dist, d);\n        }\n        distances[j] = min_dist;\n        total_dist += min_dist;\n    }\n\n    // \\u6309\\u4E0E\\u8DDD\\u79BB\\u5E73\\u65B9\\u6210\\u6B63\\u6BD4\\u7684\\u6982\\u7387\\u9009\\u62E9\n    std::uniform_real_distribution<float> prob_dist(0, total_dist);\n    float threshold = prob_dist(rng);\n    float cumulative = 0.0f;\n\n    for (size_t j = 0; j < n; ++j) {\n        cumulative += distances[j];\n        if (cumulative >= threshold) {\n            centroids[i] = data[j];\n            break;\n        }\n    }\n}\n`})}),`\n`,(0,i.jsxs)(n.p,{children:[(0,i.jsx)(n.strong,{children:\"\\u4F18\\u70B9\"}),`\\uFF1A\\u521D\\u59CB\\u8D28\\u5FC3\\u5206\\u5E03\\u66F4\\u597D\\uFF0C\\u6536\\u655B\\u66F4\\u5FEB\n`,(0,i.jsx)(n.strong,{children:\"\\u7F3A\\u70B9\"}),\"\\uFF1A\\u521D\\u59CB\\u5316\\u5F00\\u9500\\u66F4\\u5927\"]}),`\n`,(0,i.jsx)(n.h2,{children:\"\\u5904\\u7406\\u7A7A\\u805A\\u7C7B\"}),`\n`,(0,i.jsx)(n.p,{children:\"\\u5F53\\u805A\\u7C7B\\u53D8\\u4E3A\\u7A7A\\uFF08\\u6CA1\\u6709\\u5206\\u914D\\u7684\\u70B9\\uFF09\\u65F6\\uFF0C\\u6709\\u51E0\\u79CD\\u7B56\\u7565\\uFF1A\"}),`\n`,(0,i.jsx)(n.h3,{children:\"1. \\u91CD\\u65B0\\u521D\\u59CB\\u5316\\u7B56\\u7565\\uFF08ZYX \\u4F7F\\u7528\\uFF09\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`if (counts[c] == 0) {\n    centroids[c] = data[dist(rng)];  // \\u65B0\\u7684\\u968F\\u673A\\u70B9\n}\n`})}),`\n`,(0,i.jsx)(n.h3,{children:\"2. \\u5206\\u5272\\u6700\\u5927\\u805A\\u7C7B\"}),`\n`,(0,i.jsx)(n.p,{children:\"\\u4ECE\\u6700\\u5927\\u7684\\u805A\\u7C7B\\u79FB\\u52A8\\u4E00\\u4E2A\\u70B9\\u5230\\u7A7A\\u805A\\u7C7B\\u3002\"}),`\n`,(0,i.jsx)(n.h3,{children:\"3. \\u5FFD\\u7565\\u7A7A\\u805A\\u7C7B\"}),`\n`,(0,i.jsx)(n.p,{children:\"\\u51CF\\u5C11\\u6709\\u6548\\u805A\\u7C7B\\u6570\\u91CF\\uFF08\\u4E0D\\u63A8\\u8350\\uFF09\\u3002\"}),`\n`,(0,i.jsx)(n.h2,{children:\"\\u5B8C\\u6574\\u5B9E\\u73B0\"}),`\n`,(0,i.jsx)(n.p,{children:\"ZYX \\u4E2D\\u4F7F\\u7528\\u7684\\u5B8C\\u6574 K-Means \\u5B9E\\u73B0\\uFF1A\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`#include <limits>\n#include <random>\n#include <vector>\n#include \"graph/vector/core/VectorMetric.hpp\"\n\nnamespace graph::vector {\n    class KMeans {\n    public:\n        static std::vector<std::vector<float>> run(\n            const std::vector<std::vector<float>>& data,\n            size_t k,\n            size_t max_iter = 15\n        ) {\n            if (data.empty())\n                return {};\n\n            size_t dim = data[0].size();\n            size_t n = data.size();\n\n            // \\u521D\\u59CB\\u5316\\u8D28\\u5FC3\n            std::vector centroids(k, std::vector<float>(dim));\n            std::vector<int> assignment(n);\n            std::mt19937 rng(42);  // \\u56FA\\u5B9A\\u79CD\\u5B50\\u4EE5\\u4FDD\\u8BC1\\u53EF\\u91CD\\u590D\\u6027\n            std::uniform_int_distribution<size_t> dist(0, n - 1);\n\n            for (size_t i = 0; i < k; ++i) {\n                centroids[i] = data[dist(rng)];\n            }\n\n            // \\u4E3B\\u8FED\\u4EE3\\u5FAA\\u73AF\n            for (size_t it = 0; it < max_iter; ++it) {\n                bool changed = false;\n                std::vector sums(k, std::vector(dim, 0.0f));\n                std::vector<size_t> counts(k, 0);\n\n                // E \\u6B65\\uFF1A\\u5C06\\u70B9\\u5206\\u914D\\u5230\\u6700\\u8FD1\\u7684\\u8D28\\u5FC3\n                for (size_t i = 0; i < n; ++i) {\n                    float min_dist = std::numeric_limits<float>::max();\n                    int best_c = 0;\n\n                    for (size_t c = 0; c < k; ++c) {\n                        float dist_val = VectorMetric::computeL2Sqr(\n                            data[i].data(),\n                            centroids[c].data(),\n                            dim\n                        );\n\n                        if (dist_val < min_dist) {\n                            min_dist = dist_val;\n                            best_c = c;\n                        }\n                    }\n\n                    if (assignment[i] != best_c)\n                        changed = true;\n                    assignment[i] = best_c;\n\n                    // \\u4E3A M \\u6B65\\u7D2F\\u52A0\n                    for (size_t d = 0; d < dim; ++d)\n                        sums[best_c][d] += data[i][d];\n                    counts[best_c]++;\n                }\n\n                // \\u68C0\\u67E5\\u6536\\u655B\n                if (!changed)\n                    break;\n\n                // M \\u6B65\\uFF1A\\u66F4\\u65B0\\u8D28\\u5FC3\n                for (size_t c = 0; c < k; ++c) {\n                    if (counts[c] > 0) {\n                        float inv_count = 1.0f / static_cast<float>(counts[c]);\n                        for (size_t d = 0; d < dim; ++d)\n                            centroids[c][d] = sums[c][d] * inv_count;\n                    } else {\n                        // \\u91CD\\u65B0\\u521D\\u59CB\\u5316\\u7A7A\\u805A\\u7C7B\n                        centroids[c] = data[dist(rng)];\n                    }\n                }\n            }\n\n            return centroids;\n        }\n    };\n} // namespace graph::vector\n`})}),`\n`,(0,i.jsx)(n.h2,{children:\"\\u65F6\\u95F4\\u548C\\u7A7A\\u95F4\\u590D\\u6742\\u5EA6\"}),`\n`,(0,i.jsx)(n.h3,{children:\"\\u65F6\\u95F4\\u590D\\u6742\\u5EA6\"}),`\n`,(0,i.jsx)(n.p,{children:(0,i.jsx)(n.strong,{children:\"\\u6BCF\\u6B21\\u8FED\\u4EE3\\uFF1A\"})}),`\n`,(0,i.jsxs)(n.ul,{children:[`\n`,(0,i.jsxs)(n.li,{children:[\"\\u5206\\u914D\\u6B65\\u9AA4\\uFF1AO(n \\xD7 k \\xD7 d)\",`\n`,(0,i.jsxs)(n.ul,{children:[`\n`,(0,i.jsx)(n.li,{children:\"n \\u4E2A\\u6570\\u636E\\u70B9\"}),`\n`,(0,i.jsx)(n.li,{children:\"k \\u4E2A\\u8D28\\u5FC3\"}),`\n`,(0,i.jsx)(n.li,{children:\"d \\u7EF4\\u5EA6\"}),`\n`]}),`\n`]}),`\n`,(0,i.jsx)(n.li,{children:\"\\u66F4\\u65B0\\u6B65\\u9AA4\\uFF1AO(n \\xD7 d)\"}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u6BCF\\u6B21\\u8FED\\u4EE3\\u603B\\u8BA1\"}),\"\\uFF1AO(n \\xD7 k \\xD7 d)\"]}),`\n`]}),`\n`,(0,i.jsx)(n.p,{children:(0,i.jsx)(n.strong,{children:\"\\u603B\\u4F53\\uFF1A\"})}),`\n`,(0,i.jsxs)(n.ul,{children:[`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u6700\\u574F\\u60C5\\u51B5\"}),\"\\uFF1AO(n \\xD7 k \\xD7 d \\xD7 I)\",`\n`,(0,i.jsxs)(n.ul,{children:[`\n`,(0,i.jsx)(n.li,{children:\"I = \\u8FED\\u4EE3\\u6B21\\u6570\\uFF08\\u901A\\u5E38 10-50\\uFF09\"}),`\n`]}),`\n`]}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u5E73\\u5747\\u60C5\\u51B5\"}),\"\\uFF1AO(n \\xD7 k \\xD7 d \\xD7 log I)\"]}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u5178\\u578B\\u60C5\\u51B5\"}),\"\\uFF1AO(n \\xD7 k \\xD7 d \\xD7 15) [\\u9ED8\\u8BA4\\u6700\\u5927\\u8FED\\u4EE3\\u6B21\\u6570]\"]}),`\n`]}),`\n`,(0,i.jsx)(n.h3,{children:\"\\u7A7A\\u95F4\\u590D\\u6742\\u5EA6\"}),`\n`,(0,i.jsxs)(n.ul,{children:[`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u8D28\\u5FC3\"}),\"\\uFF1AO(k \\xD7 d)\"]}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u5206\\u914D\"}),\"\\uFF1AO(n)\"]}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u7D2F\\u52A0\\u5668\"}),\"\\uFF1AO(k \\xD7 d)\"]}),`\n`,(0,i.jsxs)(n.li,{children:[(0,i.jsx)(n.strong,{children:\"\\u603B\\u8BA1\"}),\"\\uFF1AO(k \\xD7 d + n)\"]}),`\n`]}),`\n`,(0,i.jsx)(n.h3,{children:\"\\u590D\\u6742\\u5EA6\\u6BD4\\u8F83\"}),`\n`,(0,i.jsxs)(n.p,{children:[`| \\u7EC4\\u4EF6 | \\u7A7A\\u95F4 | \\u65F6\\u95F4\\uFF08\\u6BCF\\u6B21\\u8FED\\u4EE3\\uFF09 |\n|------|------|-----------------|\n| \\u8D28\\u5FC3 | O(k\\xD7d) | - |\n| \\u5206\\u914D | O(n) | - |\n| E \\u6B65 | - | O(n\\xD7k\\xD7d) |\n| M \\u6B65 | - | O(n\\xD7d) |\n| `,(0,i.jsx)(n.strong,{children:\"\\u603B\\u8BA1\"}),\" | \",(0,i.jsx)(n.strong,{children:\"O(n + k\\xD7d)\"}),\" | \",(0,i.jsx)(n.strong,{children:\"O(n\\xD7k\\xD7d)\"}),\" |\"]}),`\n`,(0,i.jsx)(n.h2,{children:\"\\u4E0E\\u4E58\\u79EF\\u91CF\\u5316\\u7684\\u96C6\\u6210\"}),`\n`,(0,i.jsx)(n.p,{children:\"K-Means \\u7528\\u4E8E\\u8BAD\\u7EC3\\u4E58\\u79EF\\u91CF\\u5316\\u4E2D\\u7684\\u7801\\u672C\\uFF1A\"}),`\n`,(0,i.jsx)(n.h3,{children:\"\\u7801\\u672C\\u8BAD\\u7EC3\\u8FC7\\u7A0B\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`// \\u5C06\\u5411\\u91CF\\u5206\\u5272\\u4E3A\\u5B50\\u5411\\u91CF\nsize_t num_subspaces = 8;\nsize_t sub_dim = dim / num_subspaces;\n\n// \\u4E3A\\u6BCF\\u4E2A\\u5B50\\u7A7A\\u95F4\\u8BAD\\u7EC3\\u7801\\u672C\nfor (size_t s = 0; s < num_subspaces; ++s) {\n    // \\u63D0\\u53D6\\u5B50\\u5411\\u91CF\n    std::vector<std::vector<float>> sub_data(n, std::vector<float>(sub_dim));\n    for (size_t i = 0; i < n; ++i) {\n        std::copy(\n            data[i].begin() + s * sub_dim,\n            data[i].begin() + (s + 1) * sub_dim,\n            sub_data[i].begin()\n        );\n    }\n\n    // \\u8FD0\\u884C K-Means \\u83B7\\u5F97\\u7801\\u672C\n    size_t k = 256;  // 256 \\u4E2A\\u7801\\u5B57\\uFF088 \\u4F4D\\uFF09\n    auto codebook = KMeans::run(sub_data, k);\n\n    // \\u5B58\\u50A8\\u8BE5\\u5B50\\u7A7A\\u95F4\\u7684\\u7801\\u672C\n    codebooks[s] = codebook;\n}\n`})}),`\n`,(0,i.jsx)(n.h3,{children:\"PQ \\u7F16\\u7801\"}),`\n`,(0,i.jsx)(n.p,{children:\"\\u6BCF\\u4E2A\\u5411\\u91CF\\u88AB\\u7F16\\u7801\\u4E3A\\u7801\\u5B57\\u7D22\\u5F15\\u5E8F\\u5217\\uFF1A\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) {\n    std::vector<uint8_t> codes(num_subspaces);\n\n    for (size_t s = 0; s < num_subspaces; ++s) {\n        // \\u5728\\u5B50\\u7A7A\\u95F4\\u4E2D\\u627E\\u5230\\u6700\\u8FD1\\u7684\\u7801\\u5B57\n        float min_dist = std::numeric_limits<float>::max();\n        uint8_t best_code = 0;\n\n        for (size_t k = 0; k < 256; ++k) {\n            float dist = VectorMetric::computeL2Sqr(\n                vec.data() + s * sub_dim,\n                codebooks[s][k].data(),\n                sub_dim\n            );\n\n            if (dist < min_dist) {\n                min_dist = dist;\n                best_code = static_cast<uint8_t>(k);\n            }\n        }\n\n        codes[s] = best_code;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,i.jsx)(n.h2,{children:\"L2 \\u8DDD\\u79BB\\u8BA1\\u7B97\"}),`\n`,(0,i.jsx)(n.p,{children:\"K-Means \\u4F7F\\u7528 L2 \\u5E73\\u65B9\\u8DDD\\u79BB\\u4EE5\\u63D0\\u9AD8\\u6548\\u7387\\uFF1A\"}),`\n`,(0,i.jsx)(n.pre,{children:(0,i.jsx)(n.code,{className:\"language-cpp\",children:`static float computeL2Sqr(const float* a, const float* b, size_t dim) {\n    float sum = 0.0f;\n    size_t i = 0;\n\n    // 4 \\u8DEF\\u5C55\\u5F00\\u4EE5\\u5B9E\\u73B0\\u5411\\u91CF\\u5316\n    for (; i + 4 <= dim; i +