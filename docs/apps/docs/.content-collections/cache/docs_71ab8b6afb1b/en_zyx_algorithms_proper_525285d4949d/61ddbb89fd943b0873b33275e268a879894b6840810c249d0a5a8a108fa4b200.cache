s property type from first inserted value\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Batch operations\"}),\": Optimized bulk insertion for efficient index building\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Concurrent access\"}),\": Thread-safe operations with shared mutex\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"State persistence\"}),\": Automatic persistence of index metadata across restarts\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Dynamic index management\"}),\": Runtime index creation, clearing, and dropping\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Architecture\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Multi-Type Index Structure\"}),`\n`,(0,n.jsx)(t,{chart:`graph TD\n    A[PropertyIndex] --> B[stringTreeManager_]\n    A --> C[intTreeManager_]\n    A --> D[doubleTreeManager_]\n    A --> E[boolTreeManager_]\n\n    B --> F[stringRoots_: age, name]\n    C --> G[intRoots_: age, score]\n    D --> H[doubleRoots_: price, rating]\n    E --> I[boolRoots_: active, verified]\n\n    F --> J[B+Tree: name \\u2192 Node IDs]\n    G --> K[B+Tree: age \\u2192 Node IDs]\n    H --> L[B+Tree: price \\u2192 Node IDs]\n    I --> M[B+Tree: active \\u2192 Node IDs]`}),`\n`,(0,n.jsx)(e.h3,{children:\"Property-Based Query Flow\"}),`\n`,(0,n.jsx)(t,{chart:`sequenceDiagram\n    participant Q as Cypher Query\n    participant P as Query Planner\n    participant E as Query Executor\n    participant PI as PropertyIndex\n    participant B as B+Tree Manager\n    participant DM as DataManager\n\n    Q->>P: MATCH (n) WHERE n.age > 25 RETURN n\n    P->>E: Plan execution\n    E->>PI: findRange(\"age\", 25, MAX)\n    PI->>PI: Check type (INTEGER)\n    PI->>B: Search intTreeManager_\n    B->>B: Traverse B+Tree for range\n    B-->>PI: Return [1, 5, 9, ...]\n    PI-->>E: Node IDs\n    E->>DM: Fetch nodes by IDs\n    DM-->>E: Node data\n    E-->>Q: Results`}),`\n`,(0,n.jsx)(e.h2,{children:\"Implementation\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Class Definition\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`class PropertyIndex {\npublic:\n    PropertyIndex(std::shared_ptr<storage::DataManager> dataManager,\n                  std::shared_ptr<storage::state::SystemStateManager> systemStateManager,\n                  uint32_t indexType,\n                  std::string baseStateKey);\n\n    // Core operations\n    void addProperty(int64_t entityId, const std::string &key, const PropertyValue &value);\n    void addPropertiesBatch(const std::vector<std::tuple<int64_t, std::string, PropertyValue>> &properties);\n    void removeProperty(int64_t entityId, const std::string &key, const PropertyValue &value);\n    std::vector<int64_t> findExactMatch(const std::string &key, const PropertyValue &value) const;\n    std::vector<int64_t> findRange(const std::string &key, double minValue, double maxValue) const;\n\n    // Index lifecycle\n    void createIndex(const std::string &key);\n    void clearIndexData(const std::string &key);\n    void clearKey(const std::string &key);\n    void dropKey(const std::string &key);\n    void clear();\n    void drop();\n    void flush() const;\n    void saveState() const;\n\n    // Status queries\n    bool isEmpty() const;\n    bool hasKeyIndexed(const std::string &key) const;\n    const std::vector<std::string> &getIndexedKeys() const;\n    PropertyType getIndexedKeyType(const std::string &key) const;\n\nprivate:\n    std::shared_ptr<storage::DataManager> dataManager_;\n    std::shared_ptr<storage::state::SystemStateManager> systemStateManager_;\n\n    // Type-specific tree managers\n    std::shared_ptr<IndexTreeManager> stringTreeManager_;\n    std::shared_ptr<IndexTreeManager> intTreeManager_;\n    std::shared_ptr<IndexTreeManager> doubleTreeManager_;\n    std::shared_ptr<IndexTreeManager> boolTreeManager_;\n\n    mutable std::shared_mutex mutex_;\n    const std::string baseStateKey_;\n\n    // Root IDs for different property types\n    std::unordered_map<std::string, int64_t> stringRoots_;\n    std::unordered_map<std::string, int64_t> intRoots_;\n    std::unordered_map<std::string, int64_t> doubleRoots_;\n    std::unordered_map<std::string, int64_t> boolRoots_;\n\n    // Type mapping for each indexed key\n    std::unordered_map<std::string, PropertyType> indexedKeyTypes_;\n    std::vector<std::string> indexedKeysList_;\n};\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Core Operations\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Initialization\"}),`\n`,(0,n.jsx)(e.p,{children:\"The property index is initialized from persistent state on startup:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::initialize() {\n    std::unique_lock lock(mutex_);\n\n    // 1. Load root maps for all types\n    deserializeRootMap();\n\n    // 2. Load key type mappings\n    deserializeKeyTypeMap();\n\n    // 3. Rebuild indexed keys list cache\n    indexedKeysList_.clear();\n    indexedKeysList_.reserve(indexedKeyTypes_.size());\n    for (const auto &key: indexedKeyTypes_ | std::views::keys) {\n        indexedKeysList_.push_back(key);\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Key Points\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Separate root maps for each property type (string, int, double, bool)\"}),`\n`,(0,n.jsx)(e.li,{children:\"Key type mapping tracks which type each property key uses\"}),`\n`,(0,n.jsx)(e.li,{children:\"Indexed keys list cache for fast enumeration\"}),`\n`,(0,n.jsx)(e.li,{children:\"All metadata persisted across restarts\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Create Index\"}),`\n`,(0,n.jsx)(e.p,{children:\"Registers a property key for indexing:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::createIndex(const std::string &key) {\n    std::unique_lock lock(mutex_);\n    if (!indexedKeyTypes_.contains(key)) {\n        indexedKeyTypes_[key] = PropertyType::UNKNOWN;\n        indexedKeysList_.push_back(key);\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Immediate registration\"}),\": Key is visible to \",(0,n.jsx)(e.code,{children:\"listIndexes()\"}),\" even before data insertion\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type inference\"}),\": Type starts as UNKNOWN, determined from first inserted value\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Idempotent\"}),\": Safe to call multiple times for same key\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"No data structures created\"}),\": B+Tree initialized only on first data insertion\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Pre-declare indexes before bulk data loading\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Add Property\"}),`\n`,(0,n.jsx)(e.p,{children:\"Adds a single property value to the index:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::addProperty(int64_t entityId, const std::string &key,\n                                const PropertyValue &value) {\n    std::unique_lock lock(mutex_);\n\n    // 1. Validate value type\n    PropertyType valueType = getPropertyType(value);\n    if (valueType == PropertyType::UNKNOWN || valueType == PropertyType::NULL_TYPE) {\n        return;\n    }\n\n    // 2. Check or register key type\n    auto it = indexedKeyTypes_.find(key);\n    if (it == indexedKeyTypes_.end()) {\n        // Auto-creation: register key with inferred type\n        indexedKeyTypes_[key] = valueType;\n    } else if (it->second == PropertyType::UNKNOWN) {\n        // Transition from UNKNOWN to concrete type\n        it->second = valueType;\n    } else if (it->second != valueType) {\n        // Type mismatch: ignore value\n        return;\n    }\n\n    // 3. Get type-specific tree manager and root map\n    auto treeManager = getTreeManagerForType(valueType);\n    auto &rootMap = getRootMapForType(valueType);\n\n    // 4. Initialize B+Tree if needed\n    if (!rootMap.contains(key)) {\n        rootMap[key] = treeManager->initialize();\n    }\n\n    // 5. Insert into B+Tree\n    rootMap[key] = treeManager->insert(rootMap[key], value, entityId);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(log n) where n is the number of unique property values\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Space Complexity\"}),\": O(1) amortized (B+Tree growth)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Auto-creation\"}),\": Automatically creates index if key not registered\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type validation\"}),\": Enforces type consistency for existing indexes\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Type Inference Rules\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsx)(e.li,{children:\"First insertion determines the type\"}),`\n`,(0,n.jsx)(e.li,{children:\"Subsequent insertions must match type\"}),`\n`,(0,n.jsx)(e.li,{children:\"Type mismatches are silently ignored\"}),`\n`,(0,n.jsx)(e.li,{children:\"NULL and UNKNOWN values are never indexed\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Batch Add Properties\"}),`\n`,(0,n.jsx)(e.p,{children:\"Optimized bulk insertion for multiple properties:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::addPropertiesBatch(\n    const std::vector<std::tuple<int64_t, std::string, PropertyValue>> &properties\n) {\n    if (properties.empty())\n        return;\n\n    std::unique_lock lock(mutex_);\n\n    // Structure: Type -> Key -> List of {Value, EntityID} pairs\n    std::map<PropertyType, std::map<std::string, std::vector<std::pair<PropertyValue, int64_t>>>> groupedBatch;\n\n    // 1. Classification & Filtering Phase\n    for (const auto &[entityId, key, value]: properties) {\n        PropertyType valueType = getPropertyType(value);\n        if (valueType == PropertyType::UNKNOWN || valueType == PropertyType::NULL_TYPE) {\n            continue;\n        }\n\n        // Check if key is registered (NO auto-creation in batch mode)\n        auto it = indexedKeyTypes_.find(key);\n        if (it == indexedKeyTypes_.end()) {\n            continue;\n        }\n\n        PropertyType registeredType = it->second;\n\n        if (registeredType == PropertyType::UNKNOWN) {\n            // First time seeing data, set the type\n            indexedKeyTypes_[key] = valueType;\n            registeredType = valueType;\n        } else if (registeredType != valueType) {\n            // Type mismatch, skip this property\n            continue;\n        }\n\n        // Add to grouped batch\n        groupedBatch[registeredType][key].emplace_back(value, entityId);\n    }\n\n    // 2. Batch Insertion Phase\n    for (auto &[type, keyMap]: groupedBatch) {\n        auto treeManager = getTreeManagerForType(type);\n        auto &rootMap = getRootMapForType(type);\n\n        if (!treeManager)\n            continue;\n\n        for (auto &[key, entries]: keyMap) {\n            if (entries.empty())\n                continue;\n\n            // Ensure root exists\n            if (!rootMap.contains(key)) {\n                rootMap[key] = treeManager->initialize();\n            }\n\n            int64_t currentRootId = rootMap[key];\n\n            // Execute batch insert on B+Tree\n            int64_t newRootId = treeManager->insertBatch(currentRootId, entries);\n\n            // Update root if tree grew\n            if (newRootId != currentRootId) {\n                rootMap[key] = newRootId;\n            }\n        }\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Optimizations\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Single lock acquisition\"}),\": Reduces contention vs individual inserts\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type-based grouping\"}),\": Minimizes tree manager switches\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Key-based grouping\"}),\": Optimizes B+Tree batch insertion\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"No auto-creation\"}),\": Prevents accidental index explosion in bulk loads\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Performance\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Throughput\"}),\": ~10x faster than individual inserts for large batches\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Memory\"}),\": Groups entries in memory before insertion\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Index building during database startup or bulk import\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Remove Property\"}),`\n`,(0,n.jsx)(e.p,{children:\"Removes a property value from the index:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::removeProperty(int64_t entityId, const std::string &key,\n                                   const PropertyValue &value) {\n    std::unique_lock lock(mutex_);\n\n    // 1. Find registered type for key\n    const auto it = indexedKeyTypes_.find(key);\n    if (it == indexedKeyTypes_.end()) {\n        return; // Key not indexed\n    }\n\n    const PropertyType registeredType = it->second;\n    const PropertyType valueType = getPropertyType(value);\n\n    // 2. Validate type match\n    if (registeredType != valueType) {\n        return;\n    }\n\n    // 3. Get type-specific structures\n    const auto treeManager = getTreeManagerForType(registeredType);\n    auto &rootMap = getRootMapForType(registeredType);\n    const auto rootIt = rootMap.find(key);\n\n    if (rootIt == rootMap.end()) {\n        return; // No root for this key\n    }\n\n    // 4. Remove from B+Tree\n    (void) treeManager->remove(rootMap.at(key), value, entityId);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(log n)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Automatic rebalancing\"}),\": B+Tree handles underflow via merge/redistribute\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type validation\"}),\": Only removes if type matches registered type\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Find Exact Match\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves entities with exact property value match:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<int64_t> PropertyIndex::findExactMatch(\n    const std::string &key,\n    const PropertyValue &value\n) const {\n    std::shared_lock lock(mutex_);\n\n    // 1. Get value type\n    const PropertyType valueType = getPropertyType(value);\n\n    // 2. Check if key is indexed with matching type\n    if (const auto it = indexedKeyTypes_.find(key);\n        it == indexedKeyTypes_.end() || it->second != valueType) {\n        return {};\n    }\n\n    // 3. Get type-specific root map\n    const auto &rootMap = getRootMapForType(valueType);\n    const auto rootIt = rootMap.find(key);\n\n    if (rootIt == rootMap.end()) {\n        return {};\n    }\n\n    // 4. Search B+Tree\n    return getTreeManagerForType(valueType)->find(rootIt->second, value);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(log n + k) where k is the number of matching entities\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Concurrency\"}),\": Shared lock allows concurrent reads\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type validation\"}),\": Returns empty if type mismatch\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Return\"}),\": Vector of entity IDs (empty if not found)\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Queries like \",(0,n.jsx)(e.code,{children:\"WHERE n.name = 'Alice'\"})]}),`\n`,(0,n.jsx)(e.h3,{children:\"Find Range\"}),`\n`,(0,n.jsx)(e.p,{children:\"Retrieves entities with property values in a numeric range:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<int64_t> PropertyIndex::findRange(\n    const std::string &key,\n    double minValue,\n    double maxValue\n) const {\n    std::shared_lock lock(mutex_);\n\n    // 1. Get key type\n    PropertyType type = getIndexedKeyType(key);\n\n    // 2. Validate numeric type\n    if (type != PropertyType::INTEGER && type != PropertyType::DOUBLE) {\n        return {};\n    }\n\n    // 3. Get type-specific root map\n    const auto &rootMap = getRootMapForType(type);\n    auto rootIt = rootMap.find(key);\n\n    if (rootIt == rootMap.end()) {\n        return {};\n    }\n\n    // 4. Convert to appropriate type\n    PropertyValue minKey, maxKey;\n    if (type == PropertyType::INTEGER) {\n        minKey = static_cast<int64_t>(std::ceil(minValue));\n        maxKey = static_cast<int64_t>(std::floor(maxValue));\n    } else {\n        minKey = minValue;\n        maxKey = maxValue;\n    }\n\n    // 5. Search B+Tree range\n    return getTreeManagerForType(type)->findRange(rootIt->second, minKey, maxKey);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(log n + k) where k is the number of entities in range\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Numeric only\"}),\": Only supports INTEGER and DOUBLE types\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type conversion\"}),\": Automatically converts doubles to integers for INTEGER indexes\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Queries like \",(0,n.jsx)(e.code,{children:\"WHERE n.age > 25 AND n.age < 65\"})]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Type System\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Property Types\"}),`\n`,(0,n.jsx)(e.p,{children:\"The property index supports four indexed property types:\"}),`\n`,(0,n.jsx)(e.p,{children:`| Type | Description | Example Values | Range Queries |\n|------|-------------|----------------|---------------|\n| STRING | Text strings | \"Alice\", \"Bob\" | No |\n| INTEGER | 64-bit integers | 25, -10, 1000 | Yes |\n| DOUBLE | Floating-point numbers | 3.14, -0.5, 1e6 | Yes |\n| BOOLEAN | True/false values | true, false | No |`}),`\n`,(0,n.jsx)(e.h3,{children:\"Type Inference\"}),`\n`,(0,n.jsx)(e.p,{children:\"Types are inferred from the first inserted value:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// First insertion determines type\npropertyIndex.addProperty(1, \"age\", PropertyValue(25));  // Type: INTEGER\npropertyIndex.addProperty(2, \"age\", PropertyValue(30));  // OK: matches INTEGER\npropertyIndex.addProperty(3, \"age\", PropertyValue(\"25\")); // Ignored: type mismatch\n\n// Explicit creation allows deferred type inference\npropertyIndex.createIndex(\"salary\");  // Type: UNKNOWN\npropertyIndex.addProperty(1, \"salary\", PropertyValue(50000.50));  // Type: DOUBLE\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Type Validation\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Type validation ensures consistency\npropertyIndex.addProperty(1, \"name\", PropertyValue(\"Alice\"));  // Type: STRING\npropertyIndex.addProperty(2, \"name\", PropertyValue(123));       // Ignored: INTEGER != STRING\npropertyIndex.addProperty(3, \"name\", PropertyValue(true));      // Ignored: BOOLEAN != STRING\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Index Lifecycle\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Clear Index Data\"}),`\n`,(0,n.jsx)(e.p,{children:\"Clears B+Tree data while keeping index definition:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::clearIndexData(const std::string &key) {\n    std::unique_lock lock(mutex_);\n\n    if (!indexedKeyTypes_.contains(key)) {\n        return;\n    }\n\n    // Clear roots for all types (defense in depth)\n    auto clearRoot = [&](auto &rootMap, auto &treeManager) {\n        if (auto rootIt = rootMap.find(key); rootIt != rootMap.end()) {\n            treeManager->clear(rootIt->second);\n            rootMap.erase(rootIt);\n        }\n    };\n\n    clearRoot(stringRoots_, stringTreeManager_);\n    clearRoot(intRoots_, intTreeManager_);\n    clearRoot(doubleRoots_, doubleTreeManager_);\n    clearRoot(boolRoots_, boolTreeManager_);\n\n    // Reset type to UNKNOWN for rebuild\n    indexedKeyTypes_[key] = PropertyType::UNKNOWN;\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Index rebuilding scenarios\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Clear Key\"}),`\n`,(0,n.jsx)(e.p,{children:\"Removes both data and definition for a specific key:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::clearKey(const std::string &key) {\n    std::unique_lock lock(mutex_);\n\n    auto it = indexedKeyTypes_.find(key);\n    if (it == indexedKeyTypes_.end()) {\n        return;\n    }\n\n    PropertyType type = it->second;\n\n    // Handle UNKNOWN type (no B+Tree to clear)\n    if (type == PropertyType::UNKNOWN) {\n        indexedKeyTypes_.erase(it);\n        return;\n    }\n\n    // Clear B+Tree for concrete type\n    auto &rootMap = getRootMapForType(type);\n    auto rootIt = rootMap.find(key);\n\n    if (rootIt != rootMap.end()) {\n        auto treeManager = getTreeManagerForType(type);\n        treeManager->clear(rootIt->second);\n        rootMap.erase(rootIt);\n    }\n\n    // Remove type mapping\n    indexedKeyTypes_.erase(it);\n    std::erase(indexedKeysList_, key);\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Drop Key\"}),`\n`,(0,n.jsx)(e.p,{children:\"Completely removes a key and its persistent state:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::dropKey(const std::string &key) {\n    // Clear data and definition\n    clearKey(key);\n\n    // Remove persistent state if maps are empty\n    if (stringRoots_.empty()) {\n        systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_STRING_ROOTS);\n    }\n    if (intRoots_.empty()) {\n        systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_INT_ROOTS);\n    }\n    if (doubleRoots_.empty()) {\n        systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_DOUBLE_ROOTS);\n    }\n    if (boolRoots_.empty()) {\n        systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_BOOL_ROOTS);\n    }\n\n    if (indexedKeyTypes_.empty()) {\n        systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_KEY_TYPES);\n    }\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Clear All\"}),`\n`,(0,n.jsx)(e.p,{children:\"Removes all index data:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::clear() {\n    std::unique_lock lock(mutex_);\n\n    auto clearAllRoots = [&](auto &rootMap, auto &treeManager) {\n        for (const auto &rootId: rootMap | std::views::values) {\n            treeManager->clear(rootId);\n        }\n        rootMap.clear();\n    };\n\n    clearAllRoots(stringRoots_, stringTreeManager_);\n    clearAllRoots(intRoots_, intTreeManager_);\n    clearAllRoots(doubleRoots_, doubleTreeManager_);\n    clearAllRoots(boolRoots_, boolTreeManager_);\n\n    indexedKeyTypes_.clear();\n    indexedKeysList_.clear();\n}\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Drop All\"}),`\n`,(0,n.jsx)(e.p,{children:\"Completely removes the index:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::drop() {\n    clear();\n\n    // Remove all persistent state\n    systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_STRING_ROOTS);\n    systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_INT_ROOTS);\n    systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_DOUBLE_ROOTS);\n    systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_BOOL_ROOTS);\n    systemStateManager_->remove(baseStateKey_ + storage::state::keys::SUFFIX_KEY_TYPES);\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"State Persistence\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Save State\"}),`\n`,(0,n.jsx)(e.p,{children:\"Persists index metadata to disk:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::saveState() const {\n    std::shared_lock lock(mutex_);\n\n    // Save all root maps\n    serializeRootMap();\n\n    // Save key type mappings\n    serializeKeyTypeMap();\n}\n\nvoid PropertyIndex::serializeRootMap() const {\n    if (!stringRoots_.empty()) {\n        systemStateManager_->setMap(baseStateKey_ + storage::state::keys::SUFFIX_STRING_ROOTS, stringRoots_);\n    }\n    if (!intRoots_.empty()) {\n        systemStateManager_->setMap(baseStateKey_ + storage::state::keys::SUFFIX_INT_ROOTS, intRoots_);\n    }\n    if (!doubleRoots_.empty()) {\n        systemStateManager_->setMap(baseStateKey_ + storage::state::keys::SUFFIX_DOUBLE_ROOTS, doubleRoots_);\n    }\n    if (!boolRoots_.empty()) {\n        systemStateManager_->setMap(baseStateKey_ + storage::state::keys::SUFFIX_BOOL_ROOTS, boolRoots_);\n    }\n}\n\nvoid PropertyIndex::serializeKeyTypeMap() const {\n    if (!indexedKeyTypes_.empty()) {\n        std::unordered_map<std::string, int64_t> rawTypeMap;\n        for (const auto &[k, v]: indexedKeyTypes_) {\n            rawTypeMap[k] = static_cast<int64_t>(v);\n        }\n        systemStateManager_->setMap(baseStateKey_ + storage::state::keys::SUFFIX_KEY_TYPES, rawTypeMap);\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Persistence Strategy\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Only persist non-empty maps (sparse state)\"}),`\n`,(0,n.jsx)(e.li,{children:\"Type enums stored as int64_t for serialization\"}),`\n`,(0,n.jsx)(e.li,{children:\"Root IDs map property keys to B+Tree roots\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Load State\"}),`\n`,(0,n.jsx)(e.p,{children:\"Restores index metadata from disk:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void PropertyIndex::deserializeRootMap() {\n    stringRoots_ = systemStateManager_->getMap<int64_t>(baseStateKey_ + storage::state::keys::SUFFIX_STRING_ROOTS);\n    intRoots_ = systemStateManager_->getMap<int64_t>(baseStateKey_ + storage::state::keys::SUFFIX_INT_ROOTS);\n    doubleRoots_ = systemStateManager_->getMap<int64_t>(baseStateKey_ + storage::state::keys::SUFFIX_DOUBLE_ROOTS);\n    boolRoots_ = systemStateManager_->getMap<int64_t>(baseStateKey_ + storage::state::keys::SUFFIX_BOOL_ROOTS);\n}\n\nvoid PropertyIndex::deserializeKeyTypeMap() {\n    auto rawTypeMap = systemStateManager_->getMap<int64_t>(baseStateKey_ + storage::state::keys::SUFFIX_KEY_TYPES);\n    indexedKeyTypes_.clear();\n    for (const auto &[k, v]: rawTypeMap) {\n        indexedKeyTypes_[k] = static_cast<PropertyType>(v);\n    }\n}\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Concurrency Control\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Shared Mutex\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"The property index uses \",(0,n.jsx)(e.code,{children:\"std::shared_mutex\"}),\" for concurrent access:\"]}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`mutable std::shared_mutex mutex_;\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Lock Types\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Shared Lock\"}),\" (\",(0,n.jsx)(e.code,{children:\"std::shared_lock\"}),\"): Concurrent reads allowed\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Exclusive Lock\"}),\" (\",(0,n.jsx)(e.code,{children:\"std::unique_lock\"}),\"): Writes require exclusive access\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Lock Strategy\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[\"Read operations (\",(0,n.jsx)(e.code,{children:\"findExactMatch\"}),\", \",(0,n.jsx)(e.code,{children:\"findRange\"}),\", \",(0,n.jsx)(e.code,{children:\"getIndexedKeys\"}),\"): Shared lock\"]}),`\n`,(0,n.jsxs)(e.li,{children:[\"Write operations (\",(0,n.jsx)(e.code,{children:\"addProperty\"}),\", \",(0,n.jsx)(e.code,{children:\"removeProperty\"}),\", \",(0,n.jsx)(e.code,{children:\"addPropertiesBatch\"}),\"): Exclusive lock\"]}),`\n`,(0,n.jsxs)(e.li,{children:[\"State queries (\",(0,n.jsx)(e.code,{children:\"isEmpty\"}),\", \",(0,n.jsx)(e.code,{children:\"hasKeyIndexed\"}),\", \",(0,n.jsx)(e.code,{children:\"getIndexedKeyType\"}),\"): Shared lock\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Performance Implications\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"High read concurrency\"}),\": Multiple threads can query simultaneously\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Write serialization\"}),\": Only one writer at a time\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Fair scheduling\"}),\": No reader-writer starvation\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Fine-grained locking\"}),\": Separate locks per PropertyIndex instance\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Integration with Cypher Query\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Query Planning\"}),`\n`,(0,n.jsx)(e.p,{children:\"The query planner uses property indexes for optimization:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`-- Exact match query\nMATCH (n) WHERE n.name = 'Alice' RETURN n;\n\n-- Planner optimization\n1. Check if property index exists for \"name\"\n2. If exists: Use PropertyIndex.findExactMatch(\"name\", \"Alice\")\n3. If not: Full node scan with property filter\n`})}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`-- Range query\nMATCH (n) WHERE n.age > 25 AND n.age < 65 RETURN n;\n\n-- Planner optimization\n1. Check if property index exists for \"age\"\n2. If exists and type is numeric: Use PropertyIndex.findRange(\"age\", 25, 65)\n3. If not: Full node scan with property filter\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Query Execution\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Pseudo-code for property-based query execution\nstd::vector<Node> executePropertyFilter(\n    const std::string &key,\n    const PropertyValue &value\n) {\n    // Use property index if available\n    if (indexManager->hasPropertyIndex(\"Node\", key)) {\n        auto entityIds = propertyIndex.findExactMatch(key, value);\n        return fetchNodesByIds(entityIds);\n    }\n\n    // Fallback to full scan\n    return fullScanWithPropertyFilter(key, value);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Performance Comparison\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"With Index\"}),\": O(log n + k) where k = matching entities\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Without Index\"}),\": O(N) where N = total entities\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Performance Characteristics\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Time Complexity\"}),`\n`,(0,n.jsx)(e.p,{children:`| Operation | Average Case | Worst Case |\n|-----------|-------------|------------|\n| createIndex | O(1) | O(1) |\n| addProperty | O(log n) | O(log n) |\n| addPropertiesBatch | O(m log n) | O(m log n) |\n| removeProperty | O(log n) | O(log n) |\n| findExactMatch | O(log n + k) | O(log n + k) |\n| findRange | O(log n + k) | O(log n + k) |\n| clearKey | O(1) | O(1) |\n| dropKey | O(1) | O(1) |`}),`\n`,(0,n.jsx)(e.p,{children:\"Where:\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"n = number of unique property values for a key\"}),`\n`,(0,n.jsx)(e.li,{children:\"m = number of properties in batch\"}),`\n`,(0,n.jsx)(e.li,{children:\"k = number of entities matching the query\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Space Complexity\"}),`\n`,(0,n.jsx)(e.p,{children:`| Component | Space | Description |\n|-----------|-------|-------------|\n| B+Tree Nodes (per key) | O(n \\xD7 b) | n values, b = branch factor |\n| Root Maps | O(k) | k = number of indexed keys |\n| Type Map | O(k) | k = number of indexed keys |\n| Key List | O(k) | Cached key list |`}),`\n`,(0,n.jsxs)(e.p,{children:[\"Total: \",(0,n.jsx)(e.strong,{children:\"O(N)\"}),\" where N = total number of property-value-entity associations\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Memory Overhead\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{children:`For 1 million nodes with 5 indexed properties each:\n\nB+Tree Structures (per property key):\n- Internal nodes: ~100 nodes \\xD7 256 bytes = 25.6 KB\n- Leaf nodes: ~500 nodes \\xD7 256 bytes = 128 KB\n- Entity ID references: 1M \\xD7 8 bytes = 8 MB\n\nTotal per property key: ~8.15 MB\nTotal for 5 properties: ~40.75 MB\nOverhead per property-value-entity: ~8 bytes\n\nState Metadata:\n- Root maps (4 types): ~1 KB\n- Type map: ~500 bytes\n- Key list: ~500 bytes\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Multi-Key Indexing\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Multiple Properties Per Entity\"}),`\n`,(0,n.jsx)(e.p,{children:\"Entities can have multiple indexed properties:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Entity with multiple indexed properties\npropertyIndex.addProperty(1, \"name\", PropertyValue(\"Alice\"));\npropertyIndex.addProperty(1, \"age\", PropertyValue(30));\npropertyIndex.addProperty(1, \"active\", PropertyValue(true));\n\n// Query by any property\nauto alice = propertyIndex.findExactMatch(\"name\", PropertyValue(\"Alice\"));\nauto thirty = propertyIndex.findExactMatch(\"age\", PropertyValue(30));\nauto active = propertyIndex.findExactMatch(\"active\", PropertyValue(true));\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Each property key maintains independent B+Tree\"}),`\n`,(0,n.jsx)(e.li,{children:\"No cross-property indexes (no compound indexes)\"}),`\n`,(0,n.jsx)(e.li,{children:\"Multiple queries can be combined via intersection\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Type-Specific Indexes\"}),`\n`,(0,n.jsx)(e.p,{children:\"Each property type has dedicated B+Tree structures:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// String property\npropertyIndex.addProperty(1, \"name\", PropertyValue(\"Alice\"));\n// Uses: stringTreeManager_, stored in stringRoots_[\"name\"]\n\n// Integer property\npropertyIndex.addProperty(1, \"age\", PropertyValue(30));\n// Uses: intTreeManager_, stored in intRoots_[\"age\"]\n\n// Double property\npropertyIndex.addProperty(1, \"salary\", PropertyValue(50000.50));\n// Uses: doubleTreeManager_, stored in doubleRoots_[\"salary\"]\n\n// Boolean property\npropertyIndex.addProperty(1, \"active\", PropertyValue(true));\n// Uses: boolTreeManager_, stored in boolRoots_[\"active\"]\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Benefits\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type safety\"}),\": Prevents type mixing in indexes\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Optimization\"}),\": Each B+Tree optimized for its type\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Range queries\"}),\": Only numeric types support range queries\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Usage Examples\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Basic Operations\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Create property index\nPropertyIndex propertyIndex(dataManager, systemStateManager,\n                            IndexTypes::NODE_PROPERTY_TYPE,\n                            StateKeys::NODE_PROPERTY_ROOT);\n\n// Add properties\npropertyIndex.addProperty(1, \"name\", PropertyValue(\"Alice\"));\npropertyIndex.addProperty(2, \"name\", PropertyValue(\"Bob\"));\npropertyIndex.addProperty(1, \"age\", PropertyValue(30));\npropertyIndex.addProperty(2, \"age\", PropertyValue(25));\n\n// Find exact matches\nauto alice = propertyIndex.findExactMatch(\"name\", PropertyValue(\"Alice\"));\nauto thirty = propertyIndex.findExactMatch(\"age\", PropertyValue(30));\n\n// Find range (numeric only)\nauto adults = propertyIndex.findRange(\"age\", 18.0, 65.0);\n\n// Remove property\npropertyIndex.removeProperty(1, \"name\", PropertyValue(\"Alice\"));\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Batch Import\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Prepare batch data\nstd::vector<std::tuple<int64_t, std::string, PropertyValue>> properties;\n\nproperties.emplace_back(1, \"name\", PropertyValue(\"Alice\"));\nproperties.emplace_back(1, \"age\", PropertyValue(30));\nproperties.emplace_back(2, \"name\", PropertyValue(\"Bob\"));\nproperties.emplace_back(2, \"age\", PropertyValue(25));\nproperties.emplace_back(3, \"name\", PropertyValue(\"Charlie\"));\nproperties.emplace_back(3, \"age\", PropertyValue(35));\n\n// Create indexes first\npropertyIndex.createIndex(\"name\");\npropertyIndex.createIndex(\"age\");\n\n// Batch insert for performance\npropertyIndex.addPropertiesBatch(properties);\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Index Management\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Create index explicitly\npropertyIndex.createIndex(\"email\");\n\n// Check if key is indexed\nif (propertyIndex.hasKeyIndexed(\"email\")) {\n    std::cout << \"Email is indexed\" << std::endl;\n}\n\n// Get indexed keys\nauto keys = propertyIndex.getIndexedKeys();\nfor (const auto &key : keys) {\n    PropertyType type = propertyIndex.getIndexedKeyType(key);\n    std::cout << key << \" (\" << propertyTypeToString(type) << \")\" << std::endl;\n}\n\n// Clear index data (keep definition)\npropertyIndex.clearIndexData(\"email\");\n\n// Drop specific key\npropertyIndex.dropKey(\"email\");\n\n// Clear all indexes\npropertyIndex.clear();\n\n// Drop all indexes\npropertyIndex.drop();\n\n// Persist state\npropertyIndex.flush();\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Type Inference\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Type is inferred from first insertion\npropertyIndex.addProperty(1, \"score\", PropertyValue(100));\n// \"score\" is now INTEGER type\n\n// Subsequent insertions must match type\npropertyIndex.addProperty(2, \"score\", PropertyValue(200));  // OK\npropertyIndex.addProperty(3, \"score\", PropertyValue(\"100\")); // Ignored: type mismatch\n\n// Explicit creation defers type inference\npropertyIndex.createIndex(\"rating\");  // Type: UNKNOWN\npropertyIndex.addProperty(1, \"rating\", PropertyValue(4.5));  // Type: DOUBLE\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Best Practices\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Explicit Index Creation\"}),\": Use \",(0,n.jsx)(e.code,{children:\"createIndex()\"}),\" before bulk loads for predictable behavior\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Batch Operations\"}),\": Use \",(0,n.jsx)(e.code,{children:\"addPropertiesBatch()\"}),\" for bulk data loading\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type Consistency\"}),\": Ensure property values have consistent types across entities\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Selective Indexing\"}),\": Only index frequently queried properties\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Numeric for Ranges\"}),\": Use numeric types (INTEGER, DOUBLE) for range queries\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Monitor State\"}),\": Check \",(0,n.jsx)(e.code,{children:\"hasKeyIndexed()\"}),\" and \",(0,n.jsx)(e.code,{children:\"getIndexedKeyType()\"}),\" status\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Persist Regularly\"}),\": Call \",(0,n.jsx)(e.code,{children:\"flush()\"}),\" after critical operations\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Cleanup\"}),\": Use \",(0,n.jsx)(e.code,{children:\"dropKey()\"}),\" when index is no longer needed\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Limitations\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"No Compound Indexes\"}),\": Each property indexed independently (no multi-column indexes)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"No Partial Matches\"}),\": String prope