e: 'Bob'})\n\n-- Create multiple relationships\nCREATE (a:Person {name: 'Alice'})\nCREATE (a)-[:KNOWS]->(b:Person {name: 'Bob'})\nCREATE (a)-[:KNOWS]->(c:Person {name: 'Charlie'})\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"MERGE\"}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.code,{children:\"MERGE\"}),\" ensures that a pattern exists - creates it if it doesn't, matches it if it does:\"]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Create if not exists\nMERGE (n:Person {name: 'Alice'})\n\n-- MERGE with ON CREATE\nMERGE (n:Person {name: 'Alice'})\nON CREATE SET n.created = timestamp()\n\n-- MERGE with ON MATCH\nMERGE (n:Person {name: 'Alice'})\nON MATCH SET n.lastSeen = timestamp()\n\n-- MERGE with both\nMERGE (n:Person {name: 'Alice'})\nON CREATE SET n.created = timestamp()\nON MATCH SET n.lastSeen = timestamp()\n\n-- Create relationship if nodes exist\nMERGE (a:Person {name: 'Alice'})\nMERGE (b:Person {name: 'Bob'})\nMERGE (a)-[r:KNOWS]->(b)\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"SET and REMOVE\"}),`\n`,(0,e.jsx)(n.p,{children:\"Update properties:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Set properties\nMATCH (n:Person {name: 'Alice'})\nSET n.age = 31\n\n-- Set multiple properties\nMATCH (n:Person {name: 'Alice'})\nSET n.age = 31, n.city = 'San Francisco'\n\n-- Remove properties\nMATCH (n:Person {name: 'Alice'})\nREMOVE n.age\n\n-- Add labels\nMATCH (n:Person {name: 'Alice'})\nSET n:Developer\n\n-- Remove labels\nMATCH (n:Person {name: 'Alice'})\nREMOVE n:Developer\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"DELETE\"}),`\n`,(0,e.jsx)(n.p,{children:\"Remove nodes and relationships:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cypher\",children:`-- Delete relationships\nMATCH (a:Person {name: 'Alice'})-[r:KNOWS]->(b:Person)\nDELETE r\n\n-- Delete node (must have no relationships)\nMATCH (n:Person {name: 'Bob'})\nDELETE n\n\n-- Delete node and con