6Vector(nodeId),\n            dim\n        );\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. \\u6392\\u5E8F\\u5E76\\u8FD4\\u56DE top-k\n    std::sort(results.begin(), results.end(), [](auto& a, auto& b) {\n        return a.second < b.second;\n    });\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u6DF7\\u5408\\u8DDD\\u79BB\\u8BA1\\u7B97\"}),`\n`,(0,e.jsx)(n.p,{children:\"DiskANN \\u4F7F\\u7528\\u6DF7\\u5408\\u65B9\\u6CD5\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) {\n    // \\u4F7F\\u7528 PQ \\u7684\\u5FEB\\u901F\\u8FD1\\u4F3C\\u8DDD\\u79BB\n    if (hasPQCodes(targetId) && !pqTable.empty()) {\n        return computePQDistance(pqTable, targetId);  // \\u975E\\u5E38\\u5FEB\n    }\n\n    // \\u4F7F\\u7528 BFloat16 \\u5411\\u91CF\\u7684\\u7CBE\\u786E\\u8DDD\\u79BB\n    return VectorMetric::computeL2Sqr(\n        query.data(),\n        loadBFloat16Vector(targetId),\n        dim\n    );\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u4F18\\u52BF\"}),\"\\uFF1A\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u5BFC\\u822A\"}),\"\\uFF1A\\u5FEB\\u901F PQ \\u8DDD\\u79BB\\u7528\\u4E8E\\u56FE\\u904D\\u5386\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u51C6\\u786E\\u6027\"}),\"\\uFF1A\\u7CBE\\u786E\\u8DDD\\u79BB\\u7528\\u4E8E\\u6700\\u7EC8\\u6392\\u5E8F\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"\\u5185\\u5B58\"}),\"\\uFF1ABFloat16 \\u51CF\\u5C11\\u5185\\u5B58\\u5360\\u7528\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u4E0E\\u4E58\\u79EF\\u91CF\\u5316\\u96C6\\u6210\"}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ \\u8BAD\\u7EC3\"}),`\n`,(0,e.jsx)(n.p,{children:\"PQ \\u8BAD\\u7EC3\\u4E2D\\u7684 K-means \\u805A\\u7C7B\\u4F7