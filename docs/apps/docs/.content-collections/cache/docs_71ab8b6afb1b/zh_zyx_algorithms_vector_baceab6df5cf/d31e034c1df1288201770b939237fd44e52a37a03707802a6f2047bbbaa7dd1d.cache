s; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                vec.data() + offset,\n                codebooks[m][c].data(),\n                subDim\n            );\n            if (dist < minDist) {\n                minDist = dist;\n                bestIdx = static_cast<uint8_t>(c);\n            }\n        }\n        codes[m] = bestIdx;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u8DDD\\u79BB\\u8868\\u8BA1\\u7B97\"}),`\n`,(0,e.jsx)(n.p,{children:\"PQ \\u641C\\u7D22\\u4F7F\\u7528 L2 \\u9884\\u8BA1\\u7B97\\u8DDD\\u79BB\\u8868\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<float> computeDistanceTable(\n    const std::vector<float>& query\n) const {\n    std::vector<float> table(numSubspaces * numCentroids);\n\n    for (size_t m = 0; m < numSubspaces; ++m) {\n        size_t offset = m * subDim;\n        const float* querySub = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids; ++c) {\n            // \\u8BA1\\u7B97\\u4ECE\\u67E5\\u8BE2\\u5230\\u6BCF\\u4E2A\\u8D28\\u5FC3\\u7684 L2 \\u8DDD\\u79BB\n            table[m * numCentroids + c] = VectorMetric::computeL2Sqr(\n                querySub,\n                codebooks[m][c].data(),\n                subDim\n            );\n        }\n    }\n\n    return table;\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"\\u6548\\u7387\"}),\"\\uFF1A\\u6BCF\\u4E2A\\u67E5\\u8BE2\\u8BA1\\u7B97\\u4E00\\u6B21\\u8DDD\\u79BB\\u8868\\uFF0C\\u6240\\u6709\\u5019\\u9009\\u8005\\u91CD\\u7528\\u3002\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"\\u6700\\u4F73\\u5B9E\\u8DF5\"}),`\n`,(0,e.jsx)(n.h3,{children:\"1. \\u5411\\u91CF\\u5F52\\u4E00\\u5316\"}),`\n`,(0,e.jsx)(n.p,{children:\"\\u4F7F\\u7528\\u4F59\\u5F26\\u76F8\\u4F3C\\u6027\\u65F6\\u9884\\u5148\\u5F52\\u4E00\\u5316\\u5411\\u91CF\\uFF1A\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// \\u5728\\u7D22\\u5F15\\u6