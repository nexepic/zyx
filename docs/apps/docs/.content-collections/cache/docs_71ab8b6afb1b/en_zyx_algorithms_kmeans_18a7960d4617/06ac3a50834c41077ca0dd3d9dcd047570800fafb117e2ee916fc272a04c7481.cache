"var Component=(()=>{var u=Object.create;var c=Object.defineProperty;var m=Object.getOwnPropertyDescriptor;var p=Object.getOwnPropertyNames;var g=Object.getPrototypeOf,f=Object.prototype.hasOwnProperty;var _=(i,n)=>()=>(n||i((n={exports:{}}).exports,n),n.exports),b=(i,n)=>{for(var t in n)c(i,t,{get:n[t],enumerable:!0})},s=(i,n,t,o)=>{if(n&&typeof n==\"object\"||typeof n==\"function\")for(let r of p(n))!f.call(i,r)&&r!==t&&c(i,r,{get:()=>n[r],enumerable:!(o=m(n,r))||o.enumerable});return i};var v=(i,n,t)=>(t=i!=null?u(g(i)):{},s(n||!i||!i.__esModule?c(t,\"default\",{value:i,enumerable:!0}):t,i)),z=i=>s(c({},\"__esModule\",{value:!0}),i);var l=_((M,d)=>{d.exports=_jsx_runtime});var y={};b(y,{default:()=>h});var e=v(l());function a(i){let n={a:\"a\",code:\"code\",h1:\"h1\",h2:\"h2\",h3:\"h3\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...i.components},{Mermaid:t}=n;return t||k(\"Mermaid\",!0),(0,e.jsxs)(e.Fragment,{children:[(0,e.jsx)(n.h1,{children:\"K-Means Clustering Algorithm\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means is a fundamental unsupervised machine learning algorithm used for clustering data points into groups based on similarity. In ZYX, K-Means is specifically used for training Product Quantization (PQ) codebooks, which are essential for efficient vector similarity search and compression.\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Overview\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means partitions a set of n data points into k clusters, where each data point belongs to the cluster with the nearest mean (centroid). The algorithm iteratively refines cluster assignments to minimize the within-cluster sum of squares (WCSS), also known as inertia.\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Key Characteristics\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Partitioning Clustering\"}),\": Divides data into non-overlapping clusters\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Centroid-based\"}),\": Each cluster represented by its mean point\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Iterative Optimization\"}),\": Converges to local minimum through EM algorithm\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"L2 Distance\"}),\": Uses squared Euclidean distance as similarity metric\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Mathematical Foundation\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Objective Function\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means optimizes the following objective function:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`J = \\u03A3(i=1 to n) \\u03A3(j=1 to k) ||x_i - \\u03BC_j||\\xB2\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Where:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"J\"}),\" = Objective function (within-cluster sum of squares)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"n\"}),\" = Number of data points\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"k\"}),\" = Number of clusters\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"x_i\"}),\" = i-th data point\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"\\u03BC_j\"}),\" = Centroid of cluster j\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.code,{children:\"||\\xB7||\"}),\" = L2 norm (Euclidean distance)\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Convergence Properties\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Monotonic Convergence\"}),\": Objective function never increases\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Local Minimum\"}),\": Converges to local, not necessarily global, optimum\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Finite Convergence\"}),\": Guaranteed convergence in finite iterations\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Linear Convergence\"}),\": Typically converges in O(log n) iterations\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Algorithm Steps\"}),`\n`,(0,e.jsx)(n.p,{children:\"The K-Means algorithm follows an iterative Expectation-Maximization (EM) approach:\"}),`\n`,(0,e.jsx)(n.h3,{children:\"1. Initialization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Choose initial centroids from the data:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector centroids(k, std::vector<float>(dim));\nstd::mt19937 rng(42);  // Fixed seed for reproducibility\nstd::uniform_int_distribution<size_t> dist(0, n - 1);\n\nfor (size_t i = 0; i < k; ++i) {\n    centroids[i] = data[dist(rng)];  // Random selection\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"2. E-Step (Expectation)\"}),`\n`,(0,e.jsx)(n.p,{children:\"Assign each point to the nearest centroid:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`for (size_t i = 0; i < n; ++i) {\n    float min_dist = std::numeric_limits<float>::max();\n    int best_c = 0;\n\n    for (size_t c = 0; c < k; ++c) {\n        float dist_val = VectorMetric::computeL2Sqr(\n            data[i].data(),\n            centroids[c].data(),\n            dim\n        );\n\n        if (dist_val < min_dist) {\n            min_dist = dist_val;\n            best_c = c;\n        }\n    }\n    assignment[i] = best_c;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"3. M-Step (Maximization)\"}),`\n`,(0,e.jsx)(n.p,{children:\"Update centroids to be the mean of assigned points:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`for (size_t c = 0; c < k; ++c) {\n    if (counts[c] > 0) {\n        float inv_count = 1.0f / static_cast<float>(counts[c]);\n        for (size_t d = 0; d < dim; ++d) {\n            centroids[c][d] = sums[c][d] * inv_count;\n        }\n    } else {\n        // Re-initialize empty cluster\n        centroids[c] = data[dist(rng)];\n    }\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"4. Convergence Check\"}),`\n`,(0,e.jsx)(n.p,{children:\"Stop when assignments don't change or max iterations reached:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`if (!changed) {\n    break;  // Converged\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Algorithm Flowchart\"}),`\n`,(0,e.jsx)(t,{chart:`flowchart TD\n    A[Start] --> B[Initialize Centroids]\n    B --> C{Max iterations?}\n    C -->|No| D[E-Step: Assignment]\n    D --> E{Assignments changed?}\n    E -->|Yes| F[M-Step: Update]\n    E -->|No| G[Converged]\n    F --> H{Empty clusters?}\n    H -->|Yes| I[Re-initialize]\n    H -->|No| C\n    I --> C\n    C -->|Yes| G[Return Centroids]\n    G --> J[End]`}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"K-Means Algorithm Flow:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Initialize: Random selection of k centroids from data\"}),`\n`,(0,e.jsx)(n.li,{children:\"E-Step: Assign each point to nearest centroid\"}),`\n`,(0,e.jsx)(n.li,{children:\"M-Step: Recompute centroids as mean of assigned points\"}),`\n`,(0,e.jsx)(n.li,{children:\"Check for convergence or max iterations\"}),`\n`,(0,e.jsx)(n.li,{children:\"Handle empty clusters by re-initialization\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Centroid Initialization Strategies\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Random Initialization (Default)\"}),`\n`,(0,e.jsx)(n.p,{children:\"Select k random data points as initial centroids:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::uniform_int_distribution<size_t> dist(0, n - 1);\nfor (size_t i = 0; i < k; ++i) {\n    centroids[i] = data[dist(rng)];\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Pros\"}),`: Simple, fast\n`,(0,e.jsx)(n.strong,{children:\"Cons\"}),\": Poor initialization can lead to slow convergence or suboptimal results\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"K-Means++ Initialization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Probabilistically select centroids to be far apart:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// First centroid: random selection\ncentroids[0] = data[dist(rng)];\n\n// Subsequent centroids: probability proportional to distance\nfor (size_t i = 1; i < k; ++i) {\n    std::vector<float> distances(n);\n    float total_dist = 0.0f;\n\n    // Compute distance to nearest centroid\n    for (size_t j = 0; j < n; ++j) {\n        float min_dist = std::numeric_limits<float>::max();\n        for (size_t c = 0; c < i; ++c) {\n            float d = VectorMetric::computeL2Sqr(\n                data[j].data(), centroids[c].data(), dim\n            );\n            min_dist = std::min(min_dist, d);\n        }\n        distances[j] = min_dist;\n        total_dist += min_dist;\n    }\n\n    // Select with probability proportional to distance\\xB2\n    std::uniform_real_distribution<float> prob_dist(0, total_dist);\n    float threshold = prob_dist(rng);\n    float cumulative = 0.0f;\n\n    for (size_t j = 0; j < n; ++j) {\n        cumulative += distances[j];\n        if (cumulative >= threshold) {\n            centroids[i] = data[j];\n            break;\n        }\n    }\n}\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Pros\"}),`: Better spread of initial centroids, faster convergence\n`,(0,e.jsx)(n.strong,{children:\"Cons\"}),\": More expensive initialization\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"Handling Empty Clusters\"}),`\n`,(0,e.jsx)(n.p,{children:\"When a cluster becomes empty (no assigned points), several strategies exist:\"}),`\n`,(0,e.jsx)(n.h3,{children:\"1. Re-initialization Strategy (Used in ZYX)\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`if (counts[c] == 0) {\n    centroids[c] = data[dist(rng)];  // New random point\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"2. Split Largest Cluster\"}),`\n`,(0,e.jsx)(n.p,{children:\"Move a point from the largest cluster to the empty one.\"}),`\n`,(0,e.jsx)(n.h3,{children:\"3. Ignore Empty Clusters\"}),`\n`,(0,e.jsx)(n.p,{children:\"Reduce effective number of clusters (not recommended).\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Complete Implementation\"}),`\n`,(0,e.jsx)(n.p,{children:\"The complete K-Means implementation used in ZYX:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`#include <limits>\n#include <random>\n#include <vector>\n#include \"graph/vector/core/VectorMetric.hpp\"\n\nnamespace graph::vector {\n    class KMeans {\n    public:\n        static std::vector<std::vector<float>> run(\n            const std::vector<std::vector<float>>& data,\n            size_t k,\n            size_t max_iter = 15\n        ) {\n            if (data.empty())\n                return {};\n\n            size_t dim = data[0].size();\n            size_t n = data.size();\n\n            // Initialize Centroids\n            std::vector centroids(k, std::vector<float>(dim));\n            std::vector<int> assignment(n);\n            std::mt19937 rng(42);  // Fixed seed for reproducibility\n            std::uniform_int_distribution<size_t> dist(0, n - 1);\n\n            for (size_t i = 0; i < k; ++i) {\n                centroids[i] = data[dist(rng)];\n            }\n\n            // Main iteration loop\n            for (size_t it = 0; it < max_iter; ++it) {\n                bool changed = false;\n                std::vector sums(k, std::vector(dim, 0.0f));\n                std::vector<size_t> counts(k, 0);\n\n                // E-Step: Assign points to nearest centroid\n                for (size_t i = 0; i < n; ++i) {\n                    float min_dist = std::numeric_limits<float>::max();\n                    int best_c = 0;\n\n                    for (size_t c = 0; c < k; ++c) {\n                        float dist_val = VectorMetric::computeL2Sqr(\n                            data[i].data(),\n                            centroids[c].data(),\n                            dim\n                        );\n\n                        if (dist_val < min_dist) {\n                            min_dist = dist_val;\n                            best_c = c;\n                        }\n                    }\n\n                    if (assignment[i] != best_c)\n                        changed = true;\n                    assignment[i] = best_c;\n\n                    // Accumulate for M-Step\n                    for (size_t d = 0; d < dim; ++d)\n                        sums[best_c][d] += data[i][d];\n                    counts[best_c]++;\n                }\n\n                // Check convergence\n                if (!changed)\n                    break;\n\n                // M-Step: Update centroids\n                for (size_t c = 0; c < k; ++c) {\n                    if (counts[c] > 0) {\n                        float inv_count = 1.0f / static_cast<float>(counts[c]);\n                        for (size_t d = 0; d < dim; ++d)\n                            centroids[c][d] = sums[c][d] * inv_count;\n                    } else {\n                        // Re-initialize empty cluster\n                        centroids[c] = data[dist(rng)];\n                    }\n                }\n            }\n\n            return centroids;\n        }\n    };\n} // namespace graph::vector\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Time and Space Complexity\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Time Complexity\"}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Per Iteration:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Assignment step: O(n \\xD7 k \\xD7 d)\",`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"n data points\"}),`\n`,(0,e.jsx)(n.li,{children:\"k centroids\"}),`\n`,(0,e.jsx)(n.li,{children:\"d dimensions\"}),`\n`]}),`\n`]}),`\n`,(0,e.jsx)(n.li,{children:\"Update step: O(n \\xD7 d)\"}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Total per iteration\"}),\": O(n \\xD7 k \\xD7 d)\"]}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Overall:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Worst case\"}),\": O(n \\xD7 k \\xD7 d \\xD7 I)\",`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"I = number of iterations (typically 10-50)\"}),`\n`]}),`\n`]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Average case\"}),\": O(n \\xD7 k \\xD7 d \\xD7 log I)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Typical\"}),\": O(n \\xD7 k \\xD7 d \\xD7 15) [default max iterations]\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Space Complexity\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Centroids\"}),\": O(k \\xD7 d)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Assignments\"}),\": O(n)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Accumulators\"}),\": O(k \\xD7 d)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Total\"}),\": O(k \\xD7 d + n)\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Complexity Comparison\"}),`\n`,(0,e.jsxs)(n.p,{children:[`| Component | Space | Time (per iter) |\n|-----------|-------|-----------------|\n| Centroids | O(k\\xD7d) | - |\n| Assignments | O(n) | - |\n| E-Step | - | O(n\\xD7k\\xD7d) |\n| M-Step | - | O(n\\xD7d) |\n| `,(0,e.jsx)(n.strong,{children:\"Total\"}),\" | \",(0,e.jsx)(n.strong,{children:\"O(n + k\\xD7d)\"}),\" | \",(0,e.jsx)(n.strong,{children:\"O(n\\xD7k\\xD7d)\"}),\" |\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"Integration with Product Quantization\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means is used to train codebooks in Product Quantization:\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Codebook Training Process\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Split vector into sub-vectors\nsize_t num_subspaces = 8;\nsize_t sub_dim = dim / num_subspaces;\n\n// Train codebook for each subspace\nfor (size_t s = 0; s < num_subspaces; ++s) {\n    // Extract sub-vectors\n    std::vector<std::vector<float>> sub_data(n, std::vector<float>(sub_dim));\n    for (size_t i = 0; i < n; ++i) {\n        std::copy(\n            data[i].begin() + s * sub_dim,\n            data[i].begin() + (s + 1) * sub_dim,\n            sub_data[i].begin()\n        );\n    }\n\n    // Run K-Means to get codebook\n    size_t k = 256;  // 256 codewords (8 bits)\n    auto codebook = KMeans::run(sub_data, k);\n\n    // Store codebook for this subspace\n    codebooks[s] = codebook;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"PQ Encoding\"}),`\n`,(0,e.jsx)(n.p,{children:\"Each vector is encoded as a sequence of codeword indices:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) {\n    std::vector<uint8_t> codes(num_subspaces);\n\n    for (size_t s = 0; s < num_subspaces; ++s) {\n        // Find nearest codeword in subspace\n        float min_dist = std::numeric_limits<float>::max();\n        uint8_t best_code = 0;\n\n        for (size_t k = 0; k < 256; ++k) {\n            float dist = VectorMetric::computeL2Sqr(\n                vec.data() + s * sub_dim,\n                codebooks[s][k].data(),\n                sub_dim\n            );\n\n            if (dist < min_dist) {\n                min_dist = dist;\n                best_code = static_cast<uint8_t>(k);\n            }\n        }\n\n        codes[s] = best_code;\n    }\n\n    return codes;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"L2 Distance Computation\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means uses L2 squared distance for efficiency:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`static float computeL2Sqr(const float* a, const float* b, size_t dim) {\n    float sum = 0.0f;\n    size_t i = 0;\n\n    // 4-way unrolling for vectorization\n    for (; i + 4 <= dim; i += 4) {\n        float d0 = a[i] - b[i];\n        float d1 = a[i + 1] - b[i + 1];\n        float d2 = a[i + 2] - b[i + 2];\n        float d3 = a[i + 3] - b[i + 3];\n\n        sum += d0 * d0 + d1 * d1 + d2 * d2 + d3 * d3;\n    }\n\n    // Handle remaining elements\n    for (; i < dim; ++i) {\n        float d = a[i] - b[i];\n        sum += d * d;\n    }\n\n    return sum;\n}\n`})}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Why squared distance?\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Avoids expensive sqrt operation\"}),`\n`,(0,e.jsx)(n.li,{children:\"Preserves ordering (same argmin)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Faster computation\"}),`\n`,(0,e.jsx)(n.li,{children:\"Sufficient for comparison\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Configuration Parameters\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Key Parameters\"}),`\n`,(0,e.jsxs)(n.p,{children:[`| Parameter | Default | Range | Description |\n|-----------|---------|-------|-------------|\n| `,(0,e.jsx)(n.code,{children:\"k\"}),` | Required | 2-\\u221An | Number of clusters |\n| `,(0,e.jsx)(n.code,{children:\"max_iter\"}),` | 15 | 1-1000 | Maximum iterations |\n| `,(0,e.jsx)(n.code,{children:\"seed\"}),\" | 42 | Any | Random seed for initialization |\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"Parameter Selection Guidelines\"}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Choosing k:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"For PQ: k = 256 (8-bit codes)\"}),`\n`,(0,e.jsx)(n.li,{children:\"For compression: k = 16-128\"}),`\n`,(0,e.jsx)(n.li,{children:\"Elbow method: Plot WCSS vs k\"}),`\n`,(0,e.jsx)(n.li,{children:\"Silhouette analysis: Measure cluster quality\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Choosing max_iter:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Default 15 works for most cases\"}),`\n`,(0,e.jsx)(n.li,{children:\"Increase for high-dimensional data\"}),`\n`,