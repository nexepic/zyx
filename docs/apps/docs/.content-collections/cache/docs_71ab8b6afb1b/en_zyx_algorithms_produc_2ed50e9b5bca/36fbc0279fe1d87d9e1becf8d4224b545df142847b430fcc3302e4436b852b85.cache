 << \" (similarity: \"\n              << std::sqrt(-score) << \")\\\\n\";\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"See Also\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/diskann\",children:\"DiskANN Algorithm\"}),\" - Graph-based ANN search with PQ\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/kmeans\",children:\"K-Means Clustering\"}),\" - PQ training algorithm\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/vector-metrics\",children:\"Vector Metrics\"}),\" - Distance metric implementations\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.a,{href:\"/en/zyx/algorithms/compression\",children:\"Compression Algorithm\"}),\" - Lossless compression techniques\"]}),`\n`]})]})}function h(i={}){let{wrapper:n}=i.components||{};return n?(0,e.jsx)(n,{...i,children:(0,e.jsx)(l,{...i})}):l(i)}function D(i,n){throw new Error(\"Expected \"+(n?\"component\":\"object\")+\" `\"+i+\"` to be defined: you likely forgot to import, pass, or provide it.\")}return y(z);})();\n;return Component;"