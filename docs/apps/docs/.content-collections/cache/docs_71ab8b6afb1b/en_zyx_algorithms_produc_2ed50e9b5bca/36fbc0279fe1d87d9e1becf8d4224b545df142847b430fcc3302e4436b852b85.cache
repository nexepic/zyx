"var Component=(()=>{var u=Object.create;var s=Object.defineProperty;var m=Object.getOwnPropertyDescriptor;var p=Object.getOwnPropertyNames;var b=Object.getPrototypeOf,g=Object.prototype.hasOwnProperty;var f=(i,n)=>()=>(n||i((n={exports:{}}).exports,n),n.exports),_=(i,n)=>{for(var r in n)s(i,r,{get:n[r],enumerable:!0})},o=(i,n,r,c)=>{if(n&&typeof n==\"object\"||typeof n==\"function\")for(let t of p(n))!g.call(i,t)&&t!==r&&s(i,t,{get:()=>n[t],enumerable:!(c=m(n,t))||c.enumerable});return i};var v=(i,n,r)=>(r=i!=null?u(b(i)):{},o(n||!i||!i.__esModule?s(r,\"default\",{value:i,enumerable:!0}):r,i)),y=i=>o(s({},\"__esModule\",{value:!0}),i);var d=f((M,a)=>{a.exports=_jsx_runtime});var z={};_(z,{default:()=>h});var e=v(d());function l(i){let n={a:\"a\",code:\"code\",h1:\"h1\",h2:\"h2\",h3:\"h3\",h4:\"h4\",li:\"li\",ol:\"ol\",p:\"p\",pre:\"pre\",strong:\"strong\",ul:\"ul\",...i.components},{Mermaid:r}=n;return r||D(\"Mermaid\",!0),(0,e.jsxs)(e.Fragment,{children:[(0,e.jsx)(n.h1,{children:\"Product Quantization\"}),`\n`,(0,e.jsx)(n.p,{children:\"Product Quantization (PQ) is a powerful vector compression technique that enables efficient approximate nearest neighbor search in high-dimensional spaces. ZYX uses PQ to dramatically reduce memory footprint and accelerate distance computations in vector similarity search operations.\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Overview\"}),`\n`,(0,e.jsx)(n.p,{children:\"Product Quantization works by decomposing high-dimensional vectors into lower-dimensional subspaces and quantizing each subspace independently. This approach achieves:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Massive Memory Savings\"}),\": 8-32x compression ratio compared to raw vectors\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Fast Distance Computation\"}),\": Asymmetric Distance Computation (ADC) using lookup tables\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"High Accuracy\"}),\": Preserves nearest neighbor relationships with minimal quality loss\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Scalability\"}),\": Enables searching through billions of vectors with limited memory\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Key Benefits\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Memory Efficiency\"}),\": 768-dimensional vectors compressed from 3KB to ~100 bytes\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Search Speed\"}),\": Distance computation reduced from O(dim) to O(numSubspaces)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"DiskANN Integration\"}),\": Seamless integration with graph-based ANN search\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Zero-Copy Operations\"}),\": Efficient memory layout for cache-friendly access\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Mathematical Foundation\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Quantization Problem\"}),`\n`,(0,e.jsx)(n.p,{children:\"Given a high-dimensional vector space R^D, Product Quantization decomposes it into M subspaces:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`R^D = R^D1 \\xD7 R^D2 \\xD7 ... \\xD7 R^DM\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Where:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"D = total dimension (e.g., 768 for embeddings)\"}),`\n`,(0,e.jsx)(n.li,{children:\"M = number of subspaces (e.g., 96)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Di = dimension of subspace i (D/M, e.g., 8)\"}),`\n`,(0,e.jsx)(n.li,{children:\"D = \\u03A3 Di (sum of all subspace dimensions)\"}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Codebook Training\"}),`\n`,(0,e.jsx)(n.p,{children:\"For each subspace m \\u2208 [1, M], we train a codebook Cm containing K centroids:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`Cm = {c_m1, c_m2, ..., c_mK}\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Where:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"K = number of centroids per subspace (typically 256 = 2^8)\"}),`\n`,(0,e.jsx)(n.li,{children:\"c_mi \\u2208 R^Di (i-th centroid in m-th subspace)\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:\"Training uses K-Means clustering on training data:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void train(const std::vector<std::vector<float>>& trainingData) {\n    codebooks_.resize(numSubspaces_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        std::vector<std::vector<float>> subData;\n        subData.reserve(trainingData.size());\n\n        size_t offset = m * subDim_;\n\n        // Extract sub-vectors for this subspace\n        for (const auto& vec : trainingData) {\n            std::vector<float> sub(\n                vec.begin() + offset,\n                vec.begin() + offset + subDim_\n            );\n            subData.push_back(std::move(sub));\n        }\n\n        // Train K-Means on this subspace\n        codebooks_[m] = KMeans::run(subData, numCentroids_);\n    }\n    isTrained_ = true;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Encoding\"}),`\n`,(0,e.jsx)(n.p,{children:\"A vector x \\u2208 R^D is encoded into PQ codes by finding the nearest centroid in each subspace:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`encode(x) = [q_1, q_2, ..., q_M]\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Where q_m \\u2208 [0, K-1] is the index of the nearest centroid in subspace m:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`q_m = argmin_i ||x_m - c_mi||\\xB2\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"Here x_m is the sub-vector of x corresponding to subspace m:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<uint8_t> encode(const std::vector<float>& vec) const {\n    std::vector<uint8_t> codes(numSubspaces_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        float min_dist = std::numeric_limits<float>::max();\n        uint8_t best_idx = 0;\n\n        const float* subVecPtr = vec.data() + offset;\n\n        // Find nearest centroid in this subspace\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                subVecPtr,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n\n            if (dist < min_dist) {\n                min_dist = dist;\n                best_idx = static_cast<uint8_t>(c);\n            }\n        }\n        codes[m] = best_idx;\n    }\n    return codes;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Decoding\"}),`\n`,(0,e.jsx)(n.p,{children:\"Decoding reconstructs an approximate vector from PQ codes:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<float> decode(const std::vector<uint8_t>& codes) const {\n    std::vector<float> reconstructed(dim_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const auto& centroid = codebooks_[m][codes[m]];\n\n        // Copy centroid values to reconstructed vector\n        std::copy(centroid.begin(), centroid.end(),\n                  reconstructed.begin() + offset);\n    }\n\n    return reconstructed;\n}\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"The reconstructed vector x\\u0302 is:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`x\\u0302 = [c_1,q_1, c_2,q_2, ..., c_M,q_M]\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Quantization Error\"}),`\n`,(0,e.jsx)(n.p,{children:\"The quantization error for a vector x is:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`||x - x\\u0302||\\xB2 = \\u03A3 ||x_m - c_m,q_m||\\xB2\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"This error is bounded by the within-cluster variance in each subspace.\"}),`\n`,(0,e.jsx)(n.h2,{children:\"Architecture\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Codebook Structure\"}),`\n`,(0,e.jsx)(r,{chart:`graph TB\n    subgraph \"Codebooks\"\n        C1[\"Codebook 1\"]\n        C2[\"Codebook 2\"]\n        C3[\"Codebook 3\"]\n        C4[\"Codebook M\"]\n    end\n\n    subgraph \"Vector x\"\n        V1[\"Subspace 1\"]\n        V2[\"Subspace 2\"]\n        V3[\"Subspace 3\"]\n        V4[\"Subspace M\"]\n    end\n\n    subgraph \"PQ Codes\"\n        P1[\"q1 = 142\"]\n        P2[\"q2 = 87\"]\n        P3[\"q3 = 203\"]\n        P4[\"qM = 51\"]\n    end\n\n    V1 -->|\"nearest\"| P1\n    V2 -->|\"nearest\"| P2\n    V3 -->|\"nearest\"| P3\n    V4 -->|\"nearest\"| P4\n\n    C1 -.->|\"centroid\"| P1\n    C2 -.->|\"centroid\"| P2\n    C3 -.->|\"centroid\"| P3\n    C4 -.->|\"centroid\"| P4`}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Codebook Structure:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Each codebook: 256 \\xD7 8 floats (256 codewords, 8 dimensions each)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Vector: 768 dimensions total\"}),`\n`,(0,e.jsx)(n.li,{children:\"Subspaces: M subspaces, 8D each\"}),`\n`,(0,e.jsx)(n.li,{children:\"PQ Codes: 96 bytes (M \\xD7 1 byte per subspace)\"}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Memory Layout\"}),`\n`,(0,e.jsx)(n.p,{children:\"For D = 768 dimensions with M = 96 subspaces (Di = 8):\"}),`\n`,(0,e.jsx)(n.p,{children:`| Component | Memory | Formula | Example |\n|-----------|--------|---------|---------|\n| Raw vector (FP32) | 3072 bytes | D \\xD7 4 | 768 \\xD7 4 = 3072 |\n| Raw vector (BF16) | 1536 bytes | D \\xD7 2 | 768 \\xD7 2 = 1536 |\n| PQ codes | 96 bytes | M \\xD7 1 | 96 \\xD7 1 = 96 |\n| Codebooks | 786,432 bytes | M \\xD7 K \\xD7 Di \\xD7 4 | 96 \\xD7 256 \\xD7 8 \\xD7 4 |`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Compression Ratio\"}),\": 1536 / 96 = \",(0,e.jsx)(n.strong,{children:\"16\\xD7\"}),\" for BF16 vectors\"]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Amortized Cost\"}),\": For n vectors, codebook overhead per vector = 786,432 / n\"]}),`\n`,(0,e.jsx)(n.p,{children:\"For n = 1,000,000 vectors:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Total with BF16: 1,536,000,000 bytes (~1.5 GB)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Total with PQ: 96,000,000 + 786,432 = 96,786,432 bytes (~97 MB)\"}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Savings\"}),\": ~1.4 GB\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Distance Computation\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Asymmetric Distance Computation (ADC)\"}),`\n`,(0,e.jsx)(n.p,{children:\"ADC computes approximate distances between a query vector and PQ-encoded database vectors without full decoding.\"}),`\n`,(0,e.jsx)(n.h4,{children:\"Distance Table Precomputation\"}),`\n`,(0,e.jsx)(n.p,{children:\"For a query vector q, precompute distances to all centroids in all subspaces:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<float> computeDistanceTable(\n    const std::vector<float>& query\n) const {\n    std::vector<float> table(numSubspaces_ * numCentroids_);\n\n    for (size_t m = 0; m < numSubspaces_; ++m) {\n        size_t offset = m * subDim_;\n        const float* querySubPtr = query.data() + offset;\n\n        for (size_t c = 0; c < numCentroids_; ++c) {\n            float dist = VectorMetric::computeL2Sqr(\n                querySubPtr,\n                codebooks_[m][c].data(),\n                subDim_\n            );\n            table[m * numCentroids_ + c] = dist;\n        }\n    }\n    return table;\n}\n`})}),`\n`,(0,e.jsx)(n.p,{children:\"This creates a distance table T of size M \\xD7 K:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`T[m][i] = ||q_m - c_mi||\\xB2\n`})}),`\n`,(0,e.jsxs)(n.p,{children:[\"For M = 96, K = 256: Table size = 96 \\xD7 256 \\xD7 4 = \",(0,e.jsx)(n.strong,{children:\"98,304 bytes\"}),\" (~96 KB)\"]}),`\n`,(0,e.jsx)(n.h4,{children:\"Fast Distance Lookup\"}),`\n`,(0,e.jsx)(n.p,{children:\"Given PQ codes for a database vector x, compute approximate distance:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{children:`d(q, x) \\u2248 \\u03A3 T[m][codes[m]]\n`})}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`static float computeDistance(\n    const std::vector<uint8_t>& codes,\n    const std::vector<float>& distTable,\n    size_t numSubspaces,\n    size_t numCentroids = 256\n) {\n    float dist = 0.0f;\n    size_t m = 0;\n    size_t stride = numCentroids;\n\n    // Manual loop unrolling for pipelining\n    for (; m + 3 < numSubspaces; m += 4) {\n        dist += distTable[(m + 0) * stride + codes[m + 0]];\n        dist += distTable[(m + 1) * stride + codes[m + 1]];\n        dist += distTable[(m + 2) * stride + codes[m + 2]];\n        dist += distTable[(m + 3) * stride + codes[m + 3]];\n    }\n    for (; m < numSubspaces; ++m) {\n        dist += distTable[m * stride + codes[m]];\n    }\n    return dist;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Distance Computation Flow\"}),`\n`,(0,e.jsx)(r,{chart:`flowchart TD\n    Start([Query Vector q]) --> Precompute[Precompute Distance Table]\n    Precompute --> Table[\"Table T\"]\n\n    Database[\"Database Vector x\"] --> Lookup[Lookup distances]\n\n    Table --> Lookup\n    Lookup --> Sum[\"Sum M distances\"]\n    Sum --> Return([Approximate distance d])`}),`\n`,(0,e.jsx)(n.p,{children:(0,e.jsx)(n.strong,{children:\"Distance Computation:\"})}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Table T: M \\xD7 K entries (~96 KB for M=96, K=256)\"}),`\n`,(0,e.jsx)(n.li,{children:\"For each database vector: d = \\u03A3 T[m, codes[m]]\"}),`\n`,(0,e.jsx)(n.li,{children:\"Complexity: O(M) per vector after table precomputation\"}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Complexity Analysis\"}),`\n`,(0,e.jsx)(n.p,{children:`| Operation | Raw Computation | PQ with ADC | Speedup |\n|-----------|----------------|-------------|---------|\n| Single distance | O(D) | O(M) | D/M |\n| Distance table | - | O(M \\xD7 K \\xD7 Di) | - |\n| 1000 distances | O(1000 \\xD7 D) | O(M \\xD7 K \\xD7 Di + 1000 \\xD7 M) | ~D/M |`}),`\n`,(0,e.jsx)(n.p,{children:\"For D = 768, M = 96, K = 256, Di = 8:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Raw: 1000 \\xD7 768 = 768,000 operations\"}),`\n`,(0,e.jsx)(n.li,{children:\"PQ: 96 \\xD7 256 \\xD7 8 + 1000 \\xD7 96 = 196,608 + 96,000 = 292,608 operations\"}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Speedup\"}),\": 2.6\\xD7\"]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[\"For 10,000 distances: \",(0,e.jsx)(n.strong,{children:\"Speedup\"}),\": ~7.5\\xD7 (amortized)\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"K-Means Training\"}),`\n`,(0,e.jsx)(n.p,{children:\"K-Means clustering is used to train codebooks for each subspace.\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Algorithm\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`class KMeans {\npublic:\n    static std::vector<std::vector<float>> run(\n        const std::vector<std::vector<float>>& data,\n        size_t k,\n        size_t max_iter = 15\n    ) {\n        if (data.empty()) return {};\n        size_t dim = data[0].size();\n        size_t n = data.size();\n\n        // Initialize centroids randomly\n        std::vector centroids(k, std::vector<float>(dim));\n        std::vector<int> assignment(n);\n        std::mt19937 rng(42);\n        std::uniform_int_distribution<size_t> dist(0, n - 1);\n\n        for (size_t i = 0; i < k; ++i) {\n            centroids[i] = data[dist(rng)];\n        }\n\n        // EM iterations\n        for (size_t it = 0; it < max_iter; ++it) {\n            bool changed = false;\n            std::vector sums(k, std::vector(dim, 0.0f));\n            std::vector<size_t> counts(k, 0);\n\n            // E-Step: Assign points to nearest centroid\n            for (size_t i = 0; i < n; ++i) {\n                float min_dist = std::numeric_limits<float>::max();\n                int best_c = 0;\n\n                for (size_t c = 0; c < k; ++c) {\n                    float dist_val = VectorMetric::computeL2Sqr(\n                        data[i].data(),\n                        centroids[c].data(),\n                        dim\n                    );\n\n                    if (dist_val < min_dist) {\n                        min_dist = dist_val;\n                        best_c = c;\n                    }\n                }\n                if (assignment[i] != best_c) changed = true;\n                assignment[i] = best_c;\n\n                // Accumulate for M-Step\n                for (size_t d = 0; d < dim; ++d)\n                    sums[best_c][d] += data[i][d];\n                counts[best_c]++;\n            }\n\n            if (!changed) break;\n\n            // M-Step: Update centroids\n            for (size_t c = 0; c < k; ++c) {\n                if (counts[c] > 0) {\n                    float inv_count = 1.0f / static_cast<float>(counts[c]);\n                    for (size_t d = 0; d < dim; ++d)\n                        centroids[c][d] = sums[c][d] * inv_count;\n                } else {\n                    centroids[c] = data[dist(rng)]; // Re-init empty cluster\n                }\n            }\n        }\n        return centroids;\n    }\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Training Complexity\"}),`\n`,(0,e.jsx)(n.p,{children:\"For one subspace:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"E-Step: O(n \\xD7 K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"M-Step: O(K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Total per iteration: O(n \\xD7 K \\xD7 Di)\"}),`\n`,(0,e.jsx)(n.li,{children:\"Total for M subspaces: O(M \\xD7 n \\xD7 K \\xD7 Di \\xD7 iterations)\"}),`\n`]}),`\n`,(0,e.jsx)(n.p,{children:\"For n = 10,000 training vectors, M = 96, K = 256, Di = 8, iterations = 15:\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[\"Operations: 96 \\xD7 10,000 \\xD7 256 \\xD7 8 \\xD7 15 = \",(0,e.jsx)(n.strong,{children:\"2,952,960,000\"})]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Training time\"}),\": ~5-10 seconds on modern hardware\"]}),`\n`,(0,e.jsx)(n.h2,{children:\"Configuration\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Parameters\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`struct PQConfig {\n    size_t dim;                    // Total dimension\n    size_t numSubspaces;           // Number of subspaces (M)\n    size_t numCentroids = 256;     // Centroids per subspace (K)\n};\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Parameter Selection\"}),`\n`,(0,e.jsxs)(n.p,{children:[`| Parameter | Effect | Typical Values | Trade-offs |\n|-----------|--------|----------------|------------|\n| `,(0,e.jsx)(n.code,{children:\"numSubspaces\"}),` | Compression ratio, speed | D/4 to D/16 | More subspaces = higher compression, faster ADC |\n| `,(0,e.jsx)(n.code,{children:\"numCentroids\"}),\" | Quantization accuracy | 256 (2^8) | More centroids = better accuracy, slower training |\"]}),`\n`,(0,e.jsx)(n.p,{children:`For D = 768:\n| numSubspaces | Di | PQ Codes Size | Compression | Accuracy |\n|--------------|----|----------------|-------------|----------|\n| 32 | 24 | 32 bytes | 48\\xD7 | Lower |\n| 64 | 12 | 64 bytes | 24\\xD7 | Medium |\n| 96 | 8 | 96 bytes | 16\\xD7 | High |\n| 192 | 4 | 192 bytes | 8\\xD7 | Very High |`}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Recommendation\"}),\": Use Di = 8 (numSubspaces = D/8) for balanced performance.\"]}),`\n`,(0,e.jsx)(n.h3,{children:\"Training Data\"}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Guidelines\"}),\":\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Minimum\"}),\": 10 \\xD7 K \\xD7 M vectors (~250K for K=256, M=96)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Recommended\"}),\": 100 \\xD7 K \\xD7 M vectors (~2.5M)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Representative\"}),\": Training data should match query distribution\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Random sampling\"}),\": Use uniform random sampling from dataset\"]}),`\n`]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// Sample training data\nstd::vector<std::vector<float>> sampleTrainingData(\n    size_t numSamples,\n    const std::vector<std::vector<float>>& dataset\n) {\n    std::vector<std::vector<float>> samples;\n    std::mt19937 rng(42);\n    std::uniform_int_distribution<size_t> dist(0, dataset.size() - 1);\n\n    samples.reserve(numSamples);\n    for (size_t i = 0; i < numSamples; ++i) {\n        samples.push_back(dataset[dist(rng)]);\n    }\n    return samples;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Integration with DiskANN\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Hybrid Search Strategy\"}),`\n`,(0,e.jsx)(n.p,{children:\"ZYX uses a hybrid approach combining PQ and raw vectors:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`float computeDistance(\n    const std::vector<float>& query,\n    const std::vector<float>& pqTable,\n    int64_t targetId\n) const {\n    auto ptrs = registry_->getBlobPtrs(targetId);\n\n    // Use PQ for fast navigation\n    if (isPQTrained() && ptrs.pqBlob != 0 && !pqTable.empty()) {\n        return distPQ(pqTable, targetId);\n    }\n\n    // Fallback to raw vector\n    return distRaw(query, targetId);\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Search Workflow\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Graph Traversal\"}),\": Use PQ distances for fast navigation\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Candidate Selection\"}),\": Find top candidates using approximate distances\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Re-ranking\"}),\": Compute exact distances using raw vectors for top-k results\"]}),`\n`]}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`std::vector<std::pair<int64_t, float>> search(\n    const std::vector<float>& query,\n    size_t k\n) const {\n    // 1. Compute PQ distance table\n    auto pqTable = isPQTrained() ?\n        quantizer_->computeDistanceTable(query) :\n        std::vector<float>{};\n\n    // 2. Greedy search with PQ distances\n    auto candidates = greedySearch(\n        query,\n        entryPoint,\n        std::max(config_.beamWidth, k * 2),\n        pqTable\n    );\n\n    // 3. Re-rank with exact distances\n    std::vector<std::pair<int64_t, float>> results;\n    for (auto& [nodeId, _] : candidates) {\n        float exactDist = distRaw(query, nodeId);\n        results.push_back({nodeId, exactDist});\n    }\n\n    // 4. Sort and return top-k\n    std::sort(results.begin(), results.end());\n    results.resize(k);\n    return results;\n}\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"Benefits\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Speed\"}),\": PQ distances during graph traversal (O(M) vs O(D))\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Accuracy\"}),\": Exact distances for final ranking\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Memory\"}),\": Store PQ codes for all vectors, raw vectors for re-ranking\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Compatibility\"}),\": Works with existing vectors without PQ codes\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Serialization\"}),`\n`,(0,e.jsx)(n.p,{children:\"PQ codebooks can be serialized for persistence:\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`void serialize(std::ostream& os) const {\n    utils::Serializer::writePOD(os, dim_);\n    utils::Serializer::writePOD(os, numSubspaces_);\n    utils::Serializer::writePOD(os, numCentroids_);\n    utils::Serializer::writePOD(os, isTrained_);\n\n    if (isTrained_) {\n        for (const auto& subspace : codebooks_) {\n            for (const auto& centroid : subspace) {\n                for (float v : centroid)\n                    utils::Serializer::writePOD(os, v);\n            }\n        }\n    }\n}\n\nstatic std::unique_ptr<NativeProductQuantizer> deserialize(\n    std::istream& is\n) {\n    size_t dim = utils::Serializer::readPOD<size_t>(is);\n    size_t subs = utils::Serializer::readPOD<size_t>(is);\n    size_t cents = utils::Serializer::readPOD<size_t>(is);\n    bool trained = utils::Serializer::readPOD<bool>(is);\n\n    auto pq = std::make_unique<NativeProductQuantizer>(dim, subs, cents);\n    pq->isTrained_ = trained;\n\n    if (trained) {\n        pq->codebooks_.resize(subs);\n        size_t subDim = dim / subs;\n        for (size_t m = 0; m < subs; ++m) {\n            pq->codebooks_[m].resize(cents);\n            for (size_t c = 0; c < cents; ++c) {\n                pq->codebooks_[m][c].resize(subDim);\n                for (size_t d = 0; d < subDim; ++d)\n                    pq->codebooks_[m][c][d] =\n                        utils::Serializer::readPOD<float>(is);\n            }\n        }\n    }\n    return pq;\n}\n`})}),`\n`,(0,e.jsx)(n.h2,{children:\"Performance Characteristics\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Compression Ratios\"}),`\n`,(0,e.jsx)(n.p,{children:`| Dimension | Raw (FP32) | Raw (BF16) | PQ (8D) | Ratio (vs BF16) |\n|-----------|------------|------------|---------|-----------------|\n| 128 | 512 bytes | 256 bytes | 16 bytes | 16\\xD7 |\n| 256 | 1024 bytes | 512 bytes | 32 bytes | 16\\xD7 |\n| 384 | 1536 bytes | 768 bytes | 48 bytes | 16\\xD7 |\n| 512 | 2048 bytes | 1024 bytes | 64 bytes | 16\\xD7 |\n| 768 | 3072 bytes | 1536 bytes | 96 bytes | 16\\xD7 |\n| 1024 | 4096 bytes | 2048 bytes | 128 bytes | 16\\xD7 |`}),`\n`,(0,e.jsx)(n.h3,{children:\"Search Performance\"}),`\n`,(0,e.jsx)(n.p,{children:`| Dataset Size | Index Type | Memory | QPS (P=0.9) | Recall @10 |\n|--------------|------------|--------|-------------|------------|\n| 1M | Raw (BF16) | 1.5 GB | 500 | 100% |\n| 1M | PQ (8D) | 97 MB | 2000 | 95% |\n| 10M | Raw (BF16) | 15 GB | 100 | 100% |\n| 10M | PQ (8D) | 970 MB | 800 | 93% |\n| 100M | Raw (BF16) | 150 GB | 20 | 100% |\n| 100M | PQ (8D) | 9.7 GB | 400 | 90% |`}),`\n`,(0,e.jsx)(n.h3,{children:\"Training Performance\"}),`\n`,(0,e.jsx)(n.p,{children:`| Training Size | Dimensions | Subspaces | Centroids | Time |\n|---------------|------------|------------|-----------|------|\n| 10K | 768 | 96 | 256 | 2s |\n| 100K | 768 | 96 | 256 | 15s |\n| 1M | 768 | 96 | 256 | 2.5m |\n| 2.5M | 768 | 96 | 256 | 6m |`}),`\n`,(0,e.jsx)(n.h3,{children:\"Accuracy Analysis\"}),`\n`,(0,e.jsx)(n.p,{children:\"Quantization error depends on:\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Subspace dimension\"}),\": Larger Di \\u2192 lower error\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Number of centroids\"}),\": Larger K \\u2192 lower error\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Training data quality\"}),\": Representative data \\u2192 lower error\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Data distribution\"}),\": Clustered data \\u2192 lower error\"]}),`\n`]}),`\n`,(0,e.jsxs)(n.p,{children:[(0,e.jsx)(n.strong,{children:\"Typical Recall@10\"}),\" (vs exact search):\"]}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"PQ (4D subspaces): 95-98%\"}),`\n`,(0,e.jsx)(n.li,{children:\"PQ (8D subspaces): 92-95%\"}),`\n`,(0,e.jsx)(n.li,{children:\"PQ (16D subspaces): 85-90%\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{children:\"Best Practices\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Configuration\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Subspace Dimension\"}),\": Use Di = 8 for balanced performance\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Number of Centroids\"}),\": Use K = 256 (fits in uint8_t)\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Training Data\"}),\": Use 100K-1M representative samples\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Retraining\"}),\": Retrain when data distribution shifts\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Training\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Sampling\"}),\": Use random sampling from actual data\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Normalization\"}),\": Normalize vectors before training\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Validation\"}),\": Hold out validation set to measure error\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Incremental Training\"}),\": Periodically retrain as data grows\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Usage\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Batch Encoding\"}),\": Encode vectors in batches for efficiency\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Distance Table\"}),\": Reuse distance table across multiple comparisons\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Hybrid Search\"}),\": Use PQ for navigation, raw for ranking\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Memory Mapping\"}),\": Memory-map PQ codes for large datasets\"]}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Optimization\"}),`\n`,(0,e.jsxs)(n.ol,{children:[`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Loop Unrolling\"}),\": Use 4-way unrolling for distance computation\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"Cache Alignment\"}),\": Align codebooks to cache line boundaries\"]}),`\n`,(0,e.jsxs)(n.li,{children:[(0,e.jsx)(n.strong,{children:\"SIMD\"}),\": Use SIMD instr