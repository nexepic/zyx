lassName:\"language-cpp\",children:`// \\u521B\\u5EFA\\u6807\\u7B7E\\u7D22\\u5F15\nLabelIndex labelIndex(dataManager, systemStateManager,\n                      IndexTypes::NODE_LABEL_TYPE,\n                      StateKeys::NODE_LABEL_ROOT);\n\n// \\u6DFB\\u52A0\\u5E26\\u6807\\u7B7E\\u7684\\u8282\\u70B9\nlabelIndex.addNode(1, \"Person\");\nlabelIndex.addNode(2, \"Company\");\nlabelIndex.addNode(3, \"Person\");\n\n// \\u67E5\\u627E\\u5177\\u6709\\u67D0\\u4E2A\\u6807\\u7B7E\\u7684\\u6240\\u6709\\u8282\\u70B9\nauto persons = labelIndex.findNodes(\"Person\");     // [1, 3]\nauto companies = labelIndex.findNodes(\"Company\");  // [2]\n\n// \\u68C0\\u67E5\\u8282\\u70B9\\u662F\\u5426\\u6709\\u6807\\u7B7E\nbool isPerson = labelIndex.hasLabel(1, \"Person\");   // true\nbool isCompany = labelIndex.hasLabel(1, \"Company\"); // false\n\n// \\u4ECE\\u6807\\u7B7E\\u4E2D\\u79FB\\u9664\\u8282\\u70B9\nlabelIndex.removeNode(1, \"Person\");\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u6279\\u91CF\\u5BFC\\u5165\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// \\u6279\\u91CF\\u5BFC\\u5165\\u4EE5\\u63D0\\u9AD8\\u6027\\u80FD\nstd::unordered_map<std::string, std::vector<int64_t>> nodesByLabel;\n\nnodesByLabel[\"Person\"] = {1, 2, 3, 4, 5};\nnodesByLabel[\"Company\"] = {10, 20, 30, 40, 50};\nnodesByLabel[\"Location\"] = {100, 200, 300};\n\n// \\u5355\\u4E2A\\u9AD8\\u6548\\u64CD\\u4F5C\nlabelIndex.addNodesBatch(nodesByLabel);\n`})}),`\n`,(0,e.jsx)(n.h3,{children:\"\\u7D22\\u5F15\\u7BA1\\u7406\"}),`\n`,(0,e.jsx)(n.pre,{children:(0,e.jsx)(n.code,{className:\"language-cpp\",children:`// \\u521B\\u5EFA\\uFF08\\u542F\\u7528\\uFF09\\u7D22\\u5F15\nlabelIndex.createIndex();\n\n// \\u68C0\\u67E5\\u72B6\\u6001\nif (labelIndex.isEnabled()) {\n    std::cout << \"\\u7D22\\u5F15\\u5DF2\\u6FC0\\u6D3B\" << std::endl;\n}\n\n// \\u91CD\\u5EFA\\u7D22\\u5F15\nlabelIndex.clear();\n// ... \\u4F7F\\u7528\\u5F53\\u524D\\u6570\\u636E\\u91CD\\u65B0\\u586B\\u5145 ...\n\n// \\u5