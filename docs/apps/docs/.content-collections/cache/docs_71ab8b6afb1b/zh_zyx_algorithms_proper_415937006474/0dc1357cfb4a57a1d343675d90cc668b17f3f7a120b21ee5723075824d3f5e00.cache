e);\n    const auto rootIt = rootMap.find(key);\n\n    if (rootIt == rootMap.end()) {\n        return; // \\u6B64\\u952E\\u65E0\\u6839\n    }\n\n    // 4. \\u4ECE B+Tree \\u5220\\u9664\n    (void) treeManager->remove(rootMap.at(key), value, entityId);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"\\u7279\\u6027\"}),\"\\uFF1A\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u65F6\\u95F4\\u590D\\u6742\\u5EA6\"}),\"\\uFF1AO(log n)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u81EA\\u52A8\\u91CD\\u5E73\\u8861\"}),\"\\uFF1AB+Tree \\u901A\\u8FC7\\u5408\\u5E76/\\u91CD\\u65B0\\u5206\\u914D\\u5904\\u7406\\u4E0B\\u6EA2\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u7C7B\\u578B\\u9A8C\\u8BC1\"}),\"\\uFF1A\\u4EC5\\u5F53\\u7C7B\\u578B\\u5339\\u914D\\u6CE8\\u518C\\u7C7B\\u578B\\u65F6\\u5220\\u9664\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"\\u67E5\\u627E\\u7CBE\\u786E\\u5339\\u914D\"}),`\n`,(0,n.jsx)(e.p,{children:\"\\u68C0\\u7D22\\u5177\\u6709\\u7CBE\\u786E\\u5C5E\\u6027\\u503C\\u5339\\u914D\\u7684\\u5B9E\\u4F53\\uFF1A\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`std::vector<int64_t> PropertyIndex::findExactMatch(\n    const std::string &key,\n    const PropertyValue &value\n) const {\n    std::shared_lock lock(mutex_);\n\n    // 1. \\u83B7\\u53D6\\u503C\\u7C7B\\u578B\n    const PropertyType valueType = getPropertyType(value);\n\n    // 2. \\u68C0\\u67E5\\u952E\\u662F\\u5426\\u4EE5\\u5339\\u914D\\u7C7B\\u578B\\u7D22\\u5F15\n    if (const auto it = indexedKeyTypes_.find(key);\n        it == indexedKeyTypes_.end() || it->second != valueType) {\n        return {};\n    }\n\n    // 3. \\u83B7\\u53D6\\u7C7B\\u578B\\u7279\\u5B9A\\u7684\\u6839\\u6620\\u5C04\n    const auto &rootMap = getRootMapForType(valueType);\n    const auto rootIt = rootMap.find(key);\n\n    if (rootIt == rootMap.end()) {\n        return {};\