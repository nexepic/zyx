eType) {\n            // \\u7C7B\\u578B\\u4E0D\\u5339\\u914D\\uFF0C\\u8DF3\\u8FC7\\u6B64\\u5C5E\\u6027\n            continue;\n        }\n\n        // \\u6DFB\\u52A0\\u5230\\u5206\\u7EC4\\u6279\\u91CF\n        groupedBatch[registeredType][key].emplace_back(value, entityId);\n    }\n\n    // 2. \\u6279\\u91CF\\u63D2\\u5165\\u9636\\u6BB5\n    for (auto &[type, keyMap]: groupedBatch) {\n        auto treeManager = getTreeManagerForType(type);\n        auto &rootMap = getRootMapForType(type);\n\n        if (!treeManager)\n            continue;\n\n        for (auto &[key, entries]: keyMap) {\n            if (entries.empty())\n                continue;\n\n            // \\u786E\\u4FDD\\u6839\\u5B58\\u5728\n            if (!rootMap.contains(key)) {\n                rootMap[key] = treeManager->initialize();\n            }\n\n            int64_t currentRootId = rootMap[key];\n\n            // \\u5728 B+Tree \\u4E0A\\u6267\\u884C\\u6279\\u91CF\\u63D2\\u5165\n            int64_t newRootId = treeManager->insertBatch(currentRootId, entries);\n\n            // \\u5982\\u679C\\u6811\\u589E\\u957F\\u5219\\u66F4\\u65B0\\u6839\n            if (newRootId != currentRootId) {\n                rootMap[key] = newRootId;\n            }\n        }\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"\\u4F18\\u5316\"}),\"\\uFF1A\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u5355\\u6B21\\u9501\\u83B7\\u53D6\"}),\"\\uFF1A\\u76F8\\u6BD4\\u5355\\u72EC\\u63D2\\u5165\\u51CF\\u5C11\\u4E89\\u7528\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u57FA\\u4E8E\\u7C7B\\u578B\\u7684\\u5206\\u7EC4\"}),\"\\uFF1A\\u6700\\u5C0F\\u5316\\u6811\\u7BA1\\u7406\\u5668\\u5207\\u6362\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"\\u57FA\\u4E8E\\u952E\\u7684\\u5206\\u7EC4\"}),\"\\uFF1A\\u4F18\\u5316 B+Tree \\u6279\\u91CF\\u63D2\\u5165\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{chi