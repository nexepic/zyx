");\nlabelIndex.addNode(3, \"Person\");\n\n// Find all nodes with a label\nauto persons = labelIndex.findNodes(\"Person\");  // [1, 3]\nauto companies = labelIndex.findNodes(\"Company\"); // [2]\n\n// Check if node has label\nbool isPerson = labelIndex.hasLabel(1, \"Person\");  // true\nbool isCompany = labelIndex.hasLabel(1, \"Company\"); // false\n\n// Remove node from label\nlabelIndex.removeNode(1, \"Person\");\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Batch Import\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Batch import for performance\nstd::unordered_map<std::string, std::vector<int64_t>> nodesByLabel;\n\nnodesByLabel[\"Person\"] = {1, 2, 3, 4, 5};\nnodesByLabel[\"Company\"] = {10, 20, 30, 40, 50};\nnodesByLabel[\"Location\"] = {100, 200, 300};\n\n// Single efficient operation\nlabelIndex.addNodesBatch(nodesByLabel);\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Index Management\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Create (enable) index\nlabelIndex.createIndex();\n\n// Check status\nif (labelIndex.isEnabled()) {\n    std::cout << \"Index is active\" << std::endl;\n}\n\n// Rebuild index\nlabelIndex.clear();\n// ... repopulate with current data ...\n\n// Drop index completely\nlabelIndex.drop();\n\n// Persist state\nlabelIndex.flush();\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Best Practices\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Enable Early\"}),\": Create label indexes before adding data for optimal performance\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Batch Imports\"}),\": Use \",(0,n.jsx)(e.code,{children:\"addNodesBatch\"}),\" for bulk operations\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Monitor State\"}),\": Check \",(0,n.jsx)(e.code,{children:\"isEnabled()\"}),\" and \",(0,n.jsx)(e.code,{children:\"hasPhysicalData()\"}),\" status\"]}),`\n`,(0,n.jsxs)(e.li