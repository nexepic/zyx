 int64_t insert(int64_t rootId, const PropertyValue &key, int64_t value);\n    int64_t insertBatch(int64_t rootId,\n                       const std::vector<std::pair<PropertyValue, int64_t>> &entries);\n\n    // Remove operations\n    bool remove(int64_t &rootId, const PropertyValue &key, int64_t value);\n\n    // Query operations\n    std::vector<int64_t> find(int64_t rootId, const PropertyValue &key) const;\n\n    // Tree management\n    void clear(int64_t rootId) const;\n    int64_t findLeafNode(int64_t rootId, const PropertyValue &key) const;\n\nprivate:\n    std::shared_ptr<storage::DataManager> dataManager_;\n    mutable std::shared_mutex mutex_;\n    uint32_t indexType_;\n    PropertyType keyDataType_;\n    std::function<bool(const PropertyValue &, const PropertyValue &)> keyComparator_;\n};\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Key Features\"}),`\n`,(0,n.jsxs)(e.ol,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Duplicate Key Support\"}),\": Multiple node IDs can share the same label\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Automatic Rebalancing\"}),\": Split/merge operations maintain balance\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Blob Storage\"}),\": Large key/value lists stored externally\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Type Safety\"}),\": String keys for labels, int64_t values for node IDs\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Concurrency Control\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Shared Mutex\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"The label index uses \",(0,n.jsx)(e.code,{children:\"std::shared_mutex\"}),\" for concurrent access:\"]}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`mutable std::shared_mutex mutex_;\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Lock Types\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Shared Lock\"}),\" (\",(0,n.jsx)(e.code,{children:\"std::shared_lock\"}),\"): Concurrent reads allowed\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Exclusive Lock\"}),\" (\",(0,n.jsx)(e.code,{children:\"std::unique_lock\"}),\"): Writes require exclusive access\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Lock Strategy\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[\"Read operations (\",(0,n.jsx)(e.code,{children:\"findNodes\"}),\", \",(0,n.jsx)(e.code,{children:\"hasLabel\"}),\"): Shared lock\"]}),`\n`,(0,n.jsxs)(e.li,{children:[\"Write operations (\",(0,n.jsx)(e.code,{children:\"addNode\"}),\", \",(0,n.jsx)(e.code,{children:\"removeNode\"}),\"): Exclusive lock\"]}),`\n`,(0,n.jsxs)(e.li,{children:[\"State queries (\",(0,n.jsx)(e.code,{children:\"isEmpty\"}),\", \",(0,n.jsx)(e.code,{children:\"isEnabled\"}),\"): Shared lock\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Performance Implications\"}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"High read concurrency\"}),\": Multiple threads can query simultaneously\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Write serialization\"}),\": Only one writer at a time\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"No reader-writer starvation\"}),\": Fair scheduling\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Multi-Label Support\"}),`\n`,(0,n.jsx)(e.p,{children:\"Nodes can have multiple labels indexed simultaneously:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Node with multiple labels\nlabelIndex.addNode(1, \"Person\");\nlabelIndex.addNode(1, \"Employee\");\nlabelIndex.addNode(1, \"Manager\");\n\n// Query by any label\nauto persons = labelIndex.findNodes(\"Person\");    // Returns [1, ...]\nauto employees = labelIndex.findNodes(\"Employee\"); // Returns [1, ...]\nauto managers = labelIndex.findNodes(\"Manager\");   // Returns [1, ...]\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Each label \\u2192 node ID mapping is independent\"}),`\n`,(0,n.jsx)(e.li,{children:\"Removing a node from one label doesn't affect others\"}),`\n`,(0,n.jsx)(e.li,{children:\"B+Tree structure naturally supports multi-value keys\"}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Integration with Cypher Query\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Query Planning\"}),`\n`,(0,n.jsx)(e.p,{children:\"The query planner uses label index for optimization:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cypher\",children:`-- Query with label filter\nMATCH (n:Person) RETURN n;\n\n-- Planner optimization\n1. Check if label index exists for \"Person\"\n2. If exists: Use LabelIndex.findNodes(\"Person\")\n3. If not: Full node scan with label filter\n`})}),`\n`,(0,n.jsx)(e.h3,{children:\"Query Execution\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`// Pseudo-code for query execution\nstd::vector<Node> executeLabelScan(const std::string &label) {\n    // Use label index if available\n    if (indexManager->hasLabelIndex(\"Node\")) {\n        auto nodeIds = labelIndex.findNodes(label);\n        return fetchNodesByIds(nodeIds);\n    }\n\n    // Fallback to full scan\n    return fullScanWithLabelFilter(label);\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Performance Comparison\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"With Index\"}),\": O(log n + k) where k = nodes with label\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Without Index\"}),\": O(N) where N = total nodes\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h2,{children:\"Performance Characteristics\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Time Complexity\"}),`\n`,(0,n.jsx)(e.p,{ch