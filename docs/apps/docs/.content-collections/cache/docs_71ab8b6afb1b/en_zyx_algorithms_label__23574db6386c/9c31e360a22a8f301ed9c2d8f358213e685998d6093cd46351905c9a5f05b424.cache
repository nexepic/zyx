vector<int64_t>> &nodesByLabel);\n    void removeNode(int64_t nodeId, const std::string &label);\n    std::vector<int64_t> findNodes(const std::string &label) const;\n    bool hasLabel(int64_t entityId, const std::string &label) const;\n\n    // Lifecycle management\n    void initialize();\n    void createIndex();\n    void clear();\n    void drop();\n    void flush() const;\n    void saveState() const;\n\n    // Status queries\n    bool isEmpty() const;\n    bool isEnabled() const;\n    bool hasPhysicalData() const;\n\nprivate:\n    std::shared_ptr<storage::DataManager> dataManager_;\n    std::shared_ptr<storage::state::SystemStateManager> systemStateManager_;\n    std::shared_ptr<IndexTreeManager> treeManager_;\n    mutable std::shared_mutex mutex_;\n    int64_t rootId_ = 0;\n    bool enabled_ = false;\n    const std::string stateKey_;\n};\n`})}),`\n`,(0,n.jsx)(e.h2,{children:\"Core Operations\"}),`\n`,(0,n.jsx)(e.h3,{children:\"Initialization\"}),`\n`,(0,n.jsx)(e.p,{children:\"The label index is initialized from persistent state on startup:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void LabelIndex::initialize() {\n    std::unique_lock lock(mutex_);\n\n    // 1. Load Root ID from persistent state\n    rootId_ = systemStateManager_->get<int64_t>(\n        stateKey_,\n        storage::state::keys::Fields::ROOT_ID,\n        0\n    );\n\n    // 2. Load Enabled Config\n    std::string configKey = stateKey_ + storage::state::keys::SUFFIX_CONFIG;\n    enabled_ = systemStateManager_->get<bool>(\n        configKey,\n        storage::state::keys::Fields::ENABLED,\n        false\n    );\n\n    // Fallback: If we have physical data, force enable\n    if (!enabled_ && rootId_ != 0) {\n        enabled_ = true;\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Key Points\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsx)(e.li,{children:\"Root ID is persisted in system state\"}),`\n`,(0,n.jsx)(e.li,{children:\"Enabled flag controls whether index is active\"}),`\n`,(0,n.jsx)(e.li,{children:\"Physical data (rootId_ != 0) forces enablement to prevent data drift\"}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Add Node\"}),`\n`,(0,n.jsx)(e.p,{children:\"Adds a single node to the label index:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void LabelIndex::addNode(int64_t entityId, const std::string &label) {\n    std::unique_lock lock(mutex_);\n\n    // Initialize B+Tree if needed\n    if (rootId_ == 0) {\n        rootId_ = treeManager_->initialize();\n    }\n\n    // Insert into B+Tree (label \\u2192 nodeId mapping)\n    int64_t newRootId = treeManager_->insert(rootId_, label, entityId);\n\n    // Update root if tree split occurred\n    if (newRootId != rootId_) {\n        rootId_ = newRootId;\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Characteristics\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Time Complexity\"}),\": O(log n) where n is the number of unique labels\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Space Complexity\"}),\": O(1) amortized (B+Tree growth)\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Concurrency\"}),\": Exclusive lock ensures thread safety\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Batch Add Nodes\"}),`\n`,(0,n.jsx)(e.p,{children:\"Optimized bulk insertion for multiple nodes:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void LabelIndex::addNodesBatch(\n    const std::unordered_map<std::string, std::vector<int64_t>> &nodesByLabel\n) {\n    // Single lock for entire batch\n    std::unique_lock lock(mutex_);\n\n    if (rootId_ == 0) {\n        rootId_ = treeManager_->initialize();\n    }\n\n    // Process each label group\n    for (const auto &[label, entityIds]: nodesByLabel) {\n        if (entityIds.empty())\n            continue;\n\n        // Prepare batch entries\n        std::vector<std::pair<PropertyValue, int64_t>> batchEntries;\n        batchEntries.reserve(entityIds.size());\n\n        for (int64_t id: entityIds) {\n            batchEntries.emplace_back(PropertyValue(label), id);\n        }\n\n        // Perform batch insertion\n        int64_t newRootId = treeManager_->insertBatch(rootId_, batchEntries);\n\n        if (newRootId != rootId_) {\n            rootId_ = newRootId;\n        }\n    }\n}\n`})}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Optimizations\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Single lock acquisition\"}),\": Reduces contention compared to individual inserts\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Batch preparation\"}),\": Minimizes memory allocations\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Grouped by label\"}),\": Optimizes for B+Tree structure\"]}),`\n`]}),`\n`,(0,n.jsxs)(e.p,{children:[(0,n.jsx)(e.strong,{children:\"Performance\"}),\":\"]}),`\n`,(0,n.jsxs)(e.ul,{children:[`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Throughput\"}),\": ~10x faster than individual inserts for large batches\"]}),`\n`,(0,n.jsxs)(e.li,{children:[(0,n.jsx)(e.strong,{children:\"Use Case\"}),\": Index building during database startup or bulk import\"]}),`\n`]}),`\n`,(0,n.jsx)(e.h3,{children:\"Remove Node\"}),`\n`,(0,n.jsx)(e.p,{children:\"Removes a node from the label index:\"}),`\n`,(0,n.jsx)(e.pre,{children:(0,n.jsx)(e.code,{className:\"language-cpp\",children:`void LabelIndex::removeNode(int64_t entityId, const std::string &label) {\n    std::unique_lock lock(mutex_);\n\n    if (rootId_ == 0) {\n        return;\n    }\n\n    // Remove from B+Tree\n    bool success = treeManager_->remove(rootId_, label, entityId);\n\n    // Note: Underflow handling is automatic in IndexTreeManager\n    (void) success;\n