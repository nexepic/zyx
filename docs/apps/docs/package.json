{
  "name": "zyx-docs-temp-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun run check:links && next build",
    "check:links": "node ./scripts/check-doc-links.mjs",
    "build:gh-pages": "BASE_PATH=/nexdoc bun run build",
    "start": "next start",
    "clean": "rm -rf .next .swc .content-collections tsconfig.tsbuildinfo",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@content-collections/core": "^0.14.3",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@theguild/remark-mermaid": "^0.3.0",
    "clsx": "^2.1.0",
    "flexsearch": "^0.8.212",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.13.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6",
    "@nexdoc/core": "workspace:*"
